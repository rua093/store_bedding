    height: 5.1rem;
    border: 1px solid rgba(120, 84, 58, 0.16);
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 249, 242, 0.88) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.92),
      0 10px 22px rgba(47, 36, 29, 0.04);
  }

