      line-height: 1.06;
      letter-spacing: -0.025em;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .product-details--main-product product-price :is(.price__regular, .price__sale) {
      font-size: clamp(1.15rem, 5.4vw, 1.45rem);
      line-height: 1.08;
    }

