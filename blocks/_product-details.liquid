    .product-details--main-product > .group-block > .group-block-content > .rating-wrapper,
    .product-details--main-product > .group-block > .group-block-content > product-price,
    .product-details--main-product > .group-block > .group-block-content > variant-picker,
    .product-details--main-product > .group-block > .group-block-content > .buy-buttons-block {
      padding-inline: 18px;
