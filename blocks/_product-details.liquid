  }

  .product-details--main-product product-price {
    gap: 10px;
    color: #3b2c24;
  }

  .product-details--main-product product-price > [ref='priceContainer'],
  .product-details--main-product product-price .price {
    width: 100%;
  }

  .product-details--main-product product-price > [ref='priceContainer'] {
    display: grid;
    gap: 0;
  }

  .product-details--main-product product-price :is(.price__regular, .price__sale) {
    font-size: clamp(1.4rem, 1.8vw, 1.75rem);
    line-height: 1.12;
    font-weight: 600;
  }

  .product-details--main-product .price__sale-layout {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
  }

  .product-details--main-product .compare-at-price {
    font-size: 0.92em;
    color: #b19f93;
    text-decoration-thickness: 1px;
  }

  .product-details--main-product .price-sale-badge {
    display: inline-flex;
    align-items: center;
    min-height: 1.95rem;
    padding: 0.32rem 0.78rem;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(249, 239, 230, 0.98) 0%, rgba(245, 232, 220, 0.96) 100%);
    color: #9f7656;
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .product-details--main-product .tax-note,
  .product-details--main-product .installments,
  .product-details--main-product .volume-pricing-note {
    color: #7b6657;
    font-size: 0.9rem;
    line-height: 1.45;
  }

  .product-details--main-product .tax-note {
    display: none;
  }

  .product-details--main-product .price-callouts {
    display: grid;
    gap: 0.6rem;
    margin-top: 0.7rem;
  }

  .product-details--main-product .price-discount-message,
  .product-details--main-product .price-shipping-line {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    width: fit-content;
    max-width: 100%;
    font-size: 0.92rem;
    line-height: 1.4;
  }

  .product-details--main-product .price-discount-message {
    padding: 0.6rem 0.85rem;
    border-radius: 10px;
    background: linear-gradient(90deg, rgba(245, 228, 255, 0.82) 0%, rgba(246, 236, 255, 0.92) 100%);
    color: #8d58a8;
  }

  .product-details--main-product .price-shipping-line {
    color: #7a675a;
  }

  .product-details--main-product .price-discount-message__icon,
  .product-details--main-product .price-shipping-line__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    flex: 0 0 auto;
  }

  .product-details--main-product .price-discount-message__icon {
    color: #8d58a8;
  }

  .product-details--main-product .price-shipping-line__icon {
    color: #8f603e;
  }

