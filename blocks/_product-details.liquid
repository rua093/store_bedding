      padding-bottom: 8px;
      border-top-left-radius: 0;
      border-top-right-radius: 0;
      box-shadow: none;
    }

    .product-details--main-product > .group-block > .group-block-content > .rating-wrapper {
      padding-top: 10px;
      padding-bottom: 10px;
    }

    .product-details--main-product > .group-block > .group-block-content > product-price {
      padding-top: 10px;
      padding-bottom: 12px;
    }

    .product-details--main-product > .group-block > .group-block-content > variant-picker {
      padding-top: 12px;
      padding-bottom: 12px;
    }

    .product-details--main-product > .group-block > .group-block-content > .buy-buttons-block {
      padding-top: 10px;
      padding-bottom: 10px;
      border-bottom-left-radius: 0;
      border-bottom-right-radius: 0;
      box-shadow: none;
    }

    .product-details--main-product > .group-block > .group-block-content > rte-formatter,
    .product-details--main-product > .group-block > .group-block-content > .accordion {
      margin-top: 18px;
      padding: 18px;
      border-radius: 18px;
    }

    .product-details--main-product > .group-block > .group-block-content > .text-block.h2:first-of-type :is(h1, h2, h3, h4, h5, h6) {
