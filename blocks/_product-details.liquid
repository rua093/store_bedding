    .product-details > .group-block {
      height: min-content;
    }

    .product-information--main-product .product-details--main-product {
      padding-top: clamp(4px, 0.55vw, 8px);
    }

    .product-details--main-product.sticky-content--desktop {
      position: sticky;
      top: calc(var(--header-height, 80px) + 24px);
      align-self: start;
    }

    .full-height--desktop {
      height: 100%;
      max-height: calc(100vh - var(--header-group-height, 0));
      min-height: fit-content;
    }

    .full-height--desktop .group-block {
      align-self: var(--details-position, 'flex-start');
    }
  }

