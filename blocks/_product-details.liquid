
{%- assign block_settings = block.settings -%}
<div
  id="ProductInformation-{{ section.id }}"
  class="
    product-details
    {% if request.page_type == 'product' %} product-details--main-product{% endif %}
    {% if block_settings.sticky_details_desktop %} sticky-content--desktop{% endif %}
    {% if block_settings.height == 'fill' -%} full-height--desktop{% endif -%}
  "
  style="--details-position: {{ block_settings.details_position }};"
  data-testid="product-information-details"
  {% if settings.transition_to_main_product %}
    data-view-transition-type="product-details"
  {% endif %}
>
  {% capture children %}
    <div class="view-product-title">
      <a
        href="{{ closest.product.selected_or_first_available_variant.url }}"
      >
        {{- closest.product.title }}
      </a>
    </div>
    {% content_for 'blocks' %}
  {% endcapture %}

  {% render 'group',
    children: children,
    settings: block_settings,
    shopify_attributes: block.shopify_attributes,
    background_color: block_settings.background_color,
    block_id: block.id
  %}
</div>

<script>
  (() => {
    const enhanceProductDescriptions = () => {
      document.querySelectorAll('[data-product-details-below] rte-formatter').forEach((description) => {
        if (description.dataset.enhanced === 'true') return;

        const children = Array.from(description.children);
        if (!children.length) return;

        const getHeadingIndex = (matcher) =>
          children.findIndex(
            (node) =>
              /^H[1-6]$/.test(node.tagName) &&
              matcher((node.textContent || '').trim().toLowerCase())
          );

        const featuresIndex = getHeadingIndex((text) => text.includes('key features'));
        const specsIndex = getHeadingIndex((text) => text.includes('product specifications'));

        const introNodes =
          featuresIndex > -1 ? children.slice(0, featuresIndex) : specsIndex > -1 ? children.slice(0, specsIndex) : children;
        const featureNodes =
          featuresIndex > -1
            ? children.slice(featuresIndex, specsIndex > -1 ? specsIndex : children.length)
            : [];
        const specNodes = specsIndex > -1 ? children.slice(specsIndex) : [];

        const layout = document.createElement('div');
        layout.className = 'product-description-rich__layout';

        const createSection = (name, nodes) => {
          if (!nodes.length) return null;
          const section = document.createElement('section');
          section.className = `product-description-rich__section product-description-rich__section--${name}`;
          nodes.forEach((node) => section.appendChild(node));
          return section;
        };

        const introSection = createSection('intro', introNodes);
        const featureSection = createSection('features', featureNodes);
        const specsSection = createSection('specs', specNodes);

        if (introSection) layout.appendChild(introSection);
        if (featureSection) layout.appendChild(featureSection);
        if (specsSection) layout.appendChild(specsSection);

        description.classList.add('product-description-rich');
        description.style.setProperty('--width', '100%');
        description.style.setProperty('--max-width', '9999px');
        description.innerHTML = '';
        description.appendChild(layout);
        description.dataset.enhanced = 'true';
      });
    };

    const moveProductDetailsBelow = () => {
      document.querySelectorAll('.product-information--main-product').forEach((section) => {
        const source = section.querySelector(
          '.product-details--main-product > .group-block > .group-block-content'
        );
        const target = section.querySelector('[data-product-details-below]');

        if (!source || !target) return;

        const detailBlocks = source.querySelectorAll(':scope > rte-formatter, :scope > .accordion');

        if (!detailBlocks.length) return;

        detailBlocks.forEach((block) => {
          target.appendChild(block);
        });

        target.hidden = false;
      });

      enhanceProductDescriptions();
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', moveProductDetailsBelow, { once: true });
    } else {
      moveProductDetailsBelow();
    }

    document.addEventListener('shopify:section:load', moveProductDetailsBelow);
  })();
</script>

{% stylesheet %}
  /* Clear padding on mobile, if not full-width */
  @media screen and (max-width: 749px) {
    .product-information.section--page-width .product-details > .group-block {
      padding-inline: 0;
    }
  }

  .view-product-title {
    display: none;
    position: absolute;
  }

  /* Container styles */
  .product-details {
    display: flex;
    align-self: start;
    justify-content: center;
  }

  .product-details--main-product {
    --product-info-surface: linear-gradient(180deg, rgba(255, 255, 255, 0.34) 0%, rgba(255, 250, 244, 0.2) 100%);
    --product-info-border: rgba(120, 84, 58, 0.11);
    --product-info-shadow: none;
    --product-info-highlight: inset 0 1px 0 rgba(255, 255, 255, 0.58);
    width: 100%;
  }

  .product-details--main-product > .group-block {
    width: 100%;
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
    padding: 0;
    gap: 0;
  }

  .product-details--main-product > .group-block > .group-block__media-wrapper {
    display: none;
  }

  .product-details--main-product > .group-block > .group-block-content {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    grid-auto-flow: row;
    align-content: start;
    gap: 0;
    width: min(100%, 42rem);
    margin-inline: auto;
  }

  .product-details--main-product > .group-block > .group-block-content > .text-block.h2,
  .product-details--main-product > .group-block > .group-block-content > .rating-wrapper,
  .product-details--main-product > .group-block > .group-block-content > product-price,
  .product-details--main-product > .group-block > .group-block-content > variant-picker,
  .product-details--main-product > .group-block > .group-block-content > .buy-buttons-block {
    background: var(--product-info-surface);
    border-inline: 0;
    box-shadow: var(--product-info-highlight);
    padding-inline: clamp(22px, 2.4vw, 34px);
  }

  .product-details--main-product > .group-block > .group-block-content > .text-block.h2 {
    padding-top: clamp(8px, 0.8vw, 12px);
    padding-bottom: 8px;
    border-top: 0;
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    box-shadow: none;
  }

  .product-details--main-product > .group-block > .group-block-content > .rating-wrapper,
  .product-details--main-product > .group-block > .group-block-content > product-price,
  .product-details--main-product > .group-block > .group-block-content > variant-picker,
  .product-details--main-product > .group-block > .group-block-content > .buy-buttons-block {
    border-top: 0;
  }

  .product-details--main-product > .group-block > .group-block-content > .rating-wrapper {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-top: 8px;
    padding-bottom: 8px;
    border-top: 1px solid rgba(184, 115, 69, 0.16);
    color: #7c6859;
    --star-fill-color: #d8a43a;
    --star-fill-color-rgb: 216, 164, 58;
  }

  .product-details--main-product > .group-block > .group-block-content > product-price {
    padding-top: 10px;
    padding-bottom: 12px;
  }

  .product-details--main-product > .group-block > .group-block-content > variant-picker {
    padding-top: 8px;
    padding-bottom: 8px;
  }

  .product-details--main-product > .group-block > .group-block-content > .buy-buttons-block {
    padding-top: 6px;
    padding-bottom: clamp(6px, 0.8vw, 10px);
    border-bottom: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    box-shadow: none;
  }

  .product-details--main-product > .group-block > .group-block-content > rte-formatter,
  .product-details--main-product > .group-block > .group-block-content > .accordion {
    background: rgba(255, 250, 244, 0.74);
    border: 1px solid rgba(92, 61, 42, 0.1);
    border-radius: 20px;
    margin-top: 20px;
    padding: 22px 24px;
  }

  .product-details--main-product > .group-block > .group-block-content > .group-block {
    display: none;
  }

  .product-details--main-product > .group-block > .group-block-content > .text-block.h2:first-of-type {
    margin-bottom: 0;
  }

  .product-details--main-product > .group-block > .group-block-content > .text-block.h2:first-of-type :is(h1, h2, h3, h4, h5, h6) {
    max-width: 15ch;
    font-size: clamp(29px, 2.45vw, 42px);
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: #3f2f26;
  }

  .product-details--main-product > .group-block > .group-block-content > :is(variant-picker, .buy-buttons-block) > *:first-child {
    margin-top: 0;
