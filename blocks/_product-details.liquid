      0 0 0 1px rgba(184, 115, 69, 0.26),
      0 12px 24px rgba(184, 115, 69, 0.12);
  }

  .product-details--main-product .product-personalizer__summary {
    gap: 0.3rem;
    padding-top: 0;
    color: #7b6657;
    font-size: 0.88rem;
    line-height: 1.5;
  }

