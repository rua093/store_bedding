    margin-bottom: 0.6rem;
    color: #43342b;
    font-size: 0.98rem;
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: -0.01em;
  }

  .product-details--main-product .personalizer-group__options {
    gap: 0.55rem;
  }

