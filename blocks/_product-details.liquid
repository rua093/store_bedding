  .product-details--main-product > .group-block > .group-block-content > .rating-wrapper .rating {
    gap: 2px;
  }

  .product-details--main-product > .group-block > .group-block-content > .rating-wrapper .stars {
    height: 0.98rem;
  }

  .product-details--main-product > .group-block > .group-block-content > .rating-wrapper .rating-count,
  .product-details--main-product > .group-block > .group-block-content > .rating-wrapper .rating-count-separator {
