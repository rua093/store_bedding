{% liquid
  assign icon_name = icon | default: 'sparkle'
%}

{% case icon_name %}
  {% when 'package' %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none"><path d="M4 7.5 12 3l8 4.5m-16 0 8 4.5m-8-4.5V16.5L12 21m0-9v9m0-9 8-4.5m0 0V16.5L12 21M8.2 5.15l8 4.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {% when 'eye' %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none"><path d="M2.8 12s3.4-6 9.2-6 9.2 6 9.2 6-3.4 6-9.2 6-9.2-6-9.2-6Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 15.2a3.2 3.2 0 1 0 0-6.4 3.2 3.2 0 0 0 0 6.4Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {% when 'pencil' %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none"><path d="m4 16.8-.9 4.1 4.1-.9L19.1 8.1a2.1 2.1 0 0 0 0-3l-.2-.2a2.1 2.1 0 0 0-3 0L4 16.8Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/><path d="m14.7 6.1 3.2 3.2M4.7 16.3l3 3" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {% when 'shield' %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none"><path d="M12 3.2 20 6v5.9c0 5-3.3 7.8-8 9-4.7-1.2-8-4-8-9V6l8-2.8Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/><path d="m8.8 12 2.2 2.2 4.5-4.8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {% when 'washer' %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none"><path d="M6.2 3.5h11.6c.9 0 1.7.8 1.7 1.7v13.6c0 .9-.8 1.7-1.7 1.7H6.2c-.9 0-1.7-.8-1.7-1.7V5.2c0-.9.8-1.7 1.7-1.7Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/><path d="M4.8 8h14.4M8 5.7h.1M10.7 5.7h.1" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><path d="M12 17.7a3.9 3.9 0 1 0 0-7.8 3.9 3.9 0 0 0 0 7.8Z" stroke="currentColor" stroke-width="1.7"/><path d="M8.7 15c1.2-.9 2.2-.9 3.5 0 1.2.8 2.2.8 3.1 0" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
  {% when 'gift' %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none"><path d="M4 10h16v10H4V10ZM3 7h18v3H3V7ZM12 7v13" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 7H8.4a2 2 0 1 1 2-2c0 1.3 1.6 2 1.6 2Zm0 0h3.6a2 2 0 1 0-2-2c0 1.3-1.6 2-1.6 2Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {% when 'truck' %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none"><path d="M3.5 6.2h11v10.2h-11V6.2Zm11 3.5h3.2l2.8 3.2v3.5h-6V9.7Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/><path d="M7.4 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm10 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" stroke="currentColor" stroke-width="1.7"/></svg>
  {% when 'leaf' %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none"><path d="M12 21s-1.2-5.4 1.8-9.7C16.6 7.4 21 6 21 6s.1 5.2-3.2 8.3C15.1 16.8 12 21 12 21Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 21S8.3 17.8 6 15.1C3.6 12.4 3 8 3 8s4.6.4 7.2 3.8C12.4 14.7 12 21 12 21Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 21c.1-4.1 1.8-7.3 5.1-10.1M12 21c-.3-3.5-1.9-6.2-5.2-8.7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
  {% else %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none"><path d="M12 3.5 13.7 9l5.5 1.7-5.5 1.7L12 18l-1.7-5.6-5.5-1.7L10.3 9 12 3.5Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
{% endcase %}
