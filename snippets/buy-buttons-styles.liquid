{%- doc -%}
  Buy-buttons styles consolidated into a single snippet.

  @example
  {% render 'buy-buttons-styles' %}
{%- enddoc -%}

{% stylesheet %}
  .buy-buttons-block {
    --buy-button-preferred-width: 185px;
    --buy-box-background: rgb(var(--color-background-rgb) / 0.82);
    --buy-box-border: rgb(var(--color-foreground-rgb) / 0.1);
    --buy-box-shadow: 0 18px 40px rgb(62 51 45 / 0.08);

    width: 100%;
  }

  .product-information--main-product .buy-buttons-block {
    --buy-box-background: rgba(255, 250, 244, 0.8);
    --buy-box-border: rgba(92, 61, 42, 0.1);
    --buy-box-shadow: none;
    --buy-accent: #b87345;
    --buy-accent-hover: #7a4a2d;
  }

  .product-form-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap-sm);
    padding: clamp(1rem, 2vw, 1.5rem);
    border: 1px solid var(--buy-box-border);
    border-radius: calc(var(--style-border-radius-inputs) + 10px);
    background: var(--buy-box-background);
    box-shadow: var(--buy-box-shadow);
    backdrop-filter: blur(12px);
  }

  .product-form-buttons:not(:has(.quantity-rules)) {
    gap: var(--gap-sm);

    @media screen and (min-width: 750px) {
      gap: var(--gap-sm);
    }
  }

  .product-form-buttons
    > *:not(.quantity-selector-wrapper, .quantity-rules, .quantity-label, .volume-pricing, .product-form-text__error, .product-form-trust-badges) {
    flex: 1 1 var(--buy-button-preferred-width, 0);
    min-width: 0;
  }

  .product-form-buttons--stacked
    > *:not(.quantity-selector-wrapper, .quantity-rules, .quantity-label, .volume-pricing, .product-form-text__error, .product-form-trust-badges) {
    flex-basis: 51%;
  }

  .product-form-buttons button {
    width: 100%;
    padding-block: var(--padding-lg);
  }

  .product-form-buttons .quantity-selector {
    flex-grow: 0;
    flex-shrink: 0;
    height: var(--height-buy-buttons);
    border-radius: var(--style-border-radius-inputs);
  }

  .product-information--main-product .product-form-buttons {
    display: grid;
    grid-template-columns: minmax(124px, 156px) minmax(0, 1fr);
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
    backdrop-filter: none;
    gap: 12px;
    align-items: end;
  }

  .product-information--main-product .product-form-buttons .quantity-selector-wrapper {
    grid-column: 1;
    align-self: end;
    width: 100%;
    min-width: 124px;
    max-width: 156px;
  }

  .product-information--main-product .product-form-buttons .quantity-selector {
    height: clamp(50px, 5vw, 54px);
    border-radius: 14px;
    border: 1px solid rgba(92, 61, 42, 0.14);
    background: #fff;
    overflow: hidden;
  }

  .product-information--main-product .product-form-buttons .quantity-selector-wrapper {
    position: relative;
  }

  .product-information--main-product .product-form-buttons .quantity-selector-wrapper::before {
    content: 'Quantity';
    display: block;
    margin-bottom: 0.45rem;
    color: #43342b;
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .product-information--main-product .product-form-buttons:has(.quantity-label) .quantity-selector-wrapper::before {
    display: none;
  }

  .product-information--main-product .product-form-buttons .quantity-selector input {
    font-size: 0.95rem;
    font-weight: 600;
  }

  .product-information--main-product .product-form-buttons .quantity-selector button {
    color: #5c3d2a;
  }

  .quantity-label {
    flex: 1 0 100%;
    width: 100%;
    font-size: var(--font-size--sm);
    margin-block-end: var(--gap-xs);
    color: var(--color-foreground);
    letter-spacing: 0.01em;
  }

  .quantity-label__cart-count {
    color: var(--color-foreground-secondary);
  }

  .quantity-rules {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    row-gap: calc(var(--gap-xs) / 2);
    flex: 1 0 100%;
    width: 100%;
    font-size: var(--font-size--xs);
    color: var(--color-foreground-secondary);
    margin-block-start: var(--gap-xs);
    margin-block-end: var(--gap);
  }

  .product-form-buttons:has(~ .volume-pricing .volume-pricing__title) .quantity-rules {
    margin-block-end: var(--gap-md);
  }

  .quantity-rules__item {
    position: relative;
    display: inline-block;
    color: rgb(var(--color-rgb, var(--color-foreground-rgb)) / var(--opacity-subdued-text));
  }

  .quantity-rules__item:not(:last-child) {
    padding-right: var(--padding-xl);
    margin-right: var(--margin-2xs);
  }

  .quantity-rules__item:not(:last-child)::after {
    content: '•';
    position: absolute;
    inset-inline-end: 0.5rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.5em;
    line-height: 0;
  }

  .add-to-cart-button {
    height: var(--height-buy-buttons);
    text-transform: var(--button-text-case-primary);
  }

  .add-to-cart-button.button-secondary {
    text-transform: var(--button-text-case-secondary);
  }

  .product-form-text__error {
    display: flex;
    flex: 1 0 100%;
    align-items: flex-start;
    gap: var(--gap-xs);
    margin-block-end: var(--gap-xs);
  }

  .product__pickup-availabilities {
    width: 100%;
    color: var(--color, var(--color-foreground));
    padding: clamp(0.9rem, 1.5vw, 1.1rem);
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    border-radius: calc(var(--style-border-radius-inputs) + 8px);
    background: rgb(var(--color-background-rgb) / 0.72);
  }

  .pickup-availability__column {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .pickup-availability__row {
    display: flex;
    gap: var(--padding-xs);
  }

  .pickup-availability__dialog-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .pickup-availability__header-container {
    padding-block-end: var(--padding-2xl);
  }

  .pickup-location__wrapper {
    display: flex;
    flex-direction: column;
    padding-block: var(--padding-2xl);
    padding-inline: var(--theme-drawer-padding);
    border-top: 1px solid var(--color-border);
    gap: var(--padding-xs);
  }

  .pickup-location__address-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--padding-md);
  }

  .pickup-location__text-sm {
    font-size: var(--font-size--sm);
    margin: 0;
  }

  .pickup-location__text-xs {
    font-size: var(--font-size--xs);
    margin: 0;
  }

  .pickup-location__button {
    width: fit-content;
    color: var(--color, var(--color-foreground));
    font-size: var(--font-size--xs);
    font-family: var(--font-body--family);
    padding: 0;
    cursor: pointer;
    margin-block: var(--margin-xs);
  }

  .pickup-location__button:hover {
    color: rgb(var(--color-rgb, var(--color-foreground-rgb)) / var(--opacity-subdued-text));
  }

  .pickup-location__h4 {
    margin: 0;
  }

  .pickup-location__text-bold {
    font-size: var(--font-size--md);
    font-weight: 600;
    margin: 0;
  }

  .pickup-location__availability-wrapper {
    display: flex;
    align-items: center;
    gap: var(--gap-xs);
    font-family: var(--font-paragraph--family);
  }

  .pickup-location__address {
    font-style: normal;
  }

  .volume-pricing {
    display: block;
    width: 100%;
    margin-bottom: var(--gap);
  }

  .volume-pricing:not(:has(.volume-pricing__title)) {
    margin-top: 0;
    margin-bottom: 0;
  }

  .volume-pricing__title {
    display: block;
    margin-block-end: var(--gap-sm);
    font-size: var(--font-size--sm);
    font-weight: var(--font-body--weight);
    color: var(--color-foreground);
  }

  .volume-pricing__table {
    width: 100%;
    overflow: hidden;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    border-radius: calc(var(--style-border-radius-inputs) + 6px);
  }

  .volume-pricing__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--padding-sm);
    padding-inline: var(--padding-md);
    font-size: var(--font-size--sm);
  }

  .volume-pricing__row--even {
    background: rgb(var(--color-foreground-rgb) / 0.035);
  }

  .volume-pricing__row--odd {
    background: rgb(var(--color-background-rgb) / 0.9);
  }

  .volume-pricing__collapsible-wrapper {
    block-size: 0;
    overflow-y: clip;
    opacity: 0;
    interpolate-size: allow-keywords;
    transition: opacity var(--animation-speed-slow) var(--animation-easing),
      block-size var(--animation-speed-slow) var(--animation-easing);
  }

  .volume-pricing__toggle {
    width: 100%;
    padding-bottom: 0;
    padding-inline: 0;
    text-align: left;
    color: var(--color-foreground-secondary);
    font-size: var(--font-size--xs);
    cursor: default;
    margin-block-start: 0;
    pointer-events: none;
  }

  button.volume-pricing__toggle {
    /* Need the extra specificity to override .product-form-buttons button */
    padding-block: var(--padding-sm);
  }

  .volume-pricing__toggle-text {
    cursor: pointer;
    display: inline-block;
    pointer-events: auto;
  }

  .volume-pricing__show-less {
    display: none;
  }

  .volume-pricing--expanded .volume-pricing__collapsible-wrapper {
    opacity: 1;
    block-size: auto;

    @starting-style {
      block-size: 0;
      opacity: 0;
      overflow-y: clip;
    }
  }

  .volume-pricing--expanded .volume-pricing__show-more {
    display: none;
  }

  .volume-pricing--expanded .volume-pricing__show-less {
    display: inline;
  }

  /* Accelerated checkout styles — co-located here so they compile on pages
       where the quick-add modal can display buy buttons (e.g. collection pages). */
  .accelerated-checkout-block[data-shopify-visual-preview] {
    width: 300px;
  }

  more-payment-options-link {
    font-size: smaller;
  }

  more-payment-options-link a:hover {
    color: rgb(var(--color-rgb, var(--color-foreground-rgb)) / var(--opacity-subdued-text));
  }

  .shopify-payment-button__more-options[aria-hidden='true'] {
    display: none;
  }

  .product-information--main-product .product-form-buttons > .add-to-cart-button {
    grid-column: 2;
    align-self: end;
    width: 100%;
    min-width: 0;
  }

  .product-information--main-product .product-form-buttons > .accelerated-checkout-block,
  .product-information--main-product .product-form-buttons > .shopify-payment-button {
    grid-column: 1 / -1;
    width: 100%;
    min-width: 0;
  }

  .product-information--main-product .product-form-buttons button,
  .product-information--main-product .product-form-buttons .shopify-payment-button__button,
  .product-information--main-product .product-form-buttons .shopify-payment-button__more-options {
    min-height: clamp(50px, 5vw, 54px);
    border-radius: 13px;
    font-size: 1rem;
  }

  .product-information--main-product .product-form-buttons .add-to-cart-button {
    background: linear-gradient(180deg, #ffffff 0%, #fff9f2 100%);
    border: 1.5px solid rgba(184, 115, 69, 0.7);
    color: #9a6038;
    box-shadow: none;
  }

  .product-information--main-product .product-form-buttons .add-to-cart-button .add-to-cart-icon {
    color: currentColor;
  }

  .product-information--main-product .product-form-buttons .shopify-payment-button__button--unbranded {
    background: #b87345;
    border-color: #b87345;
    color: #fffaf4;
    box-shadow: none;
  }

  .product-information--main-product .product-form-buttons .add-to-cart-button:hover:not([disabled]) {
    background: #fff6ed;
    border-color: #9a6038;
    color: #7a4a2d;
  }

  .product-information--main-product .product-form-buttons .shopify-payment-button__button--unbranded:hover:not([disabled]) {
    background: #7a4a2d;
    border-color: #7a4a2d;
  }

  .product-information--main-product .product-form-trust-badges {
    grid-column: 1 / -1;
    display: grid;
    gap: 14px;
    width: 100%;
    margin-top: 4px;
    padding-top: 14px;
    border-top: 1px solid rgba(184, 115, 69, 0.16);
  }

  .product-information--main-product .product-form-trust-badges__items {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }

  .product-information--main-product .product-form-trust-badge {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: start;
    gap: 0.75rem;
    min-width: 0;
    color: #7b6657;
    position: relative;
  }

  .product-information--main-product .product-form-trust-badge:not(:last-child)::after {
    content: '';
    position: absolute;
    top: 0.1rem;
    right: -7px;
    width: 1px;
    height: calc(100% - 0.2rem);
    background: linear-gradient(180deg, rgba(184, 115, 69, 0) 0%, rgba(184, 115, 69, 0.18) 16%, rgba(184, 115, 69, 0.18) 84%, rgba(184, 115, 69, 0) 100%);
  }

  .product-information--main-product .product-form-trust-badge__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.65rem;
    height: 1.65rem;
    color: #8f603e;
  }

  .product-information--main-product .product-form-trust-badge__icon :is(svg, img) {
    width: 100%;
    height: 100%;
  }

  .product-information--main-product .product-form-trust-badge__content {
    display: grid;
    gap: 0.18rem;
    min-width: 0;
  }

  .product-information--main-product .product-form-trust-badge__title {
    color: #4a382c;
    font-size: 0.96rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .product-information--main-product .product-form-trust-badge__meta {
    color: #8a7364;
    font-size: 0.82rem;
    line-height: 1.35;
  }

  .product-information--main-product .product-form-trust-badges__note {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    width: 100%;
    min-height: 2.95rem;
    padding: 0.85rem 1rem;
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.9) 0%, rgba(255, 246, 237, 0.92) 100%);
    border: 1px solid rgba(184, 115, 69, 0.12);
    color: #725648;
    font-size: 0.98rem;
    line-height: 1.4;
    letter-spacing: -0.01em;
    text-align: center;
  }

  .product-information--main-product .product-form-trust-badges__note-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    color: #b87345;
  }

  .product-information--main-product .product-form-trust-badges__note-icon :is(svg, img) {
    width: 100%;
    height: 100%;
  }

  @media screen and (max-width: 749px) {
    .product-form-buttons {
      padding: var(--padding-md);
      gap: calc(var(--gap-sm) * 0.85);
    }

    .product-form-buttons
      > *:not(.quantity-selector-wrapper, .quantity-rules, .quantity-label, .volume-pricing, .product-form-text__error, .product-form-trust-badges) {
      flex-basis: 100%;
    }

    .product-form-buttons .quantity-selector-wrapper {
      width: 100%;
    }

    .product-form-buttons .quantity-selector {
      width: 100%;
      max-width: 100%;
    }

    .product-information--main-product .product-form-buttons {
      grid-template-columns: 1fr;
      padding: 0;
      gap: 12px;
    }

    .product-information--main-product .product-form-buttons .quantity-selector-wrapper::before {
      margin-bottom: 0.45rem;
      font-size: 0.92rem;
    }

    .product-information--main-product .product-form-buttons .quantity-selector-wrapper,
    .product-information--main-product .product-form-buttons > .add-to-cart-button,
    .product-information--main-product .product-form-buttons > .accelerated-checkout-block,
    .product-information--main-product .product-form-buttons > .shopify-payment-button {
      grid-column: 1 / -1;
      width: 100%;
      min-width: 0;
      max-width: 100%;
    }

    .product-information--main-product .product-form-trust-badges {
      gap: 12px;
      padding-bottom: max(6px, env(safe-area-inset-bottom));
    }

    .product-information--main-product .product-form-trust-badges__items {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px 14px;
    }

    .product-information--main-product .product-form-trust-badge:not(:last-child)::after {
      display: none;
    }

    .product-information--main-product .product-form-trust-badges__note {
      font-size: 0.9rem;
      padding-inline: 0.9rem;
    }
  }
{% endstylesheet %}
