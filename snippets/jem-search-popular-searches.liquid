<aside class="jem-search-sidebar" aria-label="Popular collections">
  <div class="jem-search-sidebar__panel">
    <p class="jem-search-sidebar__eyebrow">Discover faster</p>
    <a class="jem-search-sidebar__button" href="/collections">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
      View all collections
    </a>
    <div class="jem-search-sidebar__list">
      {% liquid
        assign min_collection_count = 6
        assign max_collection_count = 10
        assign collection_count = 0
        assign priority_handles = 'best-selling,memorial-blankets,memorial,christmas-blankets,sports-blankets,sports,sport-blankets,book-lover-blankets,book-lover,book-lover-blanket,christian-baptism-blankets,christian-baptism,baptism-blankets,couple-family-blankets,couple-family,family-couple-blankets,fantasy-blankets,blankets,quilts,comforters' | split: ','
        assign rendered_handles = '|'
      %}
      
      {% for handle in priority_handles %}
        {% assign collection = collections[handle] %}
        {% if collection != blank %}
          {% assign handle_key = '|' | append: collection.handle | append: '|' %}
          {% if rendered_handles contains handle_key %}
            {% continue %}
          {% endif %}
          
          {% if collection.products_count > 0 or collection_count < min_collection_count %}
            {% if collection_count < max_collection_count %}
              {% assign collection_count = collection_count | plus: 1 %}
              {% assign rendered_handles = rendered_handles | append: collection.handle | append: '|' %}
              <a class="jem-search-category" href="{{ collection.url }}" aria-label="Shop {{ collection.title }} collection">
                <span class="jem-search-category__icon">
                  {% if collection.image %}
                    {{ collection.image | image_url: width: 40, height: 40, crop: 'center' | image_tag: loading: 'lazy', class: 'jem-search-category__img', style: 'border-radius: 8px; object-fit: cover; width: 100%; height: 100%;' }}
                  {% elsif collection.products.first.featured_image %}
                    {{ collection.products.first.featured_image | image_url: width: 40, height: 40, crop: 'center' | image_tag: loading: 'lazy', class: 'jem-search-category__img', style: 'border-radius: 8px; object-fit: cover; width: 100%; height: 100%;' }}
                  {% else %}
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><path d="M3 9h18M3 15h18M9 3v18M15 3v18"/></svg>
                  {% endif %}
                </span>
                <span class="jem-search-category__copy">
                  <span class="jem-search-category__title">{{ collection.title }}</span>
                  <span class="jem-search-category__meta">
                    {% if collection.metafields.custom.search_subtitle %}
                      {{ collection.metafields.custom.search_subtitle }}
                    {% elsif collection.products_count and collection.products_count > 0 %}
                      {{ collection.products_count }} products
                    {% else %}
                      Explore collection
                    {% endif %}
                  </span>
                </span>
                <span class="jem-search-category__arrow" aria-hidden="true">→</span>
              </a>
            {% endif %}
          {% endif %}
        {% endif %}
      {% endfor %}
      
      {% if collection_count < max_collection_count %}
        {% for collection in collections %}
          {% if collection.handle == 'all' or collection.handle == 'frontpage' or collection.handle == 'automated-frontpage' %}
            {% continue %}
          {% endif %}
          
          {% assign handle_key = '|' | append: collection.handle | append: '|' %}
          {% if rendered_handles contains handle_key %}
            {% continue %}
          {% endif %}
          
          {% if collection.products_count > 0 or collection_count < min_collection_count %}
            {% if collection_count < max_collection_count %}
              {% assign collection_count = collection_count | plus: 1 %}
              {% assign rendered_handles = rendered_handles | append: collection.handle | append: '|' %}
              <a class="jem-search-category" href="{{ collection.url }}" aria-label="Shop {{ collection.title }} collection">
                <span class="jem-search-category__icon">
                  {% if collection.image %}
                    {{ collection.image | image_url: width: 40, height: 40, crop: 'center' | image_tag: loading: 'lazy', class: 'jem-search-category__img', style: 'border-radius: 8px; object-fit: cover; width: 100%; height: 100%;' }}
                  {% elsif collection.products.first.featured_image %}
                    {{ collection.products.first.featured_image | image_url: width: 40, height: 40, crop: 'center' | image_tag: loading: 'lazy', class: 'jem-search-category__img', style: 'border-radius: 8px; object-fit: cover; width: 100%; height: 100%;' }}
                  {% else %}
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><path d="M3 9h18M3 15h18M9 3v18M15 3v18"/></svg>
                  {% endif %}
                </span>
                <span class="jem-search-category__copy">
                  <span class="jem-search-category__title">{{ collection.title }}</span>
                  <span class="jem-search-category__meta">
                    {% if collection.metafields.custom.search_subtitle %}
                      {{ collection.metafields.custom.search_subtitle }}
                    {% elsif collection.products_count and collection.products_count > 0 %}
                      {{ collection.products_count }} products
                    {% else %}
                      Explore collection
                    {% endif %}
                  </span>
                </span>
                <span class="jem-search-category__arrow" aria-hidden="true">→</span>
              </a>
            {% endif %}
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</aside>
