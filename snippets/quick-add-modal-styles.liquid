  .quick-add-modal .product-details--main-product .add-to-cart-button,
  .quick-add-modal .product-details--main-product .shopify-payment-button__button,
  .quick-add-modal .product-details--main-product .shopify-payment-button__button--unbranded,
  .quick-add-modal .product-details--main-product .shopify-payment-button__more-options {
    position: static !important;
