{%- doc -%}
  Quick-add modal styles consolidated into a single snippet.

  @example
  {% render 'quick-add-modal-styles' %}
{%- enddoc -%}

{% stylesheet %}
  #quick-add-dialog {
    display: contents;
  }

  .quick-add-modal {
    width: min(860px, 96vw);
    max-width: none;
    max-height: 86dvh;
    padding: 0;
    border: 1px solid rgba(92, 61, 42, 0.12);
    border-radius: 24px;
    background:
      radial-gradient(circle at top left, rgba(255, 243, 229, 0.96), transparent 34%),
      linear-gradient(180deg, #fffdf9 0%, #fffaf4 100%);
    box-shadow:
      0 24px 60px rgba(47, 36, 29, 0.14),
      0 10px 24px rgba(184, 115, 69, 0.08);
    overflow: hidden;
  }

  .quick-add-modal::backdrop {
    background: rgba(38, 27, 20, 0.48);
    backdrop-filter: blur(8px);
  }

  .quick-add-modal[open] {
    animation: modalSlideInTop var(--animation-speed) var(--animation-easing) forwards;
  }

  .quick-add-modal.dialog-closing {
    animation: modalSlideOutTop var(--animation-speed) var(--animation-easing) forwards;
  }

  .quick-add-modal__close {
    position: absolute;
    top: 16px;
    right: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 999px;
    color: #5c3d2a;
    background: rgba(255, 250, 244, 0.92);
    border: 1px solid rgba(92, 61, 42, 0.12);
    box-shadow: 0 8px 22px rgba(47, 36, 29, 0.12);
    z-index: 3;
    transition:
      transform 0.18s ease,
      background-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .quick-add-modal__close:hover {
    transform: translateY(-1px);
    background: #fff;
    box-shadow: 0 12px 24px rgba(47, 36, 29, 0.16);
  }

  .quick-add-modal__close svg {
    width: 16px;
    height: 16px;
  }

  .quick-add-modal__content {
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    gap: 18px;
    min-height: 0;
    height: min(86dvh, 100%);
    max-height: 86dvh;
    padding: 24px;
    overflow: hidden;
    position: relative;
  }

  .quick-add-modal__content > * {
    min-width: 0;
    min-height: 0;
  }

  .quick-add-modal__main {
    display: grid;
    grid-template-columns: minmax(0, 0.86fr) minmax(0, 1fr);
    gap: 30px;
    align-items: start;
    width: 100%;
    min-width: 0;
    min-height: 0;
    overflow: hidden;
  }

  @keyframes quickAddSkeletonShimmer {
    0% {
      background-position: 100% 0;
    }

    100% {
      background-position: -100% 0;
    }
  }

  .quick-add-modal[data-quick-add-state='loading'] .quick-add-modal__content {
    display: grid;
    grid-template-columns: minmax(0, 0.86fr) minmax(0, 1fr);
    gap: 30px;
    height: min(560px, 82dvh);
    min-height: 420px;
    align-items: stretch;
  }

  .quick-add-modal__skeleton-media,
  .quick-add-modal__skeleton-info {
    display: grid;
    gap: 12px;
  }

  .quick-add-modal__skeleton-main,
  .quick-add-modal__skeleton-thumbs span,
  .quick-add-modal__skeleton-title,
  .quick-add-modal__skeleton-price,
  .quick-add-modal__skeleton-options span,
  .quick-add-modal__skeleton-button {
    background:
      linear-gradient(90deg, rgba(255, 248, 241, 0.95) 0%, rgba(244, 232, 221, 0.95) 45%, rgba(255, 248, 241, 0.95) 100%);
    background-size: 200% 100%;
    animation: quickAddSkeletonShimmer 1.4s ease-in-out infinite;
    border: 1px solid rgba(92, 61, 42, 0.06);
  }

  .quick-add-modal__skeleton-main {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 20px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.84),
      0 12px 26px rgba(47, 36, 29, 0.05);
  }

  .quick-add-modal__skeleton-thumbs {
    display: flex;
    gap: 10px;
    overflow: hidden;
  }

  .quick-add-modal__skeleton-thumbs span {
    width: 60px;
    height: 60px;
    min-width: 60px;
    border-radius: 14px;
  }

  .quick-add-modal__skeleton-info {
    align-content: start;
    padding-top: 8px;
  }

  .quick-add-modal__skeleton-title {
    width: 90%;
    height: 22px;
    border-radius: 999px;
  }

  .quick-add-modal__skeleton-title--short {
    width: 56%;
  }

  .quick-add-modal__skeleton-price {
    width: 36%;
    height: 28px;
    margin-top: 6px;
    border-radius: 999px;
  }

  .quick-add-modal__skeleton-options {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding-top: 12px;
  }

  .quick-add-modal__skeleton-options span {
    width: 92px;
    height: 42px;
    border-radius: 15px;
  }

  .quick-add-modal__skeleton-button {
    width: 100%;
    height: 50px;
    margin-top: 8px;
    border-radius: 16px;
  }

  .quick-add-modal__skeleton-button--secondary {
    margin-top: 0;
    opacity: 0.88;
  }

  .quick-add-modal[data-quick-add-state='error'] .quick-add-modal__content {
    grid-template-columns: minmax(0, 1fr);
    height: auto;
    min-height: 260px;
    align-items: center;
  }

  .quick-add-modal__error {
    display: grid;
    justify-items: start;
    gap: 10px;
    max-width: 360px;
    padding: 28px;
    border-radius: 22px;
    background: rgba(255, 252, 248, 0.96);
    border: 1px solid rgba(92, 61, 42, 0.1);
    box-shadow: 0 18px 40px rgba(47, 36, 29, 0.08);
  }

  .quick-add-modal__error strong {
    color: #3c2b21;
    font-size: 1.05rem;
    line-height: 1.35;
  }

  .quick-add-modal__error span {
    color: #7b6657;
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .quick-add-modal__error-close {
    min-height: 44px;
    padding: 0.8rem 1rem;
    border: 1px solid rgba(92, 61, 42, 0.14);
    border-radius: 14px;
    background: #fff;
    color: #4b382c;
    font-weight: 600;
  }

  .quick-add-modal .quantity-selector-wrapper {
    --color-input-background: rgba(255, 255, 255, 0.92);
    --color-input-text: #2f241d;
    --color-input-text-rgb: 47, 36, 29;
    --color-input-border: rgba(92, 61, 42, 0.16);
    --style-border-width-inputs: 1px;
    --style-border-radius-inputs: 16px;
    --style-border-radius-buttons-primary: 16px;
    --style-border-radius-buttons-secondary: 16px;
  }

  .quick-add-modal__content .product-information__media {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-self: start;
    width: 100%;
    min-width: 0;
    overflow: hidden;
  }

  .quick-add-modal__main > .product-information__media {
    grid-column: 1;
    align-self: start;
    width: 100%;
    min-width: 0;
  }

  .quick-add-modal__content .product-information__media media-gallery {
    display: block;
    position: static;
    top: auto;
    width: 100%;
    max-height: none;
    overflow: visible;
    padding: 0;
    pointer-events: auto;
  }

  .quick-add-modal__content .product-information__media slideshow-component,
  .quick-add-modal media-gallery.media-gallery--grid slideshow-component,
  .quick-add-modal media-gallery.media-gallery--carousel slideshow-component {
    display: grid !important;
    grid-template:
      'media' minmax(0, 1fr)
      'controls' auto
      / minmax(0, 1fr) !important;
    gap: 12px;
    position: static;
    width: 100%;
    min-width: 0;
    max-height: none;
    overflow: visible;
  }

  .quick-add-modal media-gallery[data-quick-add-slideshow-ready='true'] .media-gallery__grid {
    display: none !important;
  }

  .quick-add-modal media-gallery:not([data-quick-add-slideshow-ready='true']) .media-gallery__grid {
    display: block !important;
  }

  .quick-add-modal__content .product-information__media slideshow-container,
  .quick-add-modal media-gallery.media-gallery--grid slideshow-container,
  .quick-add-modal media-gallery.media-gallery--carousel slideshow-container {
    display: block;
    grid-area: media !important;
    position: static;
    width: 100%;
    aspect-ratio: 4 / 3;
    max-height: 390px;
    min-height: 0;
    border-radius: 20px;
    overflow: hidden;
    background: #fffdf9;
    border: 1px solid rgba(92, 61, 42, 0.1);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      0 10px 24px rgba(47, 36, 29, 0.06);
  }

  .quick-add-modal__content .product-information__media slideshow-slides {
    position: relative;
    top: auto;
    max-height: none;
    width: 100%;
    height: 100%;
    min-height: 100%;
    display: flex;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: auto;
    scrollbar-width: none;
  }

  .quick-add-modal__content .product-information__media slideshow-slides::-webkit-scrollbar {
    display: none;
  }

  .quick-add-modal__content .product-information__media slideshow-slide {
    flex: 0 0 100%;
    min-width: 100%;
    width: 100%;
    height: 100%;
    scroll-snap-align: start;
  }

  .quick-add-modal__content .product-information__media .product-media,
  .quick-add-modal__content .product-information__media .product-media > *,
  .quick-add-modal__content .product-information__media .product-media-constraint-wrapper,
  .quick-add-modal__content .product-information__media .product-media img,
  .quick-add-modal__content .product-information__media .product-media video,
  .quick-add-modal__content .product-information__media .product-media iframe,
  .quick-add-modal__content .product-information__media .product-media model-viewer {
    width: 100%;
    height: 100%;
  }

  .quick-add-modal__content .product-information__media .product-media img,
  .quick-add-modal__content .product-information__media .product-media video,
  .quick-add-modal__content .product-information__media .product-media iframe,
  .quick-add-modal__content .product-information__media .product-media model-viewer {
    object-fit: contain;
    border-radius: 0;
  }

  .quick-add-modal__content .product-information__media .product-media-container__zoom-button,
  .quick-add-modal__content .product-information__media slideshow-arrows,
  .quick-add-modal__content .product-information__media .slideshow-controls__arrows {
    display: none;
  }

  .quick-add-modal__content .product-information__media slideshow-controls[thumbnails] {
    grid-area: controls !important;
    position: static !important;
    display: block !important;
    width: 100%;
    height: auto !important;
    min-height: 0 !important;
    margin: 0;
    overflow: visible;
  }

  .quick-add-modal__content .product-information__media slideshow-controls[thumbnails][pagination-position='left'],
  .quick-add-modal__content .product-information__media slideshow-controls[thumbnails][pagination-position='right'],
  .quick-add-modal__content .product-information__media slideshow-controls[thumbnails][pagination-position='center'] {
    display: block !important;
    height: auto;
    min-height: 0;
  }

  .quick-add-modal__content .product-information__media .slideshow-controls__thumbnails-container {
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    padding: 0;
  }

  .quick-add-modal__content .product-information__media .slideshow-controls__thumbnails-container::-webkit-scrollbar {
    display: none;
  }

  .quick-add-modal__content .product-information__media .slideshow-controls__thumbnails {
    display: flex !important;
    flex-direction: row !important;
    gap: 10px;
    width: max-content;
    margin: 0;
    padding: 2px 2px 6px;
  }

  .quick-add-modal__content .product-information__media .slideshow-controls__thumbnail {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 58px;
    height: 58px;
    min-width: 58px;
    padding: 0;
    overflow: hidden;
    border-radius: 14px;
    border: 1px solid rgba(92, 61, 42, 0.14);
    background: rgba(255, 255, 255, 0.84);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      0 1px 2px rgba(47, 36, 29, 0.05);
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .quick-add-modal__content .product-information__media .slideshow-controls__thumbnail:hover {
    transform: translateY(-1px);
    border-color: rgba(184, 115, 69, 0.34);
  }

  .quick-add-modal__content .product-information__media .slideshow-controls__thumbnail[aria-selected='true'] {
    border-color: #b87345;
    box-shadow:
      inset 0 0 0 1px rgba(184, 115, 69, 0.36),
      0 10px 20px rgba(184, 115, 69, 0.12);
  }

  .quick-add-modal__content .product-information__media .slideshow-controls__thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
  }

  .quick-add-modal__content .product-information__media .slideshow-controls__thumbnail-badge {
    top: 6px;
    right: 6px;
  }

  .quick-add-modal
    media-gallery:not([data-quick-add-slideshow-ready='true'])
    .media-gallery__grid
    .product-media-container:not(:first-child) {
    display: none !important;
  }

  .quick-add-modal
    media-gallery:not([data-quick-add-slideshow-ready='true'])
    .media-gallery__grid
    .product-media-container:first-child {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 20px;
    overflow: hidden;
    background: #fffdf9;
    border: 1px solid rgba(92, 61, 42, 0.1);
  }

  .quick-add-modal__content .product-details {
    display: block;
    align-self: start !important;
    justify-self: stretch;
    margin: 0 !important;
    padding: 0 !important;
    padding-top: 0 !important;
    height: auto !important;
    min-height: 0 !important;
    max-height: none !important;
    overflow: visible !important;
  }

  .quick-add-modal__main > .product-details {
    grid-column: 2;
    align-self: start !important;
    justify-self: stretch;
    margin: 0 !important;
    padding: 0 !important;
    padding-top: 0 !important;
    height: 100% !important;
    min-height: 0 !important;
    max-height: 100% !important;
    overflow-y: auto !important;
    overflow-x: hidden !important;
    display: block !important;
    padding-right: 6px !important;
    scrollbar-gutter: stable;
  }

  .quick-add-modal__content .product-details > .group-block {
    width: 100%;
    height: auto !important;
    min-height: 0 !important;
    max-height: none !important;
    flex-grow: 0;
    margin: 0 !important;
    padding: 0 !important;
    background: transparent !important;
    border: 0 !important;
    box-shadow: none !important;
    border-radius: 0 !important;
  }

  .quick-add-modal__content .product-details > .group-block > .group-block-content {
    display: flex !important;
    flex-direction: column !important;
    align-content: start !important;
    align-items: stretch !important;
    justify-content: flex-start !important;
    gap: 12px !important;
    width: 100% !important;
    height: auto !important;
    min-height: 0 !important;
    max-height: none !important;
    flex-grow: 0;
    margin: 0 !important;
    padding: 0 !important;
    padding-top: 0 !important;
  }

  /* Reset PDP card styling leaks inside quick add only. */
  .quick-add-modal__content .product-details--main-product > .group-block,
  .quick-add-modal__content .product-details--main-product > .group-block > .group-block-content,
  .quick-add-modal__content .product-details--main-product > .group-block > .group-block-content > product-price,
  .quick-add-modal__content .product-details--main-product > .group-block > .group-block-content > variant-picker,
  .quick-add-modal__content .product-details--main-product > .group-block > .group-block-content > .buy-buttons-block {
    background: transparent !important;
    border: 0 !important;
    box-shadow: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  .quick-add-modal__content .product-details--main-product > .group-block > .group-block-content {
    width: 100% !important;
    height: auto !important;
    min-height: 0 !important;
    max-height: none !important;
    flex-grow: 0;
  }

  .quick-add-modal .product-details--main-product > .group-block,
  .quick-add-modal .product-details--main-product > .group-block > .group-block-content {
    width: 100% !important;
    max-width: none !important;
    height: auto !important;
    min-height: 0 !important;
    max-height: none !important;
    margin: 0 !important;
    padding: 0 !important;
    padding-top: 0 !important;
    background: transparent !important;
    border: 0 !important;
