{%- doc -%}
  Renders the predictive search products list for empty state and recently viewed products

  @param {string} title - title of the result list
  @param {object[]} products - array of products
  @param {string[]} [order_ids] - array of product ids
  @param {number} [limit] - limit of products to display
  @param {string} [products_test_id] - a playwright test id, used to differentiate empty state from 'real' search results
{%- enddoc -%}
{%- liquid
  assign recently_viewed_title_text = 'content.recently_viewed_products' | t
  assign title = title | default: 'Top Results'
-%}
<div
  id="predictive-search-products"
  class="predictive-search-results__products"
  {% if products_test_id %}
    data-testid="{{ products_test_id }}"
  {% endif %}
>
  {% if title == recently_viewed_title_text %}
    <div
      class="recently-viewed-wrapper"
      ref="recentlyViewedWrapper"
    >
      <div class="jem-search-results-header">
        <h4
          class="predictive-search-results__title"
          ref="recentlyViewedTitle[]"
        >
          {{ title }}
        </h4>
        <button
          class="predictive-search-results__clear button button-unstyled"
          type="button"
          on:click="/clearRecentlyViewedProducts"
        >
          {{ 'actions.clear' | t }}
        </button>
      </div>
      <ul
        class="predictive-search-results__list predictive-search-results__wrapper-products jem-search-products-grid list-unstyled"
      >
        {% liquid
          assign limit = limit | default: 8
        %}
        {% comment %}
          If we're searching for recently viewed products by id, we need to reorder the products.
          The order here comes from the search terms, and we display the products in the order of the ids.
        {% endcomment %}
        {% if order_ids != blank %}
          {% for _id in order_ids %}
            {% assign int_id = _id | times: 1 %}
            {% assign product = products | find: 'id', int_id %}
            {% liquid
              assign selected_variant = product.selected_or_first_available_variant
              assign current_price = selected_variant.price
              assign compare_price = selected_variant.compare_at_price
              assign max_safe_compare_price = current_price | times: 5
              assign show_compare_price = false
              if compare_price > current_price and compare_price <= max_safe_compare_price
                assign show_compare_price = true
              endif
            %}
            <li
              class="predictive-search-results__card predictive-search-results__card--product"
              ref="recentlyViewedItems[]"
            >
              <a class="jem-search-product-card" href="{{ product.url }}">
                <div class="jem-search-product-card__media">
                  {% if product.featured_media.preview_image %}
                    {{
                      product.featured_media.preview_image
                      | image_url: width: 520
                      | image_tag:
                        loading: 'lazy',
                        class: 'jem-search-product-card__image',
                        widths: '240, 360, 520',
                        sizes: '(min-width: 990px) 18vw, (min-width: 750px) 26vw, 44vw'
                    }}
                  {% endif %}
                  {% if show_compare_price %}
                    <span class="jem-search-product-card__badge">Sale</span>
                  {% endif %}
                </div>
                <div class="jem-search-product-card__content">
                  <span class="jem-search-product-card__title">{{ product.title }}</span>
                  <div class="jem-search-product-card__price-row">
                    <span class="jem-search-product-card__price">{{ current_price | money }}</span>
                    {% if show_compare_price %}
                      <span class="jem-search-product-card__compare">{{ compare_price | money }}</span>
                    {% endif %}
                  </div>
                </div>
              </a>
            </li>
          {% endfor %}
        {% else %}
          {% for product in products limit: limit %}
            {% liquid
              assign selected_variant = product.selected_or_first_available_variant
              assign current_price = selected_variant.price
              assign compare_price = selected_variant.compare_at_price
              assign max_safe_compare_price = current_price | times: 5
              assign show_compare_price = false
              if compare_price > current_price and compare_price <= max_safe_compare_price
                assign show_compare_price = true
              endif
            %}
            <li
              class="predictive-search-results__card predictive-search-results__card--product"
              ref="recentlyViewedItems[]"
            >
              <a class="jem-search-product-card" href="{{ product.url }}">
                <div class="jem-search-product-card__media">
                  {% if product.featured_media.preview_image %}
                    {{
                      product.featured_media.preview_image
                      | image_url: width: 520
                      | image_tag:
                        loading: 'lazy',
                        class: 'jem-search-product-card__image',
                        widths: '240, 360, 520',
                        sizes: '(min-width: 990px) 18vw, (min-width: 750px) 26vw, 44vw'
                    }}
                  {% endif %}
                  {% if show_compare_price %}
                    <span class="jem-search-product-card__badge">Sale</span>
                  {% endif %}
                </div>
                <div class="jem-search-product-card__content">
                  <span class="jem-search-product-card__title">{{ product.title }}</span>
                  <div class="jem-search-product-card__price-row">
                    <span class="jem-search-product-card__price">{{ current_price | money }}</span>
                    {% if show_compare_price %}
                      <span class="jem-search-product-card__compare">{{ compare_price | money }}</span>
                    {% endif %}
                  </div>
                </div>
              </a>
            </li>
          {% endfor %}
        {% endif %}
      </ul>
    </div>
  {% else %}
    <div class="jem-search-results-header">
      <h4 class="predictive-search-results__title">
        {{ title }}
      </h4>
      {% if view_all_url %}
        <a class="jem-search-results-header__link" href="{{ view_all_url }}">View all results</a>
      {% endif %}
    </div>
    <ul
      class="predictive-search-results__list predictive-search-results__wrapper-products jem-search-products-grid list-unstyled"
    >
      {% liquid
        assign limit = limit | default: 8
      %}
      {% for product in products limit: limit %}
        {% liquid
          assign selected_variant = product.selected_or_first_available_variant
          assign current_price = selected_variant.price
          assign compare_price = selected_variant.compare_at_price
          assign max_safe_compare_price = current_price | times: 5
          assign show_compare_price = false
          if compare_price > current_price and compare_price <= max_safe_compare_price
            assign show_compare_price = true
          endif
        %}
        <li
          class="predictive-search-results__card predictive-search-results__card--product"
          ref="resultsItems[]"
        >
          <a class="jem-search-product-card" href="{{ product.url }}">
            <div class="jem-search-product-card__media">
              {% if product.featured_media.preview_image %}
                {{
                  product.featured_media.preview_image
                  | image_url: width: 520
                  | image_tag:
                    loading: 'lazy',
                    class: 'jem-search-product-card__image',
                    widths: '240, 360, 520',
                    sizes: '(min-width: 990px) 18vw, (min-width: 750px) 26vw, 44vw'
                }}
              {% endif %}
              {% if show_compare_price %}
                <span class="jem-search-product-card__badge">Sale</span>
              {% endif %}
            </div>
            <div class="jem-search-product-card__content">
              <span class="jem-search-product-card__title">{{ product.title }}</span>
              <div class="jem-search-product-card__price-row">
                <span class="jem-search-product-card__price">{{ current_price | money }}</span>
                {% if show_compare_price %}
                  <span class="jem-search-product-card__compare">{{ compare_price | money }}</span>
                {% endif %}
              </div>
            </div>
          </a>
        </li>
      {% endfor %}
    </ul>
  {% endif %}

</div>
