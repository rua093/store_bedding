{% doc %}
  Product Information Content

  Renders the product information layout with media gallery and product details.
  Used by both product-information and featured-product-information sections.

  @param {product} product - Product object
  @param {string} section_id - Unique section ID
  @param {object} settings - Section settings object
  @param {string} media_gallery - Captured HTML for the product media gallery block
  @param {string} product_details - Captured HTML for the product details block
  @param {string} additional_blocks - Captured HTML for additional section blocks

  @example
  {% capture media_gallery %}
    {% content_for 'block', type: '_product-media-gallery', id: 'media-gallery', closest.product: product %}
  {% endcapture %}

  {% capture product_details %}
    {% content_for 'block', type: '_product-details', id: 'product-details', closest.product: product %}
  {% endcapture %}

  {% capture additional_blocks %}
    {% content_for 'blocks' %}
  {% endcapture %}

  {% render 'product-information-content',
    product: product,
    section_id: section.id,
    settings: section.settings,
    media_gallery: media_gallery,
    product_details: product_details,
    additional_blocks: additional_blocks
  %}
{% enddoc %}

{% liquid
  assign is_main_product_page = false
  if request.page_type == 'product'
    assign is_main_product_page = true
  endif

  # Determine render order based on media position
  if settings.desktop_media_position == 'left'
    assign render_order = 'media,product-details'
  else
    assign render_order = 'product-details,media'
  endif

  # Check if product has media
  assign product_has_media = true
  if product.media.size == 0
    assign product_has_media = false
  endif

  # Build product grid class
  assign product_grid_class = 'product-information__grid'

  if product_has_media == false
    assign product_grid_class = product_grid_class | append: ' product-information--media-none'
  elsif settings.desktop_media_position == 'right'
    assign product_grid_class = product_grid_class | append: ' product-information--media-right'
  else
    assign product_grid_class = product_grid_class | append: ' product-information--media-left'
  endif

  if settings.equal_columns and is_main_product_page == false
    assign product_grid_class = product_grid_class | append: ' product-information__grid--half'

    if settings.limit_details_width
      assign product_grid_class = product_grid_class | append: ' product-information__grid--limit-details'
    endif
  endif

  # Determine content width
  case settings.content_width
    when 'content-center-aligned'
      assign content_width = 'page-width'
    when 'content-full-width'
      assign content_width = 'full-width'
  endcase

%}

{% liquid
  if settings.background_color != blank
    render 'contrast-override', background_color: settings.background_color, section_id: section_id
  endif
%}

<div
  class="section-background{% if settings.background_color != blank %} color-custom-{{ section_id }}{% endif %}"
></div>
<div
  class="product-information section section--{{ content_width }} spacing-style{% if settings.background_color != blank %} color-custom-{{ section_id }}{% endif %} relative{% if is_main_product_page %} product-information--main-product{% endif %}"
  style="{% render 'spacing-style', settings: settings %} --gap: {{ settings.gap }}px;"
  data-testid="product-information"
>
  {% if settings.desktop_media_position == 'left' and product_has_media and request.page_type == 'product' %}
    {% assign product_href = '#ProductInformation-' | append: section_id %}
    {% render 'skip-to-content-link', href: product_href, text: 'accessibility.skip_to_product_info' %}
  {% endif %}
  <product-component
    class="{{ product_grid_class }}"
    data-product-grid-content
    {% # theme-check-disable UnknownFilter %}
    view-event-payload="{{ product | standard_event_data: 'view' | escape }}"
    {% # theme-check-enable UnknownFilter %}
  >
    {% assign render_order_array = render_order | split: ',' %}
    {% capture media %}
      <div
        class="product-information__media"
        data-testid="product-information-media"
      >
        {{ media_gallery }}
      </div>
    {% endcapture %}

    {% for block in render_order_array %}
      {% if block == 'media' and product_has_media %}
        {{ media }}
      {% elsif block == 'product-details' %}
        {{ product_details }}
      {% endif %}
    {% endfor %}
  </product-component>

  {% if is_main_product_page %}
    <div class="product-information__details-below" data-product-details-below hidden></div>
  {% endif %}

  {{ additional_blocks }}
</div>

{% stylesheet %}
  .product-information {
    gap: var(--gap) 0;
  }

  .product-information--main-product {
    --product-surface: #fffaf4;
    --product-surface-alt: #fff9f2;
    --product-border: rgba(92, 61, 42, 0.12);
    --product-shadow: 0 22px 44px rgba(47, 36, 29, 0.08);
    max-width: min(1440px, calc(100vw - clamp(24px, 4vw, 48px)));
    margin-inline: auto;
  }

  /* Base grid layout */
  .product-information__grid {
    display: grid;
    grid-template-columns: subgrid;
    grid-column: 1 / -1;
  }

  /* Default column positions */
  .product-details {
    order: 1;
  }

  .product-information__media {
    order: 0;
    width: 0;
    min-width: 100%;
  }

  .product-information__media .product-media-gallery__placeholder-image {
    width: 100%;
    height: 100%;
  }

  .product-information__details-below[hidden] {
    display: none;
  }

  .product-information--main-product .product-information__details-below {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 16px;
    margin-top: clamp(18px, 2vw, 26px);
    position: relative;
    isolation: isolate;
  }

  .product-information--main-product .product-information__details-below::before {
    content: '';
    position: absolute;
    inset: -8px -8px -10px;
    border-radius: 26px;
    background:
      radial-gradient(circle at top left, rgba(255, 241, 225, 0.98), transparent 34%),
      radial-gradient(circle at bottom right, rgba(255, 247, 238, 0.86), transparent 28%),
      linear-gradient(180deg, rgba(255, 254, 251, 0.98) 0%, rgba(255, 249, 242, 0.96) 100%);
    border: 1px solid rgba(120, 84, 58, 0.12);
    box-shadow:
      0 26px 54px rgba(47, 36, 29, 0.08),
      0 12px 24px rgba(184, 115, 69, 0.06);
    z-index: -1;
    pointer-events: none;
  }

  .product-information--main-product .product-information__details-below > :only-child {
    grid-column: 1 / -1;
  }

  .product-information--main-product .product-information__details-below > rte-formatter,
  .product-information--main-product .product-information__details-below > .accordion {
    --width: 100%;
    --max-width: 100%;
    display: block;
    width: 100%;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 249, 242, 0.93) 100%);
    border: 1px solid rgba(120, 84, 58, 0.18);
    border-radius: 22px;
    padding: clamp(18px, 1.8vw, 24px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.94),
      inset 0 0 0 1px rgba(255, 255, 255, 0.5),
      0 22px 42px rgba(47, 36, 29, 0.06);
  }

  .product-information--main-product .product-information__details-below > .accordion {
    display: none;
  }

  .product-information--main-product .product-description-rich {
    display: block;
    width: 100%;
    color: #4f3c31;
  }

  .product-information--main-product .product-description-rich__layout {
    display: grid;
    width: 100%;
    gap: 16px;
  }

  .product-information--main-product .product-description-rich__section {
    min-width: 0;
  }

  .product-information--main-product .product-description-rich__section--intro {
    max-width: 68ch;
  }

  .product-information--main-product .product-description-rich__section--intro > p:first-child {
    margin: 0;
    color: #5f4a3c;
    font-size: clamp(1.02rem, 1.25vw, 1.15rem);
    line-height: 1.75;
  }

  .product-information--main-product .product-description-rich__section--features,
  .product-information--main-product .product-description-rich__section--specs {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.86) 0%, rgba(255, 251, 246, 0.8) 100%);
    border: 1px solid rgba(120, 84, 58, 0.16);
    border-radius: 18px;
    padding: clamp(16px, 1.55vw, 20px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.92),
      inset 0 0 0 1px rgba(255, 255, 255, 0.45),
      0 16px 30px rgba(47, 36, 29, 0.05);
  }

  .product-information--main-product
    .product-description-rich__section
    > :is(h2, h3, h4, h5, h6):first-child {
    margin: 0 0 12px;
    color: #2f241d;
    font-size: clamp(1.65rem, 2vw, 2.1rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
  }

  .product-information--main-product .product-description-rich ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 12px;
  }

  .product-information--main-product .product-description-rich li {
    position: relative;
    margin: 0;
    padding-left: 1.45rem;
    color: #5a473b;
    line-height: 1.72;
  }

  .product-information--main-product .product-description-rich li::before {
    content: '';
    position: absolute;
    top: 0.78rem;
    left: 0.2rem;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    background: #b87345;
    transform: translateY(-50%);
  }

  .product-information--main-product .product-description-rich .rte-table-wrapper {
    margin: 0;
  }

  .product-information--main-product .product-description-rich table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    overflow: hidden;
    border: 1px solid rgba(120, 84, 58, 0.1);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.72);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.84);
  }

  .product-information--main-product .product-description-rich th,
  .product-information--main-product .product-description-rich td {
    padding: 10px 13px;
    border-bottom: 1px solid rgba(92, 61, 42, 0.08);
    vertical-align: top;
    text-align: left;
    line-height: 1.55;
  }

  .product-information--main-product .product-description-rich tr:last-child :is(th, td) {
    border-bottom: 0;
  }

  .product-information--main-product .product-description-rich th {
    width: 32%;
    color: #2f241d;
    font-weight: 600;
    background: rgba(255, 249, 242, 0.78);
  }

  .product-information--main-product .product-description-rich td {
    color: #5f4a3c;
    background: rgba(255, 255, 255, 0.56);
    word-break: break-word;
  }

  .product-information--main-product .product-description-rich__section--specs > p:last-child {
    margin: 14px 0 0;
    color: #7b6657;
    font-size: 0.92rem;
    line-height: 1.6;
  }

  /* Mobile styles */
  @media screen and (max-width: 749px) {
    .product-information__media {
      grid-column: 1 / -1;
    }

    .product-details {
      grid-column: 2 / 3;
    }
  }

  /* Desktop styles */
  @media screen and (min-width: 750px) {
    .product-information__grid {
      grid-column: 2;
    }

    .product-information--main-product .product-information__grid:not(.product-information--media-none) {
      align-items: start;
      gap: clamp(36px, 4vw, 64px);
      grid-column: 1 / -1;
    }

    /* Position when there is no media */
    .product-information__grid.product-information--media-none {
      .product-details {
        width: var(--narrow-content-width);
        margin: 0 auto;
      }
    }

    /* Position when there is media */
    .product-information__grid:not(.product-information--media-none) {
      /* Media on the left side */
      &.product-information--media-left {
        grid-template-columns: 1fr min(50vw, var(--sidebar-width));

        .product-information__media {
          padding-right: calc(var(--gap, 0) / 2);
        }

        .product-details {
          padding-left: calc(var(--gap, 0) / 2);
        }

        &:has(.media-gallery--extend) {
          grid-column: 1 / 3;
        }
      }

      /* Media on the right side */
      &.product-information--media-right {
        grid-template-columns: min(50vw, var(--sidebar-width)) 1fr;

        .product-information__media {
          padding-left: calc(var(--gap, 0) / 2);
          order: 1;
        }

        .product-details {
          padding-right: calc(var(--gap, 0) / 2);
          order: 0;
        }

        &:has(.media-gallery--extend) {
          grid-column: 2 / -1;
        }
      }

      /* Equal width columns */
      &.product-information__grid--half,
      &.product-information__grid--half:has(.media-gallery--extend) {
        grid-column: 1 / -1;
        grid-template-columns:
          var(--full-page-grid-margin) calc(var(--full-page-grid-central-column-width) / 2) calc(
            var(--full-page-grid-central-column-width) / 2
          )
          var(--full-page-grid-margin);

        &.product-information--media-left {
          .product-information__media {
            grid-column: 2 / 3;

            &:has(.media-gallery--extend) {
              grid-column: 1 / 3;
            }
          }

          .product-details {
            grid-column: 3 / 4;
          }
        }

        &.product-information--media-right {
          .product-information__media {
            grid-column: 3 / 4;

            &:has(.media-gallery--extend) {
              grid-column: 3 / -1;
            }
          }

          .product-details {
            grid-column: 2 / 3;
          }
        }
      }
    }

    /* Handle full width section */
    .section--full-width {
      .product-information__grid:not(.product-information--media-none) {
        &.product-information--media-left,
        &.product-information--media-right {
          grid-column: 1 / -1;
        }

        &.product-information--media-left .product-details {
          padding-inline-end: var(--padding-lg);
        }

        &.product-information--media-right .product-details {
          padding-inline-start: var(--padding-lg);
        }

        &.product-information__grid--half.product-information--media-left {
          .product-information__media {
            grid-column: 1 / 3;
          }

          .product-details {
            grid-column: 3 / -1;
          }
        }

        &.product-information__grid--half.product-information--media-right {
          .product-information__media {
            grid-column: 3 / -1;
          }

          .product-details {
            grid-column: 1 / 3;
          }
        }
      }
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .product-information--main-product .product-information__grid:not(.product-information--media-none) {
      grid-template-columns: minmax(0, 1fr);
    }

    .product-information--main-product .product-information__media,
    .product-information--main-product .product-details {
      padding-inline: 0;
      grid-column: 1 / -1;
      order: initial;
    }
  }

  /* Wider sidebar for large screens */
  @media screen and (min-width: 1200px) {
    .product-information__grid:not(
        .product-information__grid--half,
        .product-information--media-none
      ).product-information--media-left {
      grid-template-columns: 2fr 1fr;
    }

    .product-information__grid:not(
        .product-information__grid--half,
        .product-information--media-none
      ).product-information--media-right {
      grid-template-columns: 1fr 2fr;
    }
  }

  .product-information__grid--limit-details .product-details > .group-block {
    --details-max-width: var(--sidebar-width);
    max-width: var(--details-max-width);
  }

  @media screen and (min-width: 1600px) {
    .product-information__grid--limit-details .product-details > .group-block {
      --details-max-width: 32rem;
    }
  }

  /* If the header is sticky, make product details content stick underneath the header */
  body:has(#header-group #header-component[data-sticky-state='active']) .product-details.sticky-content--desktop {
    --sticky-header-offset: var(--header-height);
  }

  @media screen and (min-width: 750px) {
    .product-information--main-product .product-information__grid.product-information--media-left,
    .product-information--main-product .product-information__grid.product-information--media-right {
      grid-template-columns: minmax(0, 1fr) minmax(22rem, 0.92fr);
      grid-column: 1 / -1;
      justify-content: space-between;
    }

    .product-information--main-product .product-information__grid.product-information--media-right {
      grid-template-columns: minmax(22rem, 0.92fr) minmax(0, 1fr);
    }

    .product-information--main-product .product-information__grid.product-information__grid--half .product-information__media,
    .product-information--main-product .product-information__grid.product-information__grid--half .product-details {
      grid-column: auto;
    }

    .product-information--main-product .product-information__media,
    .product-information--main-product .product-details {
      padding-inline: 0;
    }

    .product-information--main-product .product-information__media {
      width: 100%;
      min-width: 0;
    }

    .product-information--main-product .product-information__details-below {
      grid-template-columns: minmax(0, 1fr);
      gap: 14px;
    }

    .product-information--main-product .product-description-rich__layout {
      grid-template-columns: minmax(0, 1.08fr) minmax(19rem, 0.92fr);
      align-items: start;
      gap: 18px;
    }

    .product-information--main-product .product-description-rich__section--intro {
      grid-column: 1 / -1;
      max-width: 72ch;
    }
  }

  @media screen and (max-width: 749px) {
    .product-information--main-product {
      max-width: min(100%, calc(100vw - 24px));
      padding-bottom: max(88px, env(safe-area-inset-bottom));
    }

    .product-information--main-product .product-information__details-below {
      gap: 14px;
      margin-top: 16px;
    }

    .product-information--main-product .product-information__details-below::before {
      inset: -8px -8px -10px;
      border-radius: 24px;
    }

    .product-information--main-product .product-information__details-below > rte-formatter,
    .product-information--main-product .product-information__details-below > .accordion {
      border-radius: 18px;
      padding: 18px;
    }

    .product-information--main-product .product-description-rich__layout {
      grid-template-columns: minmax(0, 1fr);
      gap: 16px;
    }

    .product-information--main-product
      .product-description-rich__section
      > :is(h2, h3, h4, h5, h6):first-child {
      font-size: clamp(1.45rem, 7vw, 1.8rem);
      margin-bottom: 14px;
    }

    .product-information--main-product .product-description-rich__section--features,
    .product-information--main-product .product-description-rich__section--specs {
      padding: 16px;
      border-radius: 16px;
    }

    .product-information--main-product .product-description-rich th,
    .product-information--main-product .product-description-rich td {
      display: block;
      width: 100%;
    }

    .product-information--main-product .product-description-rich th {
      padding-bottom: 6px;
      border-bottom: 0;
      background: transparent;
    }

    .product-information--main-product .product-description-rich td {
      padding-top: 0;
      padding-bottom: 12px;
      background: transparent;
    }

    .product-information--main-product .product-description-rich tr:last-child td {
      padding-bottom: 0;
    }
  }
{% endstylesheet %}
