

{% liquid
  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
  endif
%}

<div
  class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
></div>
<div
  class="section section--{{ section.settings.section_width }}{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
>
  {% liquid
    assign total_blocks = section.blocks.size

    # Grid layout calculations
    assign grid_columns = total_blocks | at_most: 4

    # Calculate last row counts using modulo arithmetic
    # last_row_count = (total_blocks - 1) % N + 1
    assign last_row_count = total_blocks | minus: 1 | modulo: 4 | plus: 1
    assign tablet_last_row_count = total_blocks | minus: 1 | modulo: 2 | plus: 1

    # Check if there are orphaned elements (single item in last row)
    assign has_isolated_grid_item_desktop = false
    assign has_isolated_grid_item_tablet = false

    if total_blocks > 4 and last_row_count == 1
      assign has_isolated_grid_item_desktop = true
    endif

    if total_blocks == 5
      assign has_isolated_grid_item_tablet = true
    endif
  %}
  <div
    class="
      footer-content
      spacing-style
      {% if has_isolated_grid_item_desktop %}footer-content--isolated-grid-item-desktop{% endif %}
      {% if has_isolated_grid_item_tablet %}footer-content--isolated-grid-item-tablet{% endif %}
    "
    style="
      {%  render 'spacing-style', settings: section.settings %}
      --footer-gap: {{ section.settings.gap }}px;
      --grid-columns: {{ grid_columns }};
      --last-row-count: {{ last_row_count }};
      --tablet-last-row-count: {{ tablet_last_row_count }};
    "
  >
    {% content_for 'blocks' %}
  </div>
</div>

{% stylesheet %}
  .section:has(.footer-content),
  .section:has(.footer-content) .section-background,
  .section:has(.utilities),
  .section:has(.utilities) .section-background {
    background-color: #2f241d !important;
    color: #fff9f2 !important;
  }

  .section-background + .section:has(.footer-content)::before {
    content: '';
    position: absolute;
    top: -4.5rem;
    right: 0;
    left: 0;
    height: 4.5rem;
    background: linear-gradient(180deg, rgba(216, 202, 186, 0) 0%, rgba(47, 36, 29, 0.72) 100%);
    pointer-events: none;
    z-index: 0;
  }

  .footer-content {
    position: relative;
    z-index: 1;
    contain: content;
    content-visibility: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--footer-gap);
    align-items: start;
    padding: 3rem 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-inline: 0;
    border-bottom: 0;
    border-radius: 0;
    background: transparent;
  }

  .footer-content::before {
    content: '';
    position: absolute;
    top: -3.5rem;
    right: 0;
    left: 0;
    height: 3.5rem;
    background: linear-gradient(180deg, rgba(47, 36, 29, 0) 0%, rgba(47, 36, 29, 0.62) 100%);
    pointer-events: none;
  }

  .footer-content > * {
    min-width: 0;
  }

  /* Headings styling */
  .footer-content :is(.menu__heading, .menu__heading__default, .text-block.h3 > *, .text-block.h2 > *, h2, h3, h4) {
    color: #fff9f2 !important;
    font-family: var(--font-primary--family), sans-serif;
    font-size: 0.85rem !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.15em !important;
    margin-block-end: 1.5rem !important;
    margin-block-start: 0 !important;
    line-height: 1.2 !important;
    display: block;
  }

  /* List items and links */
  .footer-content .menu__item {
    margin-block-end: 0.75rem !important;
  }
  .footer-content .menu__item + .menu__item {
    margin-block-start: 0.75rem !important;
  }

  .footer-content :is(.menu__item a, .menu a, .menu summary, .social-links a) {
    color: rgba(255, 249, 242, 0.65) !important;
    font-size: 0.95rem !important;
    line-height: 1.6 !important;
    text-decoration: none !important;
    transition: color 0.3s cubic-bezier(0.25, 0.1, 0.25, 1) !important;
  }

  .footer-content :is(.menu__item a:hover, .menu a:hover, .menu summary:hover, .social-links a:hover) {
    color: #d9a06f !important;
  }

  /* Social Icons customization */
  .footer-content .social-icons__wrapper {
    justify-content: flex-start !important;
    gap: 1rem !important;
    margin-top: 1rem !important;
  }

  .footer-content .social-icons__icon-wrapper {
    height: auto !important;
    width: auto !important;
  }

  .footer-content .social-icons__icon-wrapper a {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 2.25rem !important;
    height: 2.25rem !important;
    border-radius: 50% !important;
    border: 1px solid rgba(255, 255, 255, 0.12) !important;
    background-color: rgba(255, 255, 255, 0.03) !important;
    transition: all 0.3s ease !important;
  }

  .footer-content .social-icons__icon-wrapper a:hover {
    border-color: #d9a06f !important;
    background-color: rgba(217, 160, 111, 0.08) !important;
    transform: translateY(-2px) !important;
  }

  .footer-content .social-icons__icon {
    width: 1.1rem !important;
    height: 1.1rem !important;
    color: rgba(255, 249, 242, 0.75) !important;
    fill: currentColor !important;
    display: block !important;
  }

  .footer-content .social-icons__icon-wrapper a:hover .social-icons__icon {
    color: #d9a06f !important;
  }

  .footer-content .social-icons__icon-label {
    display: none !important;
  }

  /* Email Signup in Footer */
  .footer-content .email-signup-block {
    width: 100% !important;
    max-width: 320px !important;
    margin-top: 1.25rem !important;
  }

  .footer-content .email-signup__input-group {
    display: flex !important;
    align-items: stretch !important;
    border: 1px solid rgba(255, 255, 255, 0.15) !important;
    border-radius: 4px !important;
    background-color: rgba(255, 255, 255, 0.04) !important;
    padding: 3px !important;
    transition: border-color 0.3s ease !important;
  }

  .footer-content .email-signup__input-group:focus-within {
    border-color: #d9a06f !important;
  }

  .footer-content .email-signup__input {
    flex: 1 !important;
    border: none !important;
    background: transparent !important;
    color: #fff9f2 !important;
    padding: 0.75rem 1rem !important;
    font-size: 0.95rem !important;
    outline: none !important;
  }

  .footer-content .email-signup__input::placeholder {
    color: rgba(255, 249, 242, 0.4) !important;
  }

  .footer-content .email-signup__button {
    background-color: #d9a06f !important;
    color: #2f241d !important;
    border: none !important;
    border-radius: 3px !important;
    padding: 0.75rem 1.25rem !important;
    font-weight: 600 !important;
    font-size: 0.9rem !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
    cursor: pointer !important;
    transition: background-color 0.3s ease, color 0.3s ease !important;
  }

  .footer-content .email-signup__button:hover {
    background-color: #fff9f2 !important;
    color: #2f241d !important;
  }

  /* Responsive breakpoints */
  @media screen and (max-width: 749px) {
    .footer-content {
      grid-template-columns: 1fr !important;
      gap: 2.5rem !important;
      padding: 3.5rem 1rem !important;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .footer-content {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 3rem 2rem !important;
      padding: 4rem 2rem !important;
    }
  }

  @media screen and (min-width: 990px) {
    .footer-content {
      grid-template-columns: repeat(var(--grid-columns), 1fr) !important;
      gap: clamp(2.5rem, 4.5vw, 5.5rem) !important;
      padding: 4.5rem 0 3.5rem 0 !important;
    }

    /* Single item centered */
    .footer-content[style*='--grid-columns: 1'] {
      justify-items: center !important;
    }

    .footer-content--isolated-grid-item-desktop > :last-child {
      grid-column: 1 / -1 !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.footer",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "_divider"
    },
    {
      "type": "@app"
    },
    {
      "type": "button"
    },
    {
      "type": "follow-on-shop"
    },
    {
      "type": "group"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "menu"
    },
    {
      "type": "payment-icons"
    },
    {
      "type": "text"
    },
    {
      "type": "logo"
    },
    {
      "type": "jumbo-text"
    },
    {
      "type": "social-links"
    },
    {
      "type": "email-signup"
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "default": "{{ settings.color_palette.foreground }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "t:names.footer",
      "category": "t:categories.footer",
      "settings": {
        "gap": 20,
        "padding-block-start": 36,
        "padding-block-end": 36
      },
      "blocks": {
        "newsletter-group": {
          "type": "group",
          "settings": {
            "content_direction": "column",
            "vertical_on_mobile": true,
            "horizontal_alignment": "flex-start",
            "vertical_alignment": "center",
            "gap": 6,
            "width": "fill"
          },
          "blocks": {
            "newsletter-heading": {
              "type": "text",
              "settings": {
                "text": "t:html_defaults.join_our_email_list",
                "width": "100%",
                "alignment": "left",
                "type_preset": "h3"
              }
            },
            "newsletter-text": {
              "type": "text",
              "settings": {
                "text": "t:html_defaults.get_exclusive_deals_and_early_access_to_new_products",
                "width": "100%",
                "alignment": "left",
                "type_preset": "rte"
              }
            }
          },
          "block_order": ["newsletter-heading", "newsletter-text"]
        },
        "newsletter-form": {
          "type": "email-signup",
          "settings": {
            "width": "fill"
          }
        }
      },
      "block_order": ["newsletter-group", "newsletter-form"]
    }
  ]
}
{% endschema %}
