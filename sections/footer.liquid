{% liquid
  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
  endif
%}

<div class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"></div>
<div class="section section--{{ section.settings.section_width | default: 'page-width' }}{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}">
  <div class="footer-wrapper">
    <!-- Top Group: Brand Hero & Newsletter Card -->
    <div class="footer-top-section">
      <!-- 1. Brand intro center -->
      <div class="footer-brand">
        <div class="footer-brand__decor">
          <span class="decor-dot"></span>
          <span class="decor-leaf">
            <img
              src="{{ 'leaf.svg' | asset_url }}"
              alt=""
              class="footer-brand__leaf"
              loading="lazy">
          </span>
          <span class="decor-dot"></span>
        </div>
        <div class="footer-brand__logo">
          <img
            src="{{ 'logo_inverse.png' | asset_url }}"
            alt="JEMINISE"
            width="280"
            height="auto"
            loading="lazy">
        </div>
        <p class="footer-brand__tagline">
          Soft bedding made for warmer nights,<br class="hide-mobile">
          calmer rooms, and thoughtful gifting.
        </p>
      </div>

      <!-- 2. Newsletter card center -->
      <div class="footer-newsletter">
        <div class="footer-newsletter__left">
          <div class="footer-newsletter__icon">
            <img
              src="{{ 'mail.svg' | asset_url }}"
              alt=""
              class="footer-icon footer-icon--newsletter"
              loading="lazy">
          </div>
          <div class="footer-newsletter__text">
            <h3 class="footer-newsletter__title">Stay in the loop</h3>
            <p class="footer-newsletter__subtitle">New arrivals, cozy ideas, and exclusive offers.</p>
          </div>
        </div>
        <div class="footer-newsletter__right">
          {% form 'customer'
            , class: 'footer-newsletter__form' %}
            <input
              type="hidden"
              name="contact[tags]"
              value="newsletter">
            <div class="footer-newsletter__input-group">
              <input
                type="email"
                name="contact[email]"
                class="footer-newsletter__input"
                placeholder="Email address"
                autocorrect="off"
                autocapitalize="off"
                required>
              <button type="submit" class="footer-newsletter__submit">Subscribe &rarr;</button>
            </div>
          {% endform %}
        </div>
      </div>
    </div>

    <!-- Tầng 3: Main info band -->
    <div class="footer-info-wrapper">
      <div class="footer-info">
        <!-- Column 1: Contact -->
        <div class="footer-info__col">
          <div class="footer-info__badge">
            <img
              src="{{ 'mail.svg' | asset_url }}"
              alt=""
              class="footer-icon footer-icon--contact"
              loading="lazy">
          </div>
          <div class="footer-info__content">
            <h4 class="footer-info__title">CONTACT</h4>
            <ul class="footer-info__list">
              <li>
                <span class="contact-icon">
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round">
                    <rect
                      width="20"
                      height="16"
                      x="2"
                      y="4"
                      rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                  </svg>
                </span>
                <a href="mailto:hello@jeminise.com">hello@jeminise.com</a>
              </li>
              <li>
                <span class="contact-icon">
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                  </svg>
                </span>
                <a href="tel:+15551234567">+1 (555) 123-4567</a>
              </li>
              <li>
                <span class="contact-icon">
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round">
                    <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" /><circle
                      cx="12"
                      cy="10"
                      r="3" />
                  </svg>
                </span>
                <span>123 Cozy Lane, Irvine, CA 92618</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Divider 1 -->
        <div class="footer-info__divider"></div>

        <!-- Column 2: Help -->
        <div class="footer-info__col">
          <div class="footer-info__badge">
            <img
              src="{{ 'headset.svg' | asset_url }}"
              alt=""
              class="footer-icon footer-icon--help"
              loading="lazy">
          </div>
          <div class="footer-info__content">
            <h4 class="footer-info__title">HELP</h4>
            <ul class="footer-info__list footer-info__list--inline">
              {%- if linklists['footer-help'].links.size > 0 -%}
                {%- for link in linklists['footer-help'].links -%}
                  <li>
                    <a href="{{ link.url }}">{{ link.title }}</a>
                    {%- unless forloop.last -%}
                      <span class="footer-info__dot">&middot;</span>
                    {%- endunless -%}
                  </li>
                {%- endfor -%}
              {%- else -%}
                <li>
                  <a href="#">Contact Us</a>
                  <span class="footer-info__dot">&middot;</span>
                </li>
                <li>
                  <a href="#">FAQ</a>
                  <span class="footer-info__dot">&middot;</span>
                </li>
                <li>
                  <a href="#">Shipping</a>
                  <span class="footer-info__dot">&middot;</span>
                </li>
                <li>
                  <a href="#">Returns</a>
                  <span class="footer-info__dot">&middot;</span>
                </li>
                <li>
                  <a href="#">Track Order</a>
                </li>
              {%- endif -%}
            </ul>
          </div>
        </div>

        <!-- Divider 2 -->
        <div class="footer-info__divider"></div>

        <!-- Column 3: About -->
        <div class="footer-info__col">
          <div class="footer-info__badge">
            <img
              src="{{ 'home.svg' | asset_url }}"
              alt=""
              class="footer-icon footer-icon--about"
              loading="lazy">
          </div>
          <div class="footer-info__content">
            <h4 class="footer-info__title">ABOUT</h4>
            <ul class="footer-info__list footer-info__list--inline">
              {%- if linklists['footer-about'].links.size > 0 -%}
                {%- for link in linklists['footer-about'].links -%}
                  <li>
                    <a href="{{ link.url }}">{{ link.title }}</a>
                    {%- unless forloop.last -%}
                      <span class="footer-info__dot">&middot;</span>
                    {%- endunless -%}
                  </li>
                {%- endfor -%}
              {%- else -%}
                <li>
                  <a href="#">Our Story</a>
                  <span class="footer-info__dot">&middot;</span>
                </li>
                <li>
                  <a href="#">Blog</a>
                </li>
              {%- endif -%}
            </ul>
          </div>
        </div>

        <!-- Divider 3 -->
        <div class="footer-info__divider"></div>

        <!-- Column 4: Legal -->
        <div class="footer-info__col">
          <div class="footer-info__badge">
            <img
              src="{{ 'shield.svg' | asset_url }}"
              alt=""
              class="footer-icon footer-icon--legal"
              loading="lazy">
          </div>
          <div class="footer-info__content">
            <h4 class="footer-info__title">LEGAL</h4>
            <ul class="footer-info__list footer-info__list--inline footer-info__list--wrap">
              {%- if linklists['footer-legal'].links.size > 0 -%}
                {%- for link in linklists['footer-legal'].links -%}
                  <li>
                    <a href="{{ link.url }}">{{ link.title }}</a>
                    {%- unless forloop.last -%}
                      <span class="footer-info__dot">&middot;</span>
                    {%- endunless -%}
                  </li>
                {%- endfor -%}
              {%- else -%}
                <li>
                  <a href="#">Privacy Policy</a>
                  <span class="footer-info__dot">&middot;</span>
                </li>
                <li>
                  <a href="#">Terms of Service</a>
                  <span class="footer-info__dot">&middot;</span>
                </li>
                <li>
                  <a href="#">Refund Policy</a>
                  <span class="footer-info__dot">&middot;</span>
                </li>
                <li>
                  <a href="#">Shipping Policy</a>
                  <span class="footer-info__dot">&middot;</span>
                </li>
                <li>
                  <a href="#">Subscription Policy</a>
                </li>
              {%- endif -%}
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer Divider SVG -->
    <div class="footer-divider-svg" aria-hidden="true">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1000 100"
        preserveAspectRatio="none"
        focusable="false">
        <g>
          <path d="M0 0v100c250 0 375-24 500-48 125 24 250 48 500 48V0H0Z"></path>
          <path d="M0 0v4c250 0 375 24 500 48C625 28 750 4 1000 4V0H0Z"></path>
        </g>
      </svg>
    </div>

    <!-- Bottom Group: Social Row & Copyright Row -->
    <div class="footer-bottom-group">
      <!-- 4. Social row riêng -->
      <div class="footer-social">
        <a href="#" class="footer-social__item">
          <div class="footer-social__icon">
            <img
              src="{{ 'ig.svg' | asset_url }}"
              alt=""
              class="footer-icon footer-icon--social"
              loading="lazy">
          </div>
          <span class="footer-social__label">Instagram</span>
        </a>
        <div class="footer-social__divider"></div>
        <a href="#" class="footer-social__item">
          <div class="footer-social__icon">
            <img
              src="{{ 'fb.svg' | asset_url }}"
              alt=""
              class="footer-icon footer-icon--social"
              loading="lazy">
          </div>
          <span class="footer-social__label">Facebook</span>
        </a>
        <div class="footer-social__divider"></div>
        <a href="#" class="footer-social__item">
          <div class="footer-social__icon">
            <img
              src="{{ 'pinterest.svg' | asset_url }}"
              alt=""
              class="footer-icon footer-icon--social"
              loading="lazy">
          </div>
          <span class="footer-social__label">Pinterest</span>
        </a>
        <div class="footer-social__divider"></div>
        <a href="#" class="footer-social__item">
          <div class="footer-social__icon">
            <img
              src="{{ 'tiktok.svg' | asset_url }}"
              alt=""
              class="footer-icon footer-icon--social"
              loading="lazy">
          </div>
          <span class="footer-social__label">TikTok</span>
        </a>
        <div class="footer-social__divider"></div>
        <a href="#" class="footer-social__item">
          <div class="footer-social__icon">
            <img
              src="{{ 'ytb.svg' | asset_url }}"
              alt=""
              class="footer-icon footer-icon--social"
              loading="lazy">
          </div>
          <span class="footer-social__label">YouTube</span>
        </a>
      </div>

      <!-- 5. Copyright row -->
      <div class="footer-copyright">
        <div class="footer-copyright__rule-wrap">
          <span class="footer-copyright__line"></span>
          <div class="footer-copyright__decor" aria-hidden="true">
            <img
              src="{{ 'clover.svg' | asset_url }}"
              alt=""
              class="footer-copyright__clover"
              loading="lazy">
          </div>
          <span class="footer-copyright__line"></span>
        </div>
        <p class="footer-copyright__text">&copy; {{ 'now' | date: '%Y' }} JEMINISE. All rights reserved.</p>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  /* Section settings override */
  .section:has(.footer-wrapper) {
    padding: 0 !important;
    border-top: none !important;
    background-color: transparent !important;
    max-width: none !important;
    width: 100% !important;
  }
  .section-background:has( + .section:has(.footer-wrapper)) {
    display: none !important;
  }

  .footer-wrapper {
    color: #2f261f;
    font-family: var(--font-primary--family)
    , sans-serif;
    position: relative;
    margin-top: 24px;
    /* Push slightly away from section above */
  }

  /* Top Section (Brand + Newsletter) */
  .footer-top-section {
    background-color: #f2e5db;
    background-image: linear-gradient(180deg, #f5eae1 0%, #f2e5db 100%);
    padding: 36px 20px 44px;
    position: relative;
    overflow: hidden;
  }

  .footer-top-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 50% 0%, rgba(201, 133, 90, 0.08), transparent 38%);
    pointer-events: none;
    z-index: 1;
  }

  @media screen and (min-width: 990px) {
    .footer-top-section {
      padding: 48px 48px 54px;
    }
  }

  /* 1. Brand intro */
  .footer-brand {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 38px;
    position: relative;
    z-index: 2;
  }

  .footer-brand__decor {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    width: fit-content;
    margin: 0 auto 12px;
    transform: none;
    position: relative;
  }
  .footer-brand__decor .decor-dot {
    width: 6px;
    height: 6px;
    background-color: #c9855a;
    border-radius: 50%;
    opacity: 0.8;
    flex: 0 0 auto;
  }
  .footer-brand__leaf {
    display: block;
    width: 40px;
    height: auto;
    object-fit: contain;
    opacity: 1;
  }

  .decor-leaf {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #c9855a;
  }

  .footer-brand__logo {
    margin: 0 auto 12px;
    display: flex;
    justify-content: center;
    max-width: 195px;
  }
  @media screen and (min-width: 990px) {
    .footer-brand__logo {
      max-width: 270px;
    }
  }
  .footer-brand__logo img {
    width: 100%;
    height: auto;
    display: block;
  }
  .footer-brand__tagline {
    font-family: var(--font-primary--family)
    , serif;
    font-size: clamp(1.05rem, 1.5vw, 1.1rem);
    line-height: 1.5;
    color: #8a7566;
    margin: 0;
    max-width: 600px;
    margin-inline: auto;
  }

  @media screen and (max-width: 749px) {
    .hide-mobile {
      display: none;
    }

    .footer-brand__decor {
      gap: 10px;
    }

    .footer-brand__leaf {
      width: 32px;
    }
  }

  /* 2. Newsletter card */
  .footer-newsletter {
    background-color: #ffffff;
    border: 1px solid rgba(201, 133, 90, 0.12);
    border-radius: 30px;
    box-shadow: 0 18px 50px rgba(47, 38, 31, 0.07);
    max-width: 940px;
    margin: 0 auto;
    padding: 26px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
    z-index: 3;
  }

  @media screen and (min-width: 990px) {
    .footer-newsletter {
      padding: 30px 48px;
      border-radius: 34px;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 40px;
    }
  }

  .footer-newsletter__left {
    display: flex;
    align-items: center;
    gap: 16px;
    text-align: left;
  }

  .footer-icon {
    display: block;
    object-fit: contain;
  }

  .footer-icon--newsletter {
    width: 60px;
    height: 60px;
  }

  .footer-newsletter__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background-color: #f4eae1;
    border: 1px solid rgba(201, 133, 90, 0.1);
    border-radius: 50%;
    flex-shrink: 0;
    color: #8a7566;
  }
  .footer-newsletter__text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .footer-newsletter__title {
    font-family: var(--font-primary--family)
    , serif;
    font-size: clamp(1.2rem, 2vw, 1.35rem);
    font-weight: 500;
    margin: 0;
    color: #2f261f;
    line-height: 1.25;
  }
  .footer-newsletter__subtitle {
    font-size: 0.92rem;
    color: #8a7566;
    margin: 0;
    line-height: 1.4;
  }

  .footer-newsletter__right {
    flex: 1;
    max-width: 440px;
    width: 100%;
  }

  .footer-newsletter__form {
    width: 100%;
    margin: 0;
  }

  .footer-newsletter__input-group {
    display: flex;
    background-color: #fffaf4;
    border: 1px solid #e4d3c4;
    border-radius: 50px;
    padding: 4px 4px 4px 18px;
    transition: border-color 0.3s
    , box-shadow 0.3s;
    width: 100%;
    box-sizing: border-box;
  }
  .footer-newsletter__input-group:focus-within {
    border-color: #c9855a;
    box-shadow: 0 0 0 2px rgba(201, 133, 90, 0.1);
  }

  .footer-newsletter__input {
    flex: 1;
    border: none;
    background: transparent;
    font-size: 0.95rem;
    color: #2f261f;
    outline: none;
    min-width: 0;
    padding: 8px 0;
  }
  .footer-newsletter__input::placeholder {
    color: #8a7566;
    opacity: 0.7;
  }

  .footer-newsletter__submit {
    background-color: #c9855a;
    color: #fffaf4;
    border: none;
    border-radius: 50px;
    padding: 10px 24px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .footer-newsletter__submit:hover {
    background-color: #b3734a;
  }

  /* 3. Navigation/contact band */
  .footer-info-wrapper {
    background-color: #faf6f2;
    border-top: 1px solid #e4d3c4;
    padding: 36px 20px;
    position: relative;
    z-index: 2;
  }

  @media screen and (min-width: 990px) {
    .footer-info-wrapper {
      padding: 48px 48px 46px;
    }
  }

  .footer-info {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 1360px;
    margin: 0 auto;
  }

  @media screen and (min-width: 768px) {
    .footer-info {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: 24px;
    }
    .footer-info__col {
      flex: 1 1 calc(50% - 24px);
      max-width: calc(50% - 24px);
    }
  }

  @media screen and (min-width: 990px) {
    .footer-info {
      display: grid;
      grid-template-columns: 1.18fr auto 1fr auto 0.9fr auto 1.2fr;
      align-items: start;
      gap: 0;
    }
    .footer-info__col {
      flex: none;
      max-width: none;
    }
    .footer-info__divider {
      display: block;
      width: 1px;
      background-color: rgba(201, 133, 90, 0.22);
      height: 96px;
      margin: 0 24px;
      align-self: center;
      position: relative;
    }
    .footer-info__divider::after {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 6px;
      height: 6px;
      background-color: #c9855a;
      border-radius: 50%;
    }
  }

  @media screen and (max-width: 989px) {
    .footer-info__divider {
      display: none;
    }
  }

  .footer-info__col {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    text-align: left;
  }

  .footer-info__badge {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background-color: #f4eae1;
    border: 1px solid rgba(201, 133, 90, 0.12);
    box-shadow: 0 4px 10px rgba(47, 38, 31, 0.02);
    color: #6f5f52;
    flex-shrink: 0;
  }
  .footer-info__badge .footer-icon {
    width: 60px;
    height: 60px;
  }

  .footer-info__content {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .footer-info__title {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #2f261f;
    margin: 0;
  }

  .footer-info__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-info__list--inline {
    flex-direction: row;
    flex-wrap: wrap;
    row-gap: 6px;
    column-gap: 8px;
  }

  .footer-info__list li {
    display: flex;
    align-items: center;
    font-size: 0.9rem;
    line-height: 1.6;
    color: #6f5f52;
  }

  .footer-info__list a {
    color: #6f5f52;
    text-decoration: none;
    transition: color 0.25s;
  }

  .footer-info__list a:hover {
    color: #c9855a;
  }

  .contact-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-right: 6px;
    color: #8a7566;
    flex-shrink: 0;
  }

  .footer-info__dot {
    color: #c9855a;
    margin: 0 4px;
    opacity: 0.8;
  }

  /* Wave Sep - SVG Landscape transition band */
  .footer-divider-svg {
    position: relative;
    width: 100%;
    height: 32px;
    line-height: 0;
    background: #faf6f2;
    /* matches info row background */
    overflow: hidden;
  }
  .footer-divider-svg svg {
    display: block;
    width: 100%;
    height: 100%;
    transform: scaleY(-1);
  }
  .footer-divider-svg path:first-child {
    fill: #efe3d7;
    opacity: 0.55;
  }
  .footer-divider-svg path:last-child {
    fill: #e6c8b7;
  }
  @media screen and (max-width: 749px) {
    .footer-divider-svg {
      height: 20px;
    }

    .footer-copyright__clover {
      width: 18px;
    }
  }

  /* Bottom Section (Socials + Copyright) */
  .footer-bottom-group {
    background: linear-gradient(180deg, #fbf8f4 0%, #f8f1ea 100%);
    padding: 12px 20px 18px;
    position: relative;
    z-index: 2;
  }

  @media screen and (min-width: 990px) {
    .footer-bottom-group {
      padding: 14px 48px 20px;
    }
  }

  /* 4. Social row */
  .footer-social {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    max-width: 960px;
    margin-inline: auto;
  }

  @media screen and (min-width: 768px) {
    .footer-social {
      gap: 24px;
    }
  }

  .footer-social__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: #6f5f52;
    transition: transform 0.3s
    , color 0.3s;
    min-width: 64px;
  }

  .footer-social__item:hover {
    color: #c9855a;
    transform: translateY(-2px);
  }
  .footer-social__item:hover .footer-social__icon {
    border-color: #c9855a;
    color: #c9855a;
    background-color: #fff;
  }

  .footer-social__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid #e4d3c4;
    background-color: #ffffff;
    color: #6f5f52;
    transition: all 0.3s;
  }
  .footer-social__icon .footer-icon {
    width: 28px;
    height: 28px;
  }

  .footer-social__label {
    font-size: 0.85rem;
    font-weight: 500;
  }

  .footer-social__divider {
    width: 1px;
    height: 26px;
    background-color: #e4d3c4;
  }
  @media screen and (max-width: 767px) {
    .footer-social__divider {
      display: none;
    }
    .footer-social {
      gap: 16px 20px;
    }
  }

  /* 5. Copyright */
  .footer-copyright {
    text-align: center;
    max-width: 1060px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .footer-copyright__rule-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    width: 100%;
    margin-bottom: 11px;
  }

  .footer-copyright__line {
    flex: 1;
    height: 1px;
    background-color: rgba(201, 133, 90, 0.25);
  }

  .footer-copyright__decor {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-copyright__clover {
    display: block;
    width: 22px;
    height: auto;
    object-fit: contain;
  }

  .footer-copyright__text {
    font-size: 0.9rem;
    color: #8a7566;
    margin: 0;
    letter-spacing: 0.02em;
  }
{% endstylesheet %}

{% schema %}
  {
    "name": "t:names.footer",
    "class": "section-wrapper",
    "enabled_on": {
      "groups": ["footer"]
    },
    "settings": [
      {
        "type": "select",
        "id": "section_width",
        "label": "t:settings.width",
        "options": [
          {
            "value": "page-width",
            "label": "t:options.page"
          }, {
            "value": "full-width",
            "label": "t:options.full"
          }
        ],
        "default": "page-width"
      }, {
        "type": "color",
        "id": "background_color",
        "label": "t:settings.background_color"
      }
    ]
  }
{% endschema %}
