

{% liquid
  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
  endif
%}

<div
  class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
></div>
<div
  class="section section--{{ section.settings.section_width }}{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
  {{ section.shopify_attributes }}
>
  <div
    class="utilities utilities--blocks-{{ section.blocks.size }} spacing-style"
    style="{% render 'spacing-style', settings: section.settings %} --border-width: {{ section.settings.divider_thickness }}px;{% if section.settings.divider_color != blank %} --divider-color: {{ section.settings.divider_color }};{% endif %} --gap: {{ section.settings.gap }}px;"
    data-testid="footer-utilities"
  >
    {% content_for 'blocks' %}
  </div>
</div>

{% stylesheet %}
  .section-background + .section:has(.utilities) {
    position: relative;
    background: #2f261f !important;
    color: #f6eee5 !important;
    border-top: none !important;
    padding-block-start: 16px !important;
    padding-block-end: 16px !important;
    min-height: 56px !important;
    display: flex !important;
    align-items: center !important;
    box-sizing: border-box !important;
  }

  .section-background + .section:has(.utilities)::before {
    display: none !important;
  }

  .utilities {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    border-top: none !important;
    color: #f6eee5 !important;
    padding-block-start: 0 !important;
    max-width: var(--page-width, 1400px) !important;
    margin-inline: auto !important;

    @media screen and (min-width: 750px) {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      justify-content: center;
      gap: var(--gap);
      align-items: center;
      text-align: left;
    }
  }

  @media screen and (max-width: 749px) {
    .utilities {
      text-wrap: balance;
      gap: 12px;
      text-align: center !important;
    }

    .utilities > * {
      width: 100%;
      text-align: center !important;
    }
  }

  .utilities a,
  .utilities button,
  .utilities p,
  .utilities span,
  .utilities small {
    color: #f6eee5 !important;
    font-size: 14px !important;
    text-decoration: none !important;
    transition: color 0.25s ease !important;
  }

  .utilities a:hover,
  .utilities button:hover {
    color: #c9855a !important;
  }

  .utilities > * {
    text-align: center;
    min-width: 0;
    max-width: 100%;
    overflow-wrap: anywhere;

    @media screen and (min-width: 750px) {
      text-align: left;
      justify-self: start;
    }
  }

  /* Dynamic positioning based on number of blocks */
  @media screen and (min-width: 750px) {
    /* 1 block: Single column, left aligned */
    .utilities--blocks-1 {
      grid-template-columns: 1fr;
      justify-content: start;
    }

    .utilities--blocks-1 > * {
      justify-self: start;
      text-align: left;
    }

    /* 2 blocks: Two equal columns, start and end aligned */
    .utilities--blocks-2 {
      grid-template-columns: 1fr 1fr;
    }

    .utilities--blocks-2 > *:nth-child(2) {
      justify-self: end;
      text-align: right;
    }

    /* 3 blocks: Three columns (1fr auto 1fr), start/center/end aligned */
    .utilities--blocks-3 {
      grid-template-columns: 1fr auto 1fr;
    }

    .utilities--blocks-3 > *:nth-child(2) {
      justify-self: center;
      text-align: center;
    }

    .utilities--blocks-3 > *:nth-child(3) {
      justify-self: end;
      text-align: right;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.policies_and_links",
  "tag": "div",
  "class": "footer-utilities",
  "max_blocks": 3,
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "default": "{{ settings.color_palette.foreground }}"
    },
    {
      "type": "range",
      "id": "divider_thickness",
      "label": "t:settings.divider_thickness",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "t:settings.divider_color",
      "visible_if": "{{ section.settings.divider_thickness > 0 }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "footer-copyright"
    },
    {
      "type": "footer-policy-list"
    },
    {
      "type": "social-links"
    }
  ],
  "presets": [
    {
      "name": "t:names.policies_and_links",
      "category": "t:categories.footer",
      "blocks": {
        "copyright": {
          "type": "footer-copyright"
        },
        "policy_list": {
          "type": "footer-policy-list"
        },
        "social_icons": {
          "type": "social-links"
        }
      },
      "block_order": ["copyright", "policy_list", "social_icons"]
    }
  ]
}
{% endschema %}
