{% liquid
  assign featured_collection = section.settings.collection
  assign collection_url = section.settings.cta_link
  if collection_url == blank and featured_collection != blank
    assign collection_url = featured_collection.url
  endif

  assign section_title = section.settings.title | default: 'Bestselling Bedding'
  assign section_eyebrow = section.settings.eyebrow | default: 'OUR MOST LOVED'
  assign section_description = section.settings.description | default: 'Loved for softness, warmth and everyday comfort.'
  assign section_cta_label = section.settings.cta_label | default: 'Shop Collection'
  assign promo_alt = section.settings.promo_image.alt | default: section_title
%}

<section
  class="bestselling-bedding color-scheme-{{ section.settings.color_scheme }}"
  data-section-id="{{ section.id }}"
>
  <div class="bestselling-bedding__inner section section--{{ section.settings.section_width }}">
    <div class="bestselling-bedding__shell">
      <div class="bestselling-bedding__grid">
        <div class="bestselling-bedding__visual">
          {% if collection_url != blank %}
            <a class="bestselling-bedding__visual-link" href="{{ collection_url }}">
          {% endif %}
          <div class="bestselling-bedding__visual-frame">
            {% if section.settings.promo_image != blank %}
              {{
                section.settings.promo_image
                | image_url: width: 1800
                | image_tag:
                  class: 'bestselling-bedding__visual-image',
                  widths: '480, 720, 960, 1280, 1600, 1800',
                  sizes: '(min-width: 990px) 38vw, (min-width: 750px) 46vw, 100vw',
                  loading: 'lazy',
                  alt: promo_alt
              }}
            {% else %}
              <img
                class="bestselling-bedding__visual-image"
                src="{{ 'best_seller.png' | asset_url }}"
                loading="lazy"
                alt="{{ promo_alt | escape }}"
              >
            {% endif %}

            <div class="bestselling-bedding__visual-overlay"></div>
            <div class="bestselling-bedding__copy">
              <p class="bestselling-bedding__eyebrow">{{ section_eyebrow | escape }}</p>
              <h2 class="bestselling-bedding__title">{{ section_title | escape }}</h2>
              <p class="bestselling-bedding__description">{{ section_description | escape }}</p>
              {% if collection_url != blank %}
                <span class="bestselling-bedding__cta">
                  <span>{{ section_cta_label | escape }}</span>
                </span>
              {% endif %}
            </div>
          </div>
          {% if collection_url != blank %}
            </a>
          {% endif %}
        </div>

        <div class="bestselling-bedding__products">
          <div class="bestselling-bedding__product-grid">
            {% if featured_collection != blank and featured_collection.products_count > 0 %}
              {% for product in featured_collection.products limit: 6 %}
                {% liquid
                  assign card_variant = product.selected_or_first_available_variant
                  assign product_card_id = 'bestselling-bedding-card-link-' | append: section.id | append: '-' | append: product.id
                  assign current_price = card_variant.price
                  assign compare_price = card_variant.compare_at_price
                  assign max_safe_compare_price = current_price | times: 5
                  assign show_compare_price = false
                  assign has_quick_add = false
                  if settings.quick_add and product.available
                    assign has_quick_add = true
                  endif
                  assign has_mobile_quick_add = false
                  if has_quick_add and settings.mobile_quick_add
                    assign has_mobile_quick_add = true
                  endif
                  if compare_price > current_price and compare_price <= max_safe_compare_price
                    assign show_compare_price = true
                  endif

                  assign badge_label = 'Best Seller'
                  if show_compare_price
                    assign badge_label = 'Sale'
                  endif
                %}

                <product-card
                  class="product-card bestselling-bedding-card"
                  data-product-id="{{ product.id }}"
                  style="
                    --quick-add-display: {% if has_quick_add %}flex{% else %}none{% endif %};
                    --quick-add-mobile-display: {% if has_mobile_quick_add %}flex{% else %}none{% endif %};
                    --quick-add-mobile-opacity: {% if has_mobile_quick_add %}1{% else %}0{% endif %};
                  "
                >
                  <a
                    id="{{ product_card_id | md5 }}"
                    class="bestselling-bedding-card__card-link"
                    href="{{ card_variant.url | default: product.url }}"
                    ref="productCardLink"
                  >
                    <span class="visually-hidden">{{ product.title }}</span>
                  </a>
                  <div class="bestselling-bedding-card__card">
                    <div class="bestselling-bedding-card__media">
                      {% if product.featured_media != blank %}
                        {{
                          product.featured_media
                          | image_url: width: 960
                          | image_tag:
                            class: 'bestselling-bedding-card__image',
                            widths: '220, 320, 480, 640, 960',
                            sizes: '(min-width: 990px) 17vw, (min-width: 750px) 28vw, 46vw',
                            loading: 'lazy',
                            alt: product.featured_media.alt | default: product.title
                        }}
                        {% if product.media.size > 1 %}
                          {{
                            product.media[1]
                            | image_url: width: 960
                            | image_tag:
                              class: 'bestselling-bedding-card__image bestselling-bedding-card__image--hover',
                              widths: '220, 320, 480, 640, 960',
                              sizes: '(min-width: 990px) 17vw, (min-width: 750px) 28vw, 46vw',
                              loading: 'lazy',
                              alt: product.media[1].alt | default: product.title
                          }}
                        {% endif %}
                      {% else %}
                        <div class="bestselling-bedding-card__placeholder" aria-hidden="true">
                          {{ 'product-apparel-1' | placeholder_svg_tag: 'bestselling-bedding-card__placeholder-svg' }}
                        </div>
                      {% endif %}
                      <span class="bestselling-bedding-card__badge{% if badge_label == 'Sale' %} bestselling-bedding-card__badge--sale{% endif %}">
                        {{ badge_label }}
                      </span>
                      {% if settings.quick_add or settings.mobile_quick_add %}
                        {% render 'quick-add', product: product, section_id: section.id %}
                      {% endif %}
                    </div>

                    <div class="bestselling-bedding-card__content">
                      <h3 class="bestselling-bedding-card__title">{{ product.title | escape }}</h3>
                      <div class="bestselling-bedding-card__price-row">
                        <span class="bestselling-bedding-card__price">{{ current_price | money }}</span>
                        {% if show_compare_price %}
                          <span class="bestselling-bedding-card__compare">{{ compare_price | money }}</span>
                        {% endif %}
                      </div>
                    </div>
                  </div>
                </product-card>
              {% endfor %}
            {% else %}
              {% for index in (1..6) %}
                <article class="bestselling-bedding-card bestselling-bedding-card--placeholder">
                  <div class="bestselling-bedding-card__media">
                    <div class="bestselling-bedding-card__placeholder" aria-hidden="true">
                      {{ 'product-apparel-1' | placeholder_svg_tag: 'bestselling-bedding-card__placeholder-svg' }}
                    </div>
                    <span class="bestselling-bedding-card__badge">Best Seller</span>
                  </div>
                  <div class="bestselling-bedding-card__content">
                    <h3 class="bestselling-bedding-card__title">Signature Bedding Set {{ index }}</h3>
                    <div class="bestselling-bedding-card__price-row">
                      <span class="bestselling-bedding-card__price">{{ 8900 | money }}</span>
                    </div>
                  </div>
                </article>
              {% endfor %}
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .bestselling-bedding {
    --bb-surface: #fbf5ee;
    --bb-surface-strong: #fffaf4;
    --bb-card-surface: linear-gradient(180deg, rgba(255, 254, 251, 0.995) 0%, rgba(255, 249, 242, 0.985) 100%);
    --bb-border: rgba(116, 82, 58, 0.26);
    --bb-border-strong: rgba(116, 82, 58, 0.38);
    --bb-text: #46342a;
    --bb-muted: #7f6758;
    --bb-accent: #b87345;
    --bb-accent-strong: #925634;
    --bb-shadow: 0 18px 44px rgba(75, 54, 40, 0.08);
    --bb-card-shadow:
      0 1px 0 rgba(255, 255, 255, 0.9) inset,
      0 14px 30px rgba(80, 58, 43, 0.1),
      0 3px 10px rgba(80, 58, 43, 0.05);
    --bb-card-shadow-hover:
      0 1px 0 rgba(255, 255, 255, 0.94) inset,
      0 20px 40px rgba(80, 58, 43, 0.13),
      0 6px 18px rgba(80, 58, 43, 0.07);
    background:
      radial-gradient(circle at top left, rgba(255, 248, 241, 0.95) 0%, rgba(255, 248, 241, 0) 34%),
      linear-gradient(180deg, #fcf8f2 0%, #f5ecdf 100%);
    color: var(--bb-text);
  }

  .bestselling-bedding__inner {
    padding-block: clamp(1.35rem, 2vw, 2.1rem);
  }

  .bestselling-bedding__shell {
    border: 1px solid var(--bb-border);
    border-radius: 28px;
    background: linear-gradient(180deg, rgba(255, 251, 246, 0.9) 0%, rgba(250, 243, 234, 0.96) 100%);
    box-shadow: var(--bb-shadow);
    padding: clamp(0.9rem, 1.5vw, 1.25rem);
  }

  .bestselling-bedding__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.94fr) minmax(0, 1.34fr);
    gap: clamp(1rem, 1.8vw, 1.4rem);
    align-items: stretch;
  }

  .bestselling-bedding__visual,
  .bestselling-bedding__visual-link {
    display: block;
    height: 100%;
  }

  .bestselling-bedding__visual-frame {
    position: relative;
    min-height: clamp(28rem, 42vw, 36rem);
    height: 100%;
    overflow: hidden;
    border-radius: 24px;
    background:
      linear-gradient(150deg, rgba(244, 225, 208, 0.95) 0%, rgba(222, 196, 173, 0.92) 54%, rgba(195, 160, 134, 0.88) 100%);
  }

  .bestselling-bedding__visual-image,
  .bestselling-bedding__visual-placeholder,
  .bestselling-bedding__placeholder-svg {
    width: 100%;
    height: 100%;
  }

  .bestselling-bedding__visual-image {
    object-fit: cover;
  }

  .bestselling-bedding__visual-placeholder {
    position: relative;
    background:
      radial-gradient(circle at 18% 22%, rgba(255, 255, 255, 0.32) 0%, rgba(255, 255, 255, 0) 22%),
      radial-gradient(circle at 78% 16%, rgba(255, 243, 229, 0.44) 0%, rgba(255, 243, 229, 0) 20%),
      linear-gradient(180deg, #ead9ca 0%, #dbc1ad 52%, #d0af95 100%);
  }

  .bestselling-bedding__placeholder-svg {
    display: block;
    opacity: 0.18;
    color: #ffffff;
  }

  .bestselling-bedding__visual-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 18%, rgba(30, 18, 12, 0.42) 0%, rgba(30, 18, 12, 0.24) 24%, rgba(30, 18, 12, 0.08) 46%, rgba(30, 18, 12, 0) 68%),
      linear-gradient(180deg, rgba(34, 20, 12, 0.08) 0%, rgba(34, 20, 12, 0.05) 34%, rgba(34, 20, 12, 0.18) 100%),
      linear-gradient(90deg, rgba(28, 17, 11, 0.22) 0%, rgba(28, 17, 11, 0.08) 46%, rgba(28, 17, 11, 0.02) 100%);
    pointer-events: none;
  }

  .bestselling-bedding__copy {
    position: absolute;
    inset: 0 auto auto 0;
    z-index: 1;
    display: grid;
    gap: 0.72rem;
    max-width: min(28rem, 72%);
    padding: clamp(1.15rem, 2.3vw, 1.9rem);
    color: #fffdf9;
  }

  .bestselling-bedding__eyebrow {
    margin: 0;
    font-family: var(--font-subheading--family);
    font-style: var(--font-subheading--style);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.19em;
    text-transform: uppercase;
    color: rgba(255, 250, 243, 0.94);
    text-shadow: 0 1px 10px rgba(28, 17, 11, 0.18);
  }

  .bestselling-bedding__title {
    margin: 0;
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-size: clamp(2rem, 3vw, 3.25rem);
    font-weight: 600;
    line-height: 0.96;
    letter-spacing: -0.035em;
    color: #fffdf9;
    text-shadow: 0 6px 22px rgba(28, 17, 11, 0.22);
    text-wrap: balance;
  }

  .bestselling-bedding__description {
    margin: 0;
    max-width: 24ch;
    font-family: var(--font-subheading--family);
    font-style: var(--font-subheading--style);
    font-size: 1.02rem;
    line-height: 1.55;
    color: rgba(255, 248, 241, 0.94);
    text-shadow: 0 4px 16px rgba(28, 17, 11, 0.18);
  }

  .bestselling-bedding__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 2.4rem;
    padding: 0.45rem 0.95rem;
    border: 1px solid rgba(255, 245, 236, 0.22);
    border-radius: 999px;
    background: rgba(255, 247, 239, 0.14);
    backdrop-filter: blur(8px);
    color: #fffaf4;
    font-family: var(--font-subheading--family);
    font-style: var(--font-subheading--style);
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    box-shadow: 0 10px 24px rgba(28, 17, 11, 0.16);
  }

  .bestselling-bedding__products {
    min-width: 0;
  }

  .bestselling-bedding__product-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(0.8rem, 1.2vw, 1rem);
    height: 100%;
  }

  .bestselling-bedding-card {
    position: relative;
    min-width: 0;
  }

  .bestselling-bedding-card__card-link {
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: 22px;
  }

  .bestselling-bedding-card__card {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 0.62rem;
    height: 100%;
    padding: 0.72rem;
    border: 1px solid var(--bb-border);
    border-radius: 22px;
    background: var(--bb-card-surface);
    box-shadow: var(--bb-card-shadow);
    color: inherit;
    text-decoration: none;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .bestselling-bedding-card .quick-add {
    z-index: 5;
    pointer-events: none;
  }

  .bestselling-bedding-card .quick-add__button {
    z-index: 6;
    pointer-events: all;
  }

  .bestselling-bedding-card--placeholder {
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 0.62rem;
    padding: 0.72rem;
    border: 1px solid var(--bb-border);
    border-radius: 22px;
    background: var(--bb-card-surface);
    box-shadow: var(--bb-card-shadow);
  }

  @media (hover: hover) and (pointer: fine) {
    .bestselling-bedding-card:is(:hover, :focus-within) .bestselling-bedding-card__card {
      transform: translateY(-3px);
      border-color: var(--bb-border-strong);
      box-shadow: var(--bb-card-shadow-hover);
    }

    .bestselling-bedding-card:is(:hover, :focus-within) .quick-add__button {
      opacity: 1;
    }

    .bestselling-bedding-card:is(:hover, :focus-within) .bestselling-bedding-card__image--hover {
      opacity: 1;
      transform: scale(1.045);
      filter: saturate(1.015);
    }

    .bestselling-bedding-card:is(:hover, :focus-within) .bestselling-bedding-card__image:not(.bestselling-bedding-card__image--hover),
    .bestselling-bedding-card:is(:hover, :focus-within) .bestselling-bedding-card__placeholder {
      transform: scale(1.03);
      filter: saturate(1.01);
    }
  }

  .bestselling-bedding-card__media {
    --padding-inline-end: 0.35rem;
    --padding-block-end: 0.35rem;
    --border-radius: 18px;

    position: relative;
    overflow: hidden;
    border-radius: 18px;
    aspect-ratio: 1 / 1.02;
    background: linear-gradient(180deg, #f2e4d8 0%, #ead6c3 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.75),
      inset 0 0 0 1px rgba(121, 90, 69, 0.08);
  }

  .bestselling-bedding-card__image,
  .bestselling-bedding-card__placeholder,
  .bestselling-bedding-card__placeholder-svg {
    width: 100%;
    height: 100%;
  }

  .bestselling-bedding-card__image {
    display: block;
    object-fit: cover;
    transition:
      opacity 850ms ease,
      transform 1100ms ease,
      filter 900ms ease;
    transform: scale(1);
  }

  .bestselling-bedding-card__image--hover {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
  }

  .bestselling-bedding-card__placeholder {
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.34) 0%, rgba(255, 255, 255, 0) 24%),
      linear-gradient(180deg, #efdfd0 0%, #dec6b1 100%);
  }

  .bestselling-bedding-card__placeholder-svg {
    display: block;
    opacity: 0.24;
    color: #fffaf4;
  }

  .bestselling-bedding-card__badge {
    position: absolute;
    top: 0.72rem;
    left: 0.72rem;
    display: inline-flex;
    align-items: center;
    min-height: 1.8rem;
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    background: rgba(255, 247, 238, 0.96);
    color: #6a3f26;
    border: 1px solid rgba(122, 74, 45, 0.12);
    font-family: var(--font-subheading--family);
    font-style: var(--font-subheading--style);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    box-shadow: 0 10px 22px rgba(86, 53, 33, 0.14);
  }

  .bestselling-bedding-card__badge--sale {
    background: rgba(154, 79, 43, 0.96);
    color: #fff8f1;
    border-color: transparent;
    box-shadow: 0 10px 22px rgba(108, 55, 29, 0.22);
  }

  .bestselling-bedding-card__content {
    display: grid;
    align-content: start;
    gap: 0.42rem;
    min-width: 0;
  }

  .bestselling-bedding-card__title {
    margin: 0;
    font-family: var(--font-body--family);
    font-style: var(--font-body--style);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.38;
    letter-spacing: -0.01em;
    color: #000000;
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .bestselling-bedding-card__price-row {
    display: flex;
    align-items: baseline;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .bestselling-bedding-card__price {
    font-family: var(--font-body--family);
    font-style: var(--font-body--style);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #c62828;
  }

  .bestselling-bedding-card__compare {
    font-family: var(--font-body--family);
    font-style: var(--font-body--style);
    font-size: 0.85rem;
    color: #a99384;
    text-decoration: line-through;
    text-decoration-thickness: 1px;
  }

  @media screen and (max-width: 1199px) {
    .bestselling-bedding__grid {
      grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.18fr);
      gap: 1rem;
    }

    .bestselling-bedding__visual-frame {
      min-height: clamp(24rem, 38vw, 30rem);
    }

    .bestselling-bedding__copy {
      max-width: min(26rem, 76%);
    }

    .bestselling-bedding-card__card,
    .bestselling-bedding-card--placeholder {
      padding: 0.62rem;
      border-radius: 20px;
    }

    .bestselling-bedding-card__title {
      font-size: 0.94rem;
    }
  }

  @media screen and (max-width: 989px) {
    .bestselling-bedding__shell {
      padding: 0.9rem;
      border-radius: 24px;
    }

    .bestselling-bedding__grid {
      grid-template-columns: 1fr;
    }

    .bestselling-bedding__visual-frame {
      min-height: clamp(15rem, 56vw, 22rem);
    }

    .bestselling-bedding__copy {
      max-width: min(30rem, 84%);
      padding: 1rem;
    }

    .bestselling-bedding__title {
      font-size: clamp(1.85rem, 5vw, 2.5rem);
    }

    .bestselling-bedding__product-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .bestselling-bedding__inner {
      padding-block: 1rem;
    }

    .bestselling-bedding__shell {
      padding: 0.75rem;
      border-radius: 22px;
    }

    .bestselling-bedding__grid {
      gap: 0.85rem;
    }

    .bestselling-bedding__visual-frame {
      min-height: 13.5rem;
      border-radius: 20px;
    }

    .bestselling-bedding__copy {
      gap: 0.5rem;
      max-width: 86%;
      padding: 0.9rem;
    }

    .bestselling-bedding__eyebrow {
      font-size: 0.7rem;
      letter-spacing: 0.15em;
    }

    .bestselling-bedding__title {
      font-size: 1.72rem;
    }

    .bestselling-bedding__description {
      font-size: 0.9rem;
      line-height: 1.46;
    }

    .bestselling-bedding__cta {
      min-height: 2.15rem;
      padding: 0.4rem 0.85rem;
      font-size: 0.82rem;
    }

    .bestselling-bedding__product-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.72rem;
    }

    .bestselling-bedding-card__card,
    .bestselling-bedding-card--placeholder {
      gap: 0.52rem;
      padding: 0.58rem;
      border-radius: 18px;
    }

    .bestselling-bedding-card__media {
      border-radius: 15px;
      aspect-ratio: 1 / 1.08;
    }

    .bestselling-bedding-card__badge {
      top: 0.52rem;
      left: 0.52rem;
      min-height: 1.55rem;
      padding: 0.18rem 0.56rem;
      font-size: 0.62rem;
    }

    .bestselling-bedding-card__title {
      font-size: 0.88rem;
      line-height: 1.4;
    }

    .bestselling-bedding-card__price {
      font-size: 0.94rem;
    }

    .bestselling-bedding-card__compare {
      font-size: 0.78rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Bestselling Bedding",
  "tag": "section",
  "class": "section-bestselling-bedding",
  "enabled_on": {
    "templates": ["index", "page"]
  },
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "image_picker",
      "id": "promo_image",
      "label": "Lifestyle image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "OUR MOST LOVED"
    },
    {
      "type": "text",
