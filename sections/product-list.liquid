

{% liquid
  assign max_items = section.settings.max_products
  assign is_bestselling_bedding = false
  if section.id == 'product_list_EDUBdR' or section.settings.view_all_label == 'Shop all bedding'
    assign is_bestselling_bedding = true
  endif
  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
  endif
%}

<div
  class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
></div>
<div
  data-testid="product-list"
  class="
    section
    section--{{ section.settings.section_width }}
    {% if section.settings.background_color != blank %}color-custom-{{ section.id }}{% endif %}
    section-resource-list
    spacing-style
    gap-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
  "
>
  <div class="section-resource-list__header homepage-reveal{% if is_bestselling_bedding %} product-list__header--bestselling{% endif %}">
    {% if is_bestselling_bedding %}
      <div class="product-list__bestselling-shell">
        <div class="product-list__bestselling-copy">
          <p class="product-list__bestselling-eyebrow">Our Most Loved</p>
          <div class="product-list__bestselling-title-wrap">
            <h2 class="product-list__bestselling-title">
              <span>Bestselling</span>
              <span>Bedding</span>
            </h2>
            <span class="product-list__bestselling-title-rule" aria-hidden="true"></span>
          </div>
          <p class="product-list__bestselling-subtitle">
            Loved for softness, warmth and everyday comfort.
          </p>
        </div>

        <div class="product-list__bestselling-side">
          <div class="product-list__bestselling-features" aria-label="Collection highlights">
            <div class="product-list__bestselling-feature">
              <span class="product-list__bestselling-icon" aria-hidden="true">
                <svg viewBox="0 0 32 32" fill="none">
                  <path d="M10.5 24.5h11.25a6.25 6.25 0 0 0 .37-12.49 8.13 8.13 0 0 0-15.82 2.47A5.13 5.13 0 0 0 10.5 24.5Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <h4>Ultra Soft</h4>
              <p>Premium materials</p>
            </div>

            <div class="product-list__bestselling-feature">
              <span class="product-list__bestselling-icon" aria-hidden="true">
                <svg viewBox="0 0 32 32" fill="none">
                  <path d="M11 4c0 4.5 4 4.5 4 9s-4 4.5-4 9M17 4c0 4.5 4 4.5 4 9s-4 4.5-4 9M23 4c0 4.5 4 4.5 4 9s-4 4.5-4 9" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <h4>Warm &amp; Cozy</h4>
              <p>All season comfort</p>
            </div>

            <div class="product-list__bestselling-feature">
              <span class="product-list__bestselling-icon" aria-hidden="true">
                <svg viewBox="0 0 32 32" fill="none">
                  <path d="M16 27c6-3.5 9-8.5 9-15V6.75L16 4l-9 2.75V12c0 6.5 3 11.5 9 15Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <h4>Made to Last</h4>
              <p>Quality you can trust</p>
            </div>

            <div class="product-list__bestselling-feature">
              <span class="product-list__bestselling-icon" aria-hidden="true">
                <svg viewBox="0 0 32 32" fill="none">
                  <path d="M16 26.25s-8.5-4.92-8.5-11.42A4.82 4.82 0 0 1 16 11.8a4.82 4.82 0 0 1 8.5 3.03c0 6.5-8.5 11.42-8.5 11.42Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <h4>Loved by Many</h4>
              <p>Customer favorites</p>
            </div>
          </div>

          {% if section.settings.show_view_all and section.settings.view_all_label != blank and section.settings.view_all_link != blank %}
            <a
              href="{{ section.settings.view_all_link }}"
              class="product-list__bestselling-cta"
            >
              <span>Shop Collection</span>
            </a>
          {% endif %}
        </div>
      </div>
    {% else %}
      {%- content_for 'block', type: '_product-list-content', id: 'static-header' -%}
    {% endif %}
  </div>

  {% capture list_items %}
    {% if section.settings.collection != blank and shop.products_count != 0 %}
      {% paginate section.settings.collection.products by max_items %}
        {% for product in section.settings.collection.products limit: max_items %}
        <div
          class="resource-list__item homepage-reveal"
          style="--reveal-delay: {{ forloop.index0 | times: 55 }}ms;"
        >
            {% content_for 'block',
              type: '_product-card',
              id: 'static-product-card',
              closest.product: product,
              product_view_context: 'collection'
            %}
          </div>

          {% unless forloop.last %}
            <!--@list/split-->
          {% endunless %}
        {% endfor %}
      {% endpaginate %}
    {% else %}
      {% for i in (1..max_items) %}
        <div
          class="resource-list__item homepage-reveal"
          style="--reveal-delay: {{ forloop.index0 | times: 55 }}ms;"
        >
            {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: null %}
        </div>

        {% unless forloop.last %}
          <!--@list/split-->
        {% endunless %}
      {% endfor %}
    {% endif %}
  {% endcapture %}

  {% liquid
    # Create an array from the list items to be used for different layout types
    assign list_items_array = list_items | strip | split: '<!--@list/split-->'
  %}

  {% render 'resource-list',
    list_items: list_items,
    list_items_array: list_items_array,
    settings: section.settings,
    slide_count: max_items,
    content_type: 'products',
    test_id: 'resource-list-grid'
  %}

  <div
    class="section-resource-list__content homepage-reveal"
    style="--horizontal-alignment: {{ section.settings.horizontal_alignment }};"
  >
    {% if is_bestselling_bedding == false and section.settings.show_view_all and section.settings.view_all_label != blank and section.settings.view_all_link != blank %}
      <div class="product-list__view-all-wrap">
        <a
          href="{{ section.settings.view_all_link }}"
          class="product-list__view-all"
        >
          {{ section.settings.view_all_label | escape }}
        </a>
      </div>
    {% endif %}
    {%- content_for 'blocks' -%}
  </div>
</div>

{% stylesheet %}
  .ui-test-product-list .section-background,
  .ui-test-product-list [data-testid='product-list'] {
    padding-block-start: clamp(4.5rem, 5vw, 5rem);
    padding-block-end: clamp(5rem, 6vw, 5.5rem);
    background: #e7d8c8;
  }

  .ui-test-product-list [data-testid='product-list'] .section-resource-list__header {
    margin-bottom: clamp(1.4rem, 2vw, 1.85rem);
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__header--bestselling {
    position: relative;
    margin-bottom: clamp(2rem, 3vw, 2.8rem);
    padding: clamp(1.2rem, 2.2vw, 1.9rem) clamp(1.25rem, 2.4vw, 2.25rem) clamp(1rem, 2vw, 1.45rem);
    overflow: hidden;
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__header--bestselling::before {
    content: '';
    position: absolute;
    inset: -14% auto -12% -5%;
    width: min(42vw, 34rem);
    border-radius: 999px;
    background:
      radial-gradient(circle at 30% 50%, rgba(255, 252, 247, 0.99) 0%, rgba(251, 244, 234, 0.96) 34%, rgba(245, 233, 217, 0.72) 56%, rgba(236, 220, 201, 0.34) 74%, rgba(231, 216, 200, 0.1) 88%, rgba(231, 216, 200, 0) 100%);
    opacity: 1;
    pointer-events: none;
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-shell {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.18fr);
    gap: clamp(1.8rem, 3.6vw, 4rem);
    align-items: center;
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-copy {
    width: min(100%, 30rem);
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-eyebrow {
    margin: 0 0 1.1rem;
    color: rgb(153 94 62);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    line-height: 1.15;
    text-transform: uppercase;
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-title-wrap {
    margin-bottom: 1.15rem;
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-title {
    margin: 0;
    color: rgb(62 51 45);
    font-family: var(--font-heading--family);
    font-size: clamp(4.05rem, 6.35vw, 5.95rem);
    font-weight: 500;
    letter-spacing: -0.055em;
    line-height: 0.94;
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-title span {
    display: block;
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-title-rule {
    width: 4rem;
    height: 1.5px;
    margin-top: 0.95rem;
    display: block;
    border-radius: 999px;
    background: rgb(187 123 89 / 0.62);
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-subtitle {
    margin: 0;
    max-inline-size: 19.5rem;
    color: rgb(70 55 47);
    font-size: clamp(1.02rem, 1.08vw, 1.16rem);
    font-weight: 430;
    line-height: 1.62;
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-side {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(1.35rem, 2vw, 1.9rem);
    padding-top: 0;
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-features {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-feature {
    min-height: 6.5rem;
    padding: 0 clamp(0.7rem, 1vw, 1rem);
    text-align: center;
    border-left: 1px solid rgba(126, 93, 70, 0.24);
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-feature:first-child {
    border-left: none;
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-icon {
    width: 1.9rem;
    height: 1.9rem;
    margin: 0 auto 0.7rem;
    display: grid;
    place-items: center;
    color: rgb(154 104 73);
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-feature h4 {
    margin: 0 0 0.35rem;
    color: rgb(62 51 45);
    font-size: 0.94rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-feature p {
    margin: 0 auto;
    max-width: 11ch;
    color: rgb(93 77 66);
    font-size: 0.92rem;
    line-height: 1.38;
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-cta {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: rgb(62 51 45);
    font-size: 0.98rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-cta::before {
    content: '\2192';
    order: 2;
    color: rgb(166 107 73);
    font-size: 1.3rem;
    line-height: 1;
  }

  .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-cta::after {
    content: '';
    flex: 1;
    min-width: 6rem;
    height: 1px;
    background: rgba(166, 107, 73, 0.62);
  }

  .ui-test-product-list [data-testid='product-list'] .section-resource-list__header :is(.group-block, .group-block-content) {
    width: min(100%, 38rem);
  }

  .ui-test-product-list [data-testid='product-list'] .section-resource-list__header .text-block.h2 > * {
    color: rgb(62 51 45);
    font-size: clamp(2.25rem, 4vw, 3.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.02;
    text-wrap: balance;
  }

  .ui-test-product-list [data-testid='product-list'] .section-resource-list__header .text-block.h2 {
    position: relative;
    padding-block-end: 0.95rem;
  }

  .ui-test-product-list [data-testid='product-list'] .section-resource-list__header .text-block.h2::after {
    content: '';
    width: clamp(3.1rem, 6vw, 4.25rem);
    height: 2px;
    margin-top: 0.15rem;
    border-radius: 999px;
    background: rgb(180 124 97 / 0.72);
  }

  .ui-test-product-list [data-testid='product-list'] .section-resource-list__header .text-block.rte > * {
    max-inline-size: 34rem;
    color: rgb(96 80 69);
    font-size: clamp(1.05rem, 1.18vw, 1.13rem);
    font-weight: 450;
    line-height: 1.62;
  }

  .ui-test-product-list [data-testid='resource-list-grid'] {
    --resource-list-column-gap-desktop: clamp(1rem, 1.6vw, 1.3rem);
    --resource-list-row-gap-desktop: clamp(1.2rem, 2vw, 1.55rem);
  }

  .ui-test-product-list [data-testid='resource-list-grid'] .resource-list__item {
    min-width: 0;
    display: grid;
  }

  @media screen and (min-width: 990px) {
    .ui-test-product-list [data-testid='resource-list-grid']:has(.resource-list__item:first-child:nth-last-child(1)) {
      grid-template-columns: minmax(0, min(100%, 21rem));
      justify-content: center;
    }

    .ui-test-product-list [data-testid='resource-list-grid']:has(.resource-list__item:first-child:nth-last-child(2)) {
      grid-template-columns: repeat(2, minmax(0, min(100%, 21rem)));
      justify-content: center;
    }

    .ui-test-product-list [data-testid='resource-list-grid']:has(.resource-list__item:first-child:nth-last-child(3)) {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .ui-test-product-list [data-testid='product-list'] .product-card {
    height: 100%;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card__content {
    border: 1px solid rgba(62, 51, 45, 0.12);
    border-radius: 16px;
    background: #faf8f5;
    box-shadow: 0 18px 42px rgba(62, 51, 45, 0.10);
    transition:
      border-color var(--animation-speed-medium) var(--animation-timing-fade-in),
      box-shadow var(--animation-speed-medium) var(--animation-timing-fade-in),
      transform var(--animation-speed-medium) var(--animation-timing-fade-in);
  }

  .ui-test-product-list [data-testid='product-list'] .card-gallery {
    position: relative;
    overflow: hidden;
    background: #faf8f5;
    border-bottom: 1px solid rgba(62, 51, 45, 0.10);
    transform: none !important;
  }

  .ui-test-product-list [data-testid='product-list'] .card-gallery slideshow-component,
  .ui-test-product-list [data-testid='product-list'] .card-gallery .contents {
    position: relative;
    z-index: 1;
  }

  .ui-test-product-list [data-testid='product-list'] .card-gallery :is(img, .placeholder-svg, .resource-image__image) {
    transition:
      opacity 850ms ease,
      transform 1100ms ease,
      filter 900ms ease;
    transform: scale(1);
  }

  .card-hover-effect-subtle-zoom .ui-test-product-list [data-testid='product-list'] .product-card:hover .card-gallery {
    transform: none !important;
  }

  .ui-test-product-list [data-testid='product-list'] .card-gallery__fade-hover-media {
    position: absolute;
    inset: 0;
    z-index: 2;
    opacity: 0;
    pointer-events: none;
    overflow: hidden;
    transition: opacity 850ms ease;
  }

  .ui-test-product-list [data-testid='product-list'] .card-gallery__fade-hover-media :is(img, .resource-image__image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1);
    transition:
      transform 1300ms ease,
      filter 900ms ease;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card__content .group-block {
    min-width: 0;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card a.contents {
    color: inherit;
    text-decoration: none;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card .text-block p[role='heading'] {
    min-height: calc(1.42em * 2);
    color: rgb(62 51 45);
    font-family: var(--font-heading--family);
    font-size: clamp(1.02rem, 1.08vw, 1.13rem);
    font-weight: 500;
    letter-spacing: 0.05em;
    line-height: 1.3;
    text-wrap: pretty;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card-meta-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.45rem;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card-meta-tag {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    border-radius: 999px;
    padding: 0.22rem 0.55rem;
    background: rgba(180, 124, 97, 0.12);
    color: rgb(104, 73, 56);
    font-size: 0.72rem;
    font-weight: 650;
    line-height: 1.2;
    letter-spacing: 0.04em;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card-meta-tag--best {
    background: rgba(62, 51, 45, 0.12);
    color: rgb(62, 51, 45);
  }

  .ui-test-product-list [data-testid='product-list'] .product-card-meta-tag--new {
    background: rgba(153, 94, 62, 0.13);
    color: rgb(153, 94, 62);
  }

  .ui-test-product-list [data-testid='product-list'] .product-card product-price {
    color: rgb(82 67 58);
  }

  .ui-test-product-list [data-testid='product-list'] .product-card product-price > div {
    display: grid;
    gap: 0.2rem;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card .price__regular,
  .ui-test-product-list [data-testid='product-list'] .product-card .price__sale {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem 0.6rem;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card .price__regular {
    display: none;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card .price {
    color: rgb(82 67 58);
    font-family: var(--font-heading--family);
    font-size: 1.06rem;
    font-weight: 520;
    letter-spacing: -0.01em;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card .price-item--sale {
    color: rgb(180 124 97);
    font-family: var(--font-heading--family);
    font-size: 1.08rem;
    font-weight: 560;
    letter-spacing: -0.01em;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card .compare-at-price {
    font-size: 0.92rem;
    color: rgb(137 121 110);
    text-decoration-thickness: 1px;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card product-swatches {
    margin-top: 0.1rem;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card .product-badges__badge.color-custom-badge-sale {
    background: rgb(180 124 97);
    color: #fff8ef;
    box-shadow: 0 8px 18px rgb(180 124 97 / 0.22);
  }

  .ui-test-product-list [data-testid='product-list'] .product-card .product-badges__badge.color-custom-badge-sold-out {
    background: rgb(89 75 66);
    color: #fff8ef;
  }

  @media (hover: hover) and (pointer: fine) {
    .ui-test-product-list [data-testid='product-list'] .product-card:hover .product-card__content {
      transform: none;
      border-color: rgba(62, 51, 45, 0.18);
      box-shadow:
        0 1px 0 rgba(255, 255, 255, 0.72) inset,
        0 20px 46px rgba(62, 51, 45, 0.14);
    }

    .ui-test-product-list [data-testid='product-list'] .product-card:hover .card-gallery {
      transform: none !important;
    }

    .ui-test-product-list [data-testid='product-list'] .product-card:hover .card-gallery slideshow-component {
      opacity: 0;
      transition: opacity 850ms ease;
    }

    .ui-test-product-list [data-testid='product-list'] .product-card:hover .card-gallery__fade-hover-media {
      opacity: 1;
    }

    .ui-test-product-list [data-testid='product-list'] .product-card:hover .card-gallery__fade-hover-media :is(img, .resource-image__image) {
      transform: scale(1.045);
      filter: saturate(1.015);
    }
  }

  .product-list__view-all-wrap {
    display: flex;
    justify-content: center;
    margin-top: clamp(1.9rem, 4vw, 2.35rem);
  }

  .product-list__view-all {
    min-height: max(44px, var(--minimum-touch-target));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    padding: 0.45rem 0.2rem;
    color: rgb(117 101 90);
    font-size: clamp(1rem, 1.04vw, 1.05rem);
    font-weight: 600;
    line-height: 1.35;
    text-decoration: none;
    box-shadow: inset 0 -1px 0 rgb(180 124 97 / 0.55);
    transition:
      color var(--animation-speed-fast) var(--animation-easing),
      box-shadow var(--animation-speed-fast) var(--animation-easing),
      gap var(--animation-speed-fast) var(--animation-easing);
  }

  .product-list__view-all::after {
    content: '\2192';
    font-size: 0.92em;
    line-height: 1;
    opacity: 0.78;
    transition:
      opacity var(--animation-speed-fast) var(--animation-easing),
      transform var(--animation-speed-fast) var(--animation-easing);
  }

  .product-list__view-all:hover {
    color: rgb(104 73 56);
    box-shadow: inset 0 -1px 0 rgb(180 124 97 / 0.82);
    gap: 0.6rem;
  }

  .product-list__view-all:hover::after {
    opacity: 1;
    transform: translateX(2px);
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .ui-test-product-list [data-testid='resource-list-grid'] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-shell {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-copy {
      width: min(100%, 32rem);
    }

    .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-features {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem 0;
    }

    .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-feature:nth-child(3) {
      border-left: none;
    }
  }

  @media screen and (max-width: 749px) {
    .ui-test-product-list [data-testid='product-list'] {
      padding-block-start: clamp(3rem, 8vw, 3.5rem);
      padding-block-end: clamp(3.5rem, 9vw, 4rem);
    }

    .ui-test-product-list [data-testid='product-list'] .section-resource-list__header {
      margin-bottom: 1.2rem;
    }

    .ui-test-product-list [data-testid='product-list'] .product-list__header--bestselling {
      padding: 1.25rem 1rem 1rem;
    }

    .ui-test-product-list [data-testid='product-list'] .product-list__header--bestselling::before {
      inset: -4rem auto auto -7rem;
      width: 18rem;
      height: 18rem;
    }

    .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-shell {
      grid-template-columns: 1fr;
      gap: 1.8rem;
    }

    .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-copy {
      width: 100%;
    }

    .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-eyebrow {
      margin-bottom: 0.9rem;
      font-size: 0.76rem;
      letter-spacing: 0.16em;
    }

    .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-title {
      font-size: clamp(3.4rem, 14vw, 4.8rem);
      line-height: 0.88;
    }

    .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-title-rule {
      margin-top: 0.8rem;
    }

    .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-subtitle {
      max-inline-size: 14rem;
      font-size: 1.02rem;
    }

    .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-side {
      gap: 1.4rem;
      padding-top: 0;
    }

    .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-features {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem 0;
    }

    .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-feature {
      padding: 0 0.85rem;
    }

    .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-feature:nth-child(3) {
      border-left: none;
    }

    .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-feature h4 {
      font-size: 0.88rem;
    }

    .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-feature p {
      font-size: 0.95rem;
    }

    .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-cta {
      gap: 0.8rem;
      font-size: 1rem;
    }

    .ui-test-product-list [data-testid='product-list'] .product-list__bestselling-cta::after {
      min-width: 3rem;
    }

    .ui-test-product-list [data-testid='product-list'] .product-card .text-block p[role='heading'] {
      min-height: calc(1.38em * 2);
      font-size: 0.98rem;
      line-height: 1.35;
    }

    .ui-test-product-list [data-testid='product-list'] .product-card .price,
    .ui-test-product-list [data-testid='product-list'] .product-card .price-item--sale {
      font-size: 0.96rem;
    }

    .ui-test-product-list [data-testid='product-list'] .product-card .compare-at-price {
      font-size: 0.88rem;
    }

    .product-list__view-all-wrap {
      margin-top: clamp(1.5rem, 6vw, 2rem);
    }

    .ui-test-product-list [data-testid='product-list'] .section-resource-list__header .text-block.h2 > * {
      font-size: clamp(2.32rem, 8vw, 3rem);
      line-height: 1.03;
    }

    .product-list__view-all {
      font-size: 1rem;
    }
  }
