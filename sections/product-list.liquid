

{% liquid
  assign max_items = section.settings.max_products
  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
  endif
%}

<div
  class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
></div>
<div
  data-testid="product-list"
  class="
    section
    section--{{ section.settings.section_width }}
    {% if section.settings.background_color != blank %}color-custom-{{ section.id }}{% endif %}
    section-resource-list
    spacing-style
    gap-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
  "
>
  <div class="section-resource-list__header homepage-reveal">
    {%- content_for 'block', type: '_product-list-content', id: 'static-header' -%}
  </div>

  {% capture list_items %}
    {% if section.settings.collection != blank and shop.products_count != 0 %}
      {% paginate section.settings.collection.products by max_items %}
        {% for product in section.settings.collection.products limit: max_items %}
        <div
          class="resource-list__item homepage-reveal"
          style="--reveal-delay: {{ forloop.index0 | times: 55 }}ms;"
        >
            {% content_for 'block',
              type: '_product-card',
              id: 'static-product-card',
              closest.product: product,
              product_view_context: 'collection'
            %}
          </div>

          {% unless forloop.last %}
            <!--@list/split-->
          {% endunless %}
        {% endfor %}
      {% endpaginate %}
    {% else %}
      {% for i in (1..max_items) %}
        <div
          class="resource-list__item homepage-reveal"
          style="--reveal-delay: {{ forloop.index0 | times: 55 }}ms;"
        >
            {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: null %}
        </div>

        {% unless forloop.last %}
          <!--@list/split-->
        {% endunless %}
      {% endfor %}
    {% endif %}
  {% endcapture %}

  {% liquid
    # Create an array from the list items to be used for different layout types
    assign list_items_array = list_items | strip | split: '<!--@list/split-->'
  %}

  {% render 'resource-list',
    list_items: list_items,
    list_items_array: list_items_array,
    settings: section.settings,
    slide_count: max_items,
    content_type: 'products',
    test_id: 'resource-list-grid'
  %}

  <div
    class="section-resource-list__content homepage-reveal"
    style="--horizontal-alignment: {{ section.settings.horizontal_alignment }};"
  >
    {% if section.settings.show_view_all and section.settings.view_all_label != blank and section.settings.view_all_link != blank %}
      <div class="product-list__view-all-wrap">
        <a
          href="{{ section.settings.view_all_link }}"
          class="product-list__view-all"
        >
          {{ section.settings.view_all_label | escape }}
        </a>
      </div>
    {% endif %}
    {%- content_for 'blocks' -%}
  </div>
</div>

{% stylesheet %}
  .ui-test-product-list [data-testid='product-list'] {
    padding-block-start: clamp(4.5rem, 5vw, 5rem);
    padding-block-end: clamp(5rem, 6vw, 5.5rem);
  }

  .ui-test-product-list [data-testid='product-list'] .section-resource-list__header {
    margin-bottom: clamp(1.4rem, 2vw, 1.85rem);
  }

  .ui-test-product-list [data-testid='product-list'] .section-resource-list__header :is(.group-block, .group-block-content) {
    width: min(100%, 38rem);
  }

  .ui-test-product-list [data-testid='product-list'] .section-resource-list__header .text-block.h2 > * {
    color: rgb(62 51 45);
    font-size: clamp(2.25rem, 4vw, 3.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.02;
    text-wrap: balance;
  }

  .ui-test-product-list [data-testid='product-list'] .section-resource-list__header .text-block.h2 {
    position: relative;
    padding-block-end: 0.95rem;
  }

  .ui-test-product-list [data-testid='product-list'] .section-resource-list__header .text-block.h2::after {
    content: '';
    width: clamp(3.1rem, 6vw, 4.25rem);
    height: 2px;
    margin-top: 0.15rem;
    border-radius: 999px;
    background: rgb(180 124 97 / 0.72);
  }

  .ui-test-product-list [data-testid='product-list'] .section-resource-list__header .text-block.rte > * {
    max-inline-size: 34rem;
    color: rgb(96 80 69);
    font-size: clamp(1.05rem, 1.18vw, 1.13rem);
    font-weight: 450;
    line-height: 1.62;
  }

  .ui-test-product-list [data-testid='resource-list-grid'] {
    --resource-list-column-gap-desktop: clamp(1rem, 1.6vw, 1.3rem);
    --resource-list-row-gap-desktop: clamp(1.2rem, 2vw, 1.55rem);
  }

  .ui-test-product-list [data-testid='resource-list-grid'] .resource-list__item {
    min-width: 0;
    display: grid;
  }

  @media screen and (min-width: 990px) {
    .ui-test-product-list [data-testid='resource-list-grid']:has(.resource-list__item:first-child:nth-last-child(1)) {
      grid-template-columns: minmax(0, min(100%, 21rem));
      justify-content: center;
    }

    .ui-test-product-list [data-testid='resource-list-grid']:has(.resource-list__item:first-child:nth-last-child(2)) {
      grid-template-columns: repeat(2, minmax(0, min(100%, 21rem)));
      justify-content: center;
    }

    .ui-test-product-list [data-testid='resource-list-grid']:has(.resource-list__item:first-child:nth-last-child(3)) {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .ui-test-product-list [data-testid='product-list'] .product-card {
    height: 100%;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card__content {
    border-color: rgb(226 217 207 / 0.92);
    border-radius: 16px;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.96) 0%, rgb(250 248 245 / 0.98) 100%);
    box-shadow:
      0 1px 0 rgb(255 255 255 / 0.86) inset,
      0 16px 32px rgb(62 51 45 / 0.06);
    transition:
      border-color var(--animation-speed-medium) var(--animation-timing-fade-in),
      box-shadow var(--animation-speed-medium) var(--animation-timing-fade-in),
      transform var(--animation-speed-medium) var(--animation-timing-fade-in);
  }

  .ui-test-product-list [data-testid='product-list'] .card-gallery {
    overflow: hidden;
    background: rgb(244 239 233);
    border-bottom: 1px solid rgb(226 217 207 / 0.72);
  }

  .ui-test-product-list [data-testid='product-list'] .card-gallery :is(img, .placeholder-svg, .resource-image__image) {
    transition:
      transform var(--animation-speed-medium) var(--animation-timing-fade-in),
      filter var(--animation-speed-medium) var(--animation-timing-fade-in);
  }

  .ui-test-product-list [data-testid='product-list'] .product-card__content .group-block {
    min-width: 0;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card a.contents {
    color: inherit;
    text-decoration: none;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card .text-block p[role='heading'] {
    min-height: calc(1.42em * 2);
    color: rgb(62 51 45);
    font-size: clamp(1.02rem, 1.08vw, 1.13rem);
    font-weight: 650;
    line-height: 1.38;
    text-wrap: pretty;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card product-price {
    color: rgb(82 67 58);
  }

  .ui-test-product-list [data-testid='product-list'] .product-card product-price > div {
    display: grid;
    gap: 0.2rem;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card .price__regular,
  .ui-test-product-list [data-testid='product-list'] .product-card .price__sale {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem 0.6rem;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card .price {
    color: rgb(82 67 58);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card .price-item--sale {
    color: rgb(180 124 97);
    font-size: 1.04rem;
    font-weight: 700;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card .compare-at-price {
    font-size: 0.92rem;
    color: rgb(137 121 110);
    text-decoration-thickness: 1px;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card product-swatches {
    margin-top: 0.1rem;
  }

  .ui-test-product-list [data-testid='product-list'] .product-card .product-badges__badge.color-custom-badge-sale {
    background: rgb(180 124 97);
    color: #fff8ef;
    box-shadow: 0 8px 18px rgb(180 124 97 / 0.22);
  }

  .ui-test-product-list [data-testid='product-list'] .product-card .product-badges__badge.color-custom-badge-sold-out {
    background: rgb(89 75 66);
    color: #fff8ef;
  }

  @media (hover: hover) and (pointer: fine) {
    .ui-test-product-list [data-testid='product-list'] .product-card:hover .product-card__content {
      transform: translateY(-4px);
      border-color: rgb(180 154 132 / 0.48);
      box-shadow:
        0 1px 0 rgb(255 255 255 / 0.88) inset,
        0 22px 42px rgb(62 51 45 / 0.1);
    }

    .ui-test-product-list [data-testid='product-list'] .product-card:hover .card-gallery :is(img, .placeholder-svg, .resource-image__image) {
      transform: scale(1.025);
      filter: saturate(1.02);
    }
  }

  .product-list__view-all-wrap {
    display: flex;
    justify-content: center;
    margin-top: clamp(1.9rem, 4vw, 2.35rem);
  }

  .product-list__view-all {
    min-height: max(44px, var(--minimum-touch-target));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    padding: 0.45rem 0.2rem;
    color: rgb(117 101 90);
    font-size: clamp(1rem, 1.04vw, 1.05rem);
    font-weight: 600;
    line-height: 1.35;
    text-decoration: none;
    box-shadow: inset 0 -1px 0 rgb(180 124 97 / 0.55);
    transition:
      color var(--animation-speed-fast) var(--animation-easing),
      box-shadow var(--animation-speed-fast) var(--animation-easing),
      gap var(--animation-speed-fast) var(--animation-easing);
  }

  .product-list__view-all::after {
    content: '\2192';
    font-size: 0.92em;
    line-height: 1;
    opacity: 0.78;
    transition:
      opacity var(--animation-speed-fast) var(--animation-easing),
      transform var(--animation-speed-fast) var(--animation-easing);
  }

  .product-list__view-all:hover {
    color: rgb(104 73 56);
    box-shadow: inset 0 -1px 0 rgb(180 124 97 / 0.82);
    gap: 0.6rem;
  }

  .product-list__view-all:hover::after {
    opacity: 1;
    transform: translateX(2px);
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .ui-test-product-list [data-testid='resource-list-grid'] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .ui-test-product-list [data-testid='product-list'] {
      padding-block-start: clamp(3rem, 8vw, 3.5rem);
      padding-block-end: clamp(3.5rem, 9vw, 4rem);
    }

    .ui-test-product-list [data-testid='product-list'] .section-resource-list__header {
      margin-bottom: 1.2rem;
    }

    .ui-test-product-list [data-testid='product-list'] .product-card .text-block p[role='heading'] {
      min-height: calc(1.38em * 2);
      font-size: 0.98rem;
      line-height: 1.35;
    }

    .ui-test-product-list [data-testid='product-list'] .product-card .price,
    .ui-test-product-list [data-testid='product-list'] .product-card .price-item--sale {
      font-size: 0.96rem;
    }

    .ui-test-product-list [data-testid='product-list'] .product-card .compare-at-price {
      font-size: 0.88rem;
    }

    .product-list__view-all-wrap {
      margin-top: clamp(1.5rem, 6vw, 2rem);
    }

    .ui-test-product-list [data-testid='product-list'] .section-resource-list__header .text-block.h2 > * {
      font-size: clamp(2.32rem, 8vw, 3rem);
      line-height: 1.03;
    }

    .product-list__view-all {
      font-size: 1rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.product_list",
  "class": "ui-test-product-list",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "_divider"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "t:settings.collection"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:settings.layout_type",
      "options": [
        {
          "value": "grid",
          "label": "t:options.grid"
        },
        {
          "value": "carousel",
          "label": "t:options.carousel"
        },
        {
          "value": "editorial",
          "label": "t:options.editorial"
        }
      ],
      "default": "grid"
    },
    {
      "type": "checkbox",
      "id": "carousel_on_mobile",
      "label": "t:settings.carousel_on_mobile",
      "default": false,
      "visible_if": "{{ section.settings.layout_type != 'carousel' }}"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "t:settings.product_count",
      "min": 1,
      "max": 16,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:settings.columns",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 4,
      "visible_if": "{{ section.settings.layout_type != 'editorial' }}"
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "t:settings.mobile_columns",
      "options": [
        {
          "value": "1",
          "label": "t:options.one_number"
        },
        {
          "value": "2",
          "label": "t:options.two_number"
        }
      ],
      "default": "2",
      "visible_if": "{{ section.settings.layout_type == 'grid' and section.settings.carousel_on_mobile == false }}"
    },
    {
      "type": "select",
      "id": "mobile_card_size",
      "label": "t:settings.mobile_columns",
      "options": [
        {
          "value": "60cqw",
          "label": "t:options.one_number"
        },
        {
          "value": "44cqw",
          "label": "t:options.two_number"
        }
      ],
      "default": "60cqw",
      "visible_if": "{{ section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "range",
      "id": "columns_gap",
      "label": "t:settings.horizontal_gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ section.settings.layout_type == 'grid' or section.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "range",
      "id": "rows_gap",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ section.settings.layout_type == 'grid'}}"
    },
    {
      "type": "header",
      "content": "t:content.carousel_navigation",
      "visible_if": "{{ section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "select",
      "id": "icons_style",
      "label": "t:settings.icon",
      "options": [
        {
          "value": "arrow",
          "label": "t:options.arrows"
        },
        {
          "value": "chevron",
          "label": "t:options.chevrons"
        },
        {
          "value": "arrows_large",
          "label": "t:options.arrows_large"
        },
        {
          "value": "chevron_large",
          "label": "t:options.chevron_large"
        },
        {
          "value": "none",
          "label": "t:options.none"
        }
      ],
      "default": "arrow",
      "visible_if": "{{ section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "select",
      "id": "icons_shape",
      "label": "t:settings.icon_background",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "circle",
          "label": "t:options.circle"
        },
        {
          "value": "square",
          "label": "t:options.square"
        }
      ],
      "default": "none",
      "visible_if": "{{ section.settings.icons_style != 'none' and section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "header",
      "content": "t:content.section_layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.right"
        }
      ],
      "default": "flex-start"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "header",
      "content": "View all CTA"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all CTA",
      "default": false
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "CTA label",
      "default": "Shop all bedding",
      "visible_if": "{{ section.settings.show_view_all }}"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "CTA link",
      "visible_if": "{{ section.settings.show_view_all }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.products_grid",
      "category": "t:categories.products",
      "settings": {
        "collection": "",
        "max_products": 8,
        "layout_type": "grid",
        "carousel_on_mobile": false,
        "columns": 4,
        "mobile_columns": "2",
        "columns_gap": 8,
        "rows_gap": 24,
        "icons_style": "arrow",
        "icons_shape": "none",
        "section_width": "page-width",
        "gap": 28,
        "padding-block-start": 48,
        "padding-block-end": 48
      },
      "blocks": {
        "static-header": {
          "type": "_product-list-content",
          "name": "t:names.header",
          "static": true,
          "settings": {
            "content_direction": "row",
            "vertical_on_mobile": false,
            "horizontal_alignment": "space-between",
            "vertical_alignment": "flex-end",
            "align_baseline": true,
            "horizontal_alignment_flex_direction_column": "flex-start",
            "vertical_alignment_flex_direction_column": "center",
            "gap": 12,
            "width": "fill",
            "custom_width": 100,
            "width_mobile": "fill",
            "custom_width_mobile": 100,
            "height": "fit",
            "custom_height": 100,
            "background_media": "none",
            "video_position": "cover",
            "background_image_position": "cover",
            "border": "none",
            "border_width": 1,
            "border_opacity": 100,
            "border_radius": 0,
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "product_list_text": {
              "type": "_product-list-text",
              "name": "t:names.collection_title",
              "settings": {
                "text": "<h3>{{ closest.collection.title }}</h3>",
                "type_preset": "rte",
                "font": "var(--font-body--family)",
                "font_size": "",
                "line_height": "normal",
                "letter_spacing": "normal",
                "case": "none",
                "wrap": "pretty",
                "width": "fit-content",
                "max_width": "normal",
                "alignment": "left",
                "padding-block-start": 0,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              }
            },
            "product_list_button": {
              "type": "_product-list-button",
              "name": "t:names.product_list_button",
              "settings": {
                "label": "t:text_defaults.view_all_button_label",
                "open_in_new_tab": false,
                "style_class": "button-unstyled",
                "width": "fit-content",
                "custom_width": 100,
                "width_mobile": "fit-content",
                "custom_width_mobile": 100
              }
            }
          },
          "block_order": ["product_list_text", "product_list_button"]
        },
        "static-product-card": {
          "type": "_product-card",
          "name": "t:names.product_card",
          "static": true,
          "settings": {
            "product_card_gap": 4,
            "border": "none",
            "border_width": 1,
            "border_opacity": 100,
