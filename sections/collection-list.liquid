

{% liquid
  assign is_patchwork_layout = false
  assign has_selected_collections = false

  if section.settings.discovery_layout == 'patchwork'
    assign is_patchwork_layout = true
  endif

  if section.settings.collection_list != blank
    assign has_selected_collections = true
    assign section_collections = section.settings.collection_list
    assign max_items = section.settings.collection_list.count
    if is_patchwork_layout and max_items > 5
      assign max_items = 5
    endif
    if section.settings.max_collections > 0 and max_items > section.settings.max_collections
      assign max_items = section.settings.max_collections
    endif
  elsif section.settings.layout_type == 'editorial'
    assign max_items = section.settings.max_collections
  elsif section.settings.layout_type == 'bento'
    assign max_items = 4
  elsif section.settings.layout_type == 'carousel'
    assign max_items = section.settings.columns | plus: 2
  elsif section.settings.layout_type == 'grid'
    assign max_items = section.settings.columns
  endif

  if is_patchwork_layout
    assign max_items = 5
  endif
%}

{% liquid
  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
  endif

  assign comfort_chips = section.settings.comfort_chips | default: '' | split: ','
  assign patchwork_heading = section.settings.patchwork_heading | strip
  assign patchwork_subheading = section.settings.patchwork_subheading | strip
  assign patchwork_count = 0
  assign intro_collection = blank
  assign intro_image = blank
  assign intro_title = 'Collection coming soon'
  assign intro_alt = ''
  assign right_tile_limit = max_items | minus: 1

  if has_selected_collections
    for collection in section_collections limit: 1
      assign intro_collection = collection
    endfor
  endif

  if has_selected_collections
    for collection in section_collections offset: 1 limit: right_tile_limit
      if collection != blank
        assign patchwork_count = patchwork_count | plus: 1
      endif
    endfor
  endif

  if intro_collection != blank
    assign intro_title = intro_collection.title
    assign intro_image = intro_collection.image
    if intro_image == blank and intro_collection.products.first.featured_image != blank
      assign intro_image = intro_collection.products.first.featured_image
    endif
    if intro_image != blank and intro_image.alt != blank
      assign intro_alt = intro_image.alt
    else
      assign intro_alt = intro_title
    endif
  endif

  if is_patchwork_layout and patchwork_count == 0
    assign patchwork_count = 4
  endif
%}

<div
  class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
></div>

<div
  class="
    section
    section--{{ section.settings.section_width }}
    {% if section.settings.background_color != blank %}color-custom-{{ section.id }}{% endif %}
    section-resource-list
    {% if is_patchwork_layout %} section-resource-list--patchwork{% endif %}
    spacing-style
    gap-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
  "
  data-testid="collection-list"
  data-collection-layout="{% if is_patchwork_layout %}patchwork{% else %}default{% endif %}"
  data-patchwork-interaction="{% if section.settings.enable_patchwork_interaction %}true{% else %}false{% endif %}"
  {% if is_patchwork_layout and section.settings.enable_patchwork_interaction %}
    data-collection-discovery
    data-active-chip="1"
  {% endif %}
>
  {% if section_collections == null %}
    {% for i in (1..max_items) %}
      {% assign section_collections = section_collections | append: ', ' %}
    {% endfor %}

    {% assign section_collections = section_collections | split: ',' %}
  {% endif %}

  {% if is_patchwork_layout %}
    <div class="collection-patchwork collection-patchwork--count-{{ patchwork_count }}">
      {% if intro_collection != blank %}
        <a
          href="{{ intro_collection.url }}"
          class="section-resource-list__content collection-patchwork__editorial collection-patchwork__intro-tile{% if section.settings.enable_patchwork_motion %} homepage-reveal{% endif %}"
          data-reveal-preset="section-soft-reveal"
        >
      {% else %}
        <div
          class="section-resource-list__content collection-patchwork__editorial collection-patchwork__intro-tile collection-patchwork__intro-tile--placeholder{% if section.settings.enable_patchwork_motion %} homepage-reveal{% endif %}"
          data-reveal-preset="section-soft-reveal"
        >
      {% endif %}
          <div class="collection-patchwork__media">
            {% if intro_image != blank %}
              {{
                intro_image
                | image_url: width: 2400
                | image_tag:
                  widths: '600, 800, 1200, 1600, 2000, 2400',
                  sizes: '(min-width: 990px) 34vw, (min-width: 750px) 50vw, 100vw',
                  loading: 'lazy',
                  class: 'collection-patchwork__intro-image collection-patchwork__image',
                  alt: intro_alt
              }}
            {% else %}
              {{ 'collection-apparel-1' | placeholder_svg_tag: 'collection-patchwork__intro-image collection-patchwork__image collection-patchwork__image--placeholder' }}
            {% endif %}
          </div>

          <div class="collection-patchwork__content">
            <h3 class="collection-patchwork__title">{{ intro_title | escape }}</h3>
          </div>
      {% if intro_collection != blank %}
        </a>
      {% else %}
        </div>
      {% endif %}

      {% for collection in section_collections offset: 1 limit: right_tile_limit %}
        {% liquid
          assign reveal_rotation = '-0.9deg'
          assign reveal_modulo = forloop.index0 | modulo: 4
          assign tile_image = blank
          assign tile_sizes = '(min-width: 990px) 28vw, (min-width: 750px) 50vw, 100vw'
          assign tile_title = 'Collection coming soon'
          assign tile_alt = ''
          assign placeholder_variant = forloop.index0 | modulo: 4 | plus: 1
          assign placeholder_name = 'collection-apparel-' | append: placeholder_variant

          case reveal_modulo
            when 1
              assign reveal_rotation = '0.85deg'
            when 2
              assign reveal_rotation = '-0.65deg'
            when 3
              assign reveal_rotation = '1deg'
          endcase

          if patchwork_count == 1
            assign tile_sizes = '(min-width: 990px) 50vw, (min-width: 750px) 50vw, 100vw'
          elsif forloop.index == 1
            assign tile_sizes = '(min-width: 990px) 34vw, (min-width: 750px) 50vw, 100vw'
          elsif patchwork_count == 4 and forloop.index == 2
            assign tile_sizes = '(min-width: 990px) 20vw, (min-width: 750px) 50vw, 100vw'
          elsif patchwork_count == 4
            assign tile_sizes = '(min-width: 990px) 16vw, (min-width: 750px) 50vw, 100vw'
          elsif patchwork_count == 3
            assign tile_sizes = '(min-width: 990px) 24vw, (min-width: 750px) 50vw, 100vw'
          endif

          if collection != blank
            assign tile_title = collection.title
            assign tile_image = collection.image
            if tile_image == blank and collection.products.first.featured_image != blank
              assign tile_image = collection.products.first.featured_image
            endif
            if tile_image != blank and tile_image.alt != blank
              assign tile_alt = tile_image.alt
            else
              assign tile_alt = collection.title
            endif
          endif
        %}

        {% capture patchwork_tile_inner %}
          <div class="collection-patchwork__media">
            {% if tile_image != blank %}
              {{
                tile_image
                | image_url: width: 2400
                | image_tag:
                  widths: '400, 600, 800, 1200, 1600, 2000, 2400',
                  sizes: tile_sizes,
                  loading: 'lazy',
                  class: 'collection-patchwork__image',
                  alt: tile_alt
              }}
            {% else %}
              {{ placeholder_name | placeholder_svg_tag: 'collection-patchwork__image collection-patchwork__image--placeholder' }}
            {% endif %}
          </div>
          <div class="collection-patchwork__content">
            <h3 class="collection-patchwork__title">{{ tile_title | escape }}</h3>
          </div>
        {% endcapture %}

        {% if collection != blank %}
          <a
            href="{{ collection.url }}"
            class="collection-patchwork__tile collection-patchwork__tile--{{ forloop.index }}{% if section.settings.enable_patchwork_motion %} homepage-reveal{% endif %}"
            data-reveal-preset="card-cascade-reveal"
            style="--reveal-delay: {{ forloop.index | times: 110 }}ms; --collection-card-reveal-rotate: {{ reveal_rotation }};"
            data-patchwork-tile
            data-patchwork-index="{{ forloop.index }}"
          >
            {{ patchwork_tile_inner }}
          </a>
        {% else %}
          <div
            class="collection-patchwork__tile collection-patchwork__tile--{{ forloop.index }} collection-patchwork__tile--placeholder{% if section.settings.enable_patchwork_motion %} homepage-reveal{% endif %}"
            data-reveal-preset="card-cascade-reveal"
            style="--reveal-delay: {{ forloop.index | times: 110 }}ms; --collection-card-reveal-rotate: {{ reveal_rotation }};"
            data-patchwork-index="{{ forloop.index }}"
          >
            {{ patchwork_tile_inner }}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% else %}
    <div
      class="section-resource-list__content homepage-reveal"
      data-reveal-preset="section-soft-reveal"
    >
      {% if section.settings.eyebrow_text != blank %}
        <p class="collection-list__eyebrow">
          {{ section.settings.eyebrow_text | escape }}
        </p>
      {% endif %}

      {%- content_for 'blocks' -%}

      {% if section.settings.show_comfort_chips and section.settings.comfort_chips != blank %}
        <div class="collection-list__chips" aria-label="Collection highlights">
          {% for chip in comfort_chips %}
            {% assign chip_label = chip | strip %}
            {% if chip_label != blank %}
              <span class="collection-list__chip collection-list__chip--static">
                <span class="collection-list__chip-label">{{ chip_label | escape }}</span>
              </span>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>

    {% capture list_items %}
      {% for collection in section_collections limit: max_items %}
        {% assign reveal_rotation = '-0.9deg' %}
        {% assign reveal_modulo = forloop.index0 | modulo: 4 %}
        {% case reveal_modulo %}
          {% when 1 %}
            {% assign reveal_rotation = '0.85deg' %}
          {% when 2 %}
            {% assign reveal_rotation = '-0.65deg' %}
          {% when 3 %}
            {% assign reveal_rotation = '1deg' %}
        {% endcase %}
        <div
          class="resource-list__item homepage-reveal"
          data-reveal-preset="card-cascade-reveal"
          style="--reveal-delay: {{ forloop.index0 | times: 110 }}ms; --collection-card-reveal-rotate: {{ reveal_rotation }};"
          data-collection-discovery-card
        >
          {% content_for 'block', type: '_collection-card', id: 'static-collection-card', closest.collection: collection %}
        </div>
        {% unless forloop.last %}
          <!--@list/split-->
        {% endunless %}
      {% endfor %}
    {% endcapture %}

    {% liquid
      assign list_items_array = list_items | strip | split: '<!--@list/split-->'
    %}

    {% render 'resource-list',
      list_items: list_items,
      list_items_array: list_items_array,
      settings: section.settings,
      carousel_ref: 'collectionList',
      slide_count: max_items,
      content_type: 'collections',
      test_id: 'collections-list-grid'
    %}
  {% endif %}

  {% if is_patchwork_layout == false and section.settings.show_view_all and section.settings.view_all_label != blank and section.settings.view_all_link != blank %}
    <div
      class="collection-list__view-all-wrap homepage-reveal"
      data-reveal-preset="section-soft-reveal"
      style="--reveal-delay: 140ms;"
    >
      <a
        href="{{ section.settings.view_all_link }}"
        class="collection-list__view-all"
      >
        {{ section.settings.view_all_label | escape }}
      </a>
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .ui-test-collection-list [data-testid='collection-list'] {
    padding-block-start: var(--padding-block-start);
    padding-block-end: var(--padding-block-end);
  }

  [data-testid='collection-list'] .section-resource-list__content {
    display: grid;
    justify-items: center;
    gap: clamp(0.8rem, 1.8vw, 1.15rem);
    margin-bottom: clamp(1.1rem, 2.2vw, 1.75rem);
    padding: clamp(1.25rem, 2.5vw, 1.85rem) clamp(1rem, 2.4vw, 1.6rem) clamp(0.6rem, 1vw, 0.85rem);
    position: relative;
    isolation: isolate;
    overflow: clip;
  }

  [data-testid='collection-list'] .section-resource-list__content::before,
  [data-testid='collection-list'] .section-resource-list__content::after {
    content: '';
    position: absolute;
    inset: auto;
    pointer-events: none;
    z-index: 0;
  }

  [data-testid='collection-list'] .section-resource-list__content::before {
    width: min(34rem, 78vw);
    height: min(17rem, 36vw);
    top: 0;
    left: 50%;
    translate: -50% -18%;
    border-radius: 999px;
    background: radial-gradient(circle, rgb(246 231 216 / 0.82) 0%, rgb(246 231 216 / 0.36) 48%, transparent 74%);
    filter: blur(6px);
    transition:
      opacity 420ms var(--animation-timing-fade-in),
      translate 520ms var(--animation-timing-fade-in),
      scale 520ms var(--animation-timing-fade-in);
  }

  [data-testid='collection-list'] .section-resource-list__content::after {
    width: min(26rem, 56vw);
    height: min(9rem, 20vw);
    bottom: 0.55rem;
    right: min(3vw, 1.75rem);
    border-radius: 999px;
    background: radial-gradient(circle, rgb(255 255 255 / 0.52) 0%, rgb(255 255 255 / 0.12) 54%, transparent 76%);
    opacity: 0.9;
    transition:
      opacity 420ms var(--animation-timing-fade-in),
      translate 520ms var(--animation-timing-fade-in),
      scale 520ms var(--animation-timing-fade-in);
  }

  [data-testid='collection-list'] .section-resource-list__content > * {
    position: relative;
    z-index: 1;
  }

  [data-testid='collection-list'] .section-resource-list__content :is(.group-block, .group-block-content) {
    width: min(100%, 44rem);
  }

  [data-testid='collection-list'] .section-resource-list__content .text-block {
    align-items: center;
  }

  [data-testid='collection-list'] .section-resource-list__content .text-block > * {
    margin-inline: auto;
    text-align: center;
  }

  [data-testid='collection-list'] .collection-list__eyebrow {
    margin: 0;
    color: rgb(176 118 90);
    font-size: clamp(0.82rem, 0.88vw, 0.95rem);
    font-weight: 650;
    letter-spacing: 0.16em;
    line-height: 1.2;
    text-align: center;
    text-transform: uppercase;
  }

  [data-testid='collection-list'] .section-resource-list__content.homepage-reveal--pending .collection-list__eyebrow {
    opacity: 0;
    translate: 0 8px;
  }

  [data-testid='collection-list'] .section-resource-list__content.homepage-reveal.is-visible .collection-list__eyebrow {
    opacity: 1;
    translate: 0 0;
    transition:
      opacity 380ms var(--animation-timing-fade-in),
      translate 380ms var(--animation-timing-fade-in);
    transition-delay: 40ms;
  }

  [data-testid='collection-list'] .section-resource-list__content .text-block.h2 > * {
    max-inline-size: 16ch;
    color: rgb(62 51 45);
    font-size: clamp(2.2rem, 4vw, 3.45rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.02;
    text-wrap: balance;
  }

  [data-testid='collection-list'] .section-resource-list__content.homepage-reveal--pending .text-block.h2 > * {
    opacity: 0;
    clip-path: inset(0 18% 100% 18%);
  }

  [data-testid='collection-list'] .section-resource-list__content.homepage-reveal.is-visible .text-block.h2 > * {
    opacity: 1;
    clip-path: inset(0 0 0 0);
    transition:
      opacity 460ms var(--animation-timing-fade-in),
      clip-path 540ms var(--animation-timing-fade-in);
    transition-delay: 95ms;
  }

  [data-testid='collection-list'] .section-resource-list__content .text-block.h2 {
    position: relative;
    padding-block-end: 0.7rem;
  }

  [data-testid='collection-list'] .section-resource-list__content .text-block.h2::after {
    content: '';
    width: clamp(3.25rem, 8vw, 4.5rem);
    height: 2px;
    border-radius: 999px;
    background: rgb(180 124 97 / 0.72);
    margin-top: 0.2rem;
    transform-origin: center;
  }

  [data-testid='collection-list'] .section-resource-list__content .text-block.rte > * {
    max-inline-size: 38rem;
    color: rgb(96 80 69);
    font-size: clamp(1.05rem, 1.2vw, 1.14rem);
    font-weight: 450;
    line-height: 1.62;
  }

  [data-testid='collection-list'] .collection-list__chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.7rem 0.8rem;
    max-width: min(100%, 42rem);
    margin-top: clamp(0.15rem, 0.4vw, 0.3rem);
  }

  [data-testid='collection-list'] .collection-list__chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.35rem;
    padding: 0.55rem 0.9rem;
    border: 1px solid rgb(198 167 143 / 0.4);
    border-radius: 999px;
    background: linear-gradient(180deg, rgb(255 251 246 / 0.72) 0%, rgb(248 239 230 / 0.58) 100%);
    box-shadow:
      0 1px 0 rgb(255 255 255 / 0.72) inset,
      0 8px 20px rgb(117 88 68 / 0.05);
    color: rgb(122 93 76);
    font-size: clamp(0.92rem, 0.98vw, 0.98rem);
    font-weight: 500;
    line-height: 1.3;
    text-align: center;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition:
      color 240ms var(--animation-easing),
      border-color 240ms var(--animation-easing),
      background-color 240ms var(--animation-easing),
      box-shadow 240ms var(--animation-easing),
      translate 240ms var(--animation-easing);
  }

  [data-testid='collection-list'] .collection-list__chip::after {
    content: '';
    position: absolute;
    inset: auto 0 0.2rem;
    width: 100%;
    height: 1px;
    background: rgb(176 118 90 / 0.78);
    opacity: 0;
    scale: 0.45 1;
    transform-origin: center;
    transition:
      opacity 220ms var(--animation-easing),
      scale 220ms var(--animation-easing);
  }

  [data-testid='collection-list'] .collection-list__chip-label {
    position: relative;
    z-index: 1;
  }

  [data-testid='collection-list'] .collection-list__chip:hover,
  [data-testid='collection-list'] .collection-list__chip:focus-visible {
    border-color: rgb(180 124 97 / 0.58);
    background: linear-gradient(180deg, rgb(255 251 246 / 0.92) 0%, rgb(244 229 214 / 0.82) 100%);
    color: rgb(103 72 57);
    box-shadow:
      0 1px 0 rgb(255 255 255 / 0.78) inset,
      0 10px 22px rgb(117 88 68 / 0.08);
    translate: 0 -1px;
  }

  [data-testid='collection-list'] .collection-list__chip:hover::after,
  [data-testid='collection-list'] .collection-list__chip:focus-visible::after {
    opacity: 1;
    scale: 1 1;
  }

  [data-testid='collection-list'] .collection-list__chip:focus-visible {
    outline: 2px solid rgb(176 118 90 / 0.45);
    outline-offset: 2px;
  }

  [data-testid='collection-list'] .collection-list__chip--static {
    cursor: default;
    pointer-events: none;
  }

  [data-testid='collection-list'][data-patchwork-interaction='true'] .collection-patchwork__tile {
    transition:
      transform 240ms var(--animation-easing),
      opacity 240ms var(--animation-easing),
      border-color 240ms var(--animation-easing),
      box-shadow 240ms var(--animation-easing);
  }

  [data-testid='collection-list'][data-patchwork-interaction='true'] .collection-patchwork__tile:not(.collection-patchwork__tile--placeholder) {
    opacity: 1;
  }

  [data-testid='collection-list'][data-patchwork-interaction='true'][data-active-chip='1'] .collection-patchwork__tile--1,
  [data-testid='collection-list'][data-patchwork-interaction='true'][data-active-chip='2'] .collection-patchwork__tile--2,
  [data-testid='collection-list'][data-patchwork-interaction='true'][data-active-chip='3'] .collection-patchwork__tile--3,
  [data-testid='collection-list'][data-patchwork-interaction='true'][data-active-chip='4'] .collection-patchwork__tile--4 {
    opacity: 1;
    transform: translateY(-3px) scale(1.01);
    border-color: rgb(184 158 135 / 0.62);
    box-shadow:
      0 1px 0 rgb(255 255 255 / 0.84) inset,
      0 22px 42px rgb(88 67 54 / 0.12);
  }

  [data-testid='collection-list'][data-patchwork-interaction='true'][data-active-chip='1'] .collection-patchwork__tile--1 .collection-patchwork__media::after,
  [data-testid='collection-list'][data-patchwork-interaction='true'][data-active-chip='2'] .collection-patchwork__tile--2 .collection-patchwork__media::after,
  [data-testid='collection-list'][data-patchwork-interaction='true'][data-active-chip='3'] .collection-patchwork__tile--3 .collection-patchwork__media::after,
  [data-testid='collection-list'][data-patchwork-interaction='true'][data-active-chip='4'] .collection-patchwork__tile--4 .collection-patchwork__media::after {
    opacity: 0.94;
  }



  [data-testid='collection-list'][data-active-chip='1'] .collection-list__chip[data-chip-index='1'],
  [data-testid='collection-list'][data-active-chip='2'] .collection-list__chip[data-chip-index='2'],
  [data-testid='collection-list'][data-active-chip='3'] .collection-list__chip[data-chip-index='3'],
  [data-testid='collection-list'][data-active-chip='4'] .collection-list__chip[data-chip-index='4'] {
    border-color: rgb(180 124 97 / 0.62);
    background: linear-gradient(180deg, rgb(255 251 246 / 0.96) 0%, rgb(245 232 218 / 0.9) 100%);
    color: rgb(96 69 55);
    box-shadow:
      0 1px 0 rgb(255 255 255 / 0.82) inset,
      0 12px 24px rgb(117 88 68 / 0.09);
  }

  [data-testid='collection-list'][data-active-chip='1'] .collection-list__chip[data-chip-index='1']::after,
  [data-testid='collection-list'][data-active-chip='2'] .collection-list__chip[data-chip-index='2']::after,
  [data-testid='collection-list'][data-active-chip='3'] .collection-list__chip[data-chip-index='3']::after,
  [data-testid='collection-list'][data-active-chip='4'] .collection-list__chip[data-chip-index='4']::after {
    opacity: 1;
    scale: 1 1;
  }

  [data-testid='collection-list'][data-active-chip='1'] .section-resource-list__content::before {
    opacity: 0.96;
    translate: -50% -20%;
    scale: 1.02;
  }

  [data-testid='collection-list'][data-active-chip='2'] .section-resource-list__content::before {
    opacity: 0.88;
    translate: -47% -15%;
    scale: 1.05;
  }

  [data-testid='collection-list'][data-active-chip='3'] .section-resource-list__content::before {
    opacity: 0.9;
    translate: -53% -17%;
    scale: 1.03;
  }

  [data-testid='collection-list'][data-active-chip='4'] .section-resource-list__content::before {
    opacity: 0.86;
    translate: -50% -13%;
    scale: 1.06;
  }

  [data-testid='collection-list'][data-active-chip='2'] .section-resource-list__content::after,
  [data-testid='collection-list'][data-active-chip='4'] .section-resource-list__content::after {
    opacity: 1;
    translate: 0 -4px;
    scale: 1.05;
  }

  [data-testid='collection-list'] .collection-patchwork {
    display: grid;
    gap: clamp(0.9rem, 1.45vw, 1.25rem);
    align-items: stretch;
  }

  [data-testid='collection-list'] .collection-patchwork__editorial {
    grid-area: editorial;
    position: relative;
    height: auto;
