

{% liquid
  assign media_class_modifier = 'media-with-content--' | append: section.settings.media_width

  if section.settings.extend_media and section.settings.section_width == 'page-width'
    assign media_class_modifier = media_class_modifier | append: ' media-with-content--media-extend'
  endif

  if section.settings.media_position == 'right'
    assign media_class_modifier = media_class_modifier | append: ' media-with-content--media-right'
  endif

  if section.settings.media_height == 'auto'
    assign media_class_modifier = media_class_modifier | append: ' media-with-content--auto-height'
  endif

  if section.settings.background_color == '#3E332D' or section.settings.background_color == '#3e332d'
    assign media_class_modifier = media_class_modifier | append: ' media-with-content--dark-surface'
  endif

  if section.id contains 'media_with_content_RqxiU3'
    assign media_class_modifier = media_class_modifier | append: ' media-with-content--footer-newsletter'
  endif
%}

{% liquid
  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
  endif
%}
<div
  class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
></div>
<div
  class="section section--{{ section.settings.section_width }} disable-section-top-offset media-with-content{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %} spacing-style {{ media_class_modifier }} {% if section.id contains 'media_with_content_brand_intro' %}media-with-content--brand-intro{% endif %}"
  data-testid="media-with-content"
  data-homepage-reveal-children=".media-with-content__content"
  style="
    {%- render 'spacing-style', settings: section.settings %}
    {% render 'border-override', settings: section.settings %}
    --media-height: {{ section.settings.media_height }};
    {%- case section.settings.media_height %}
      {% when '50svh' %}
        --media-height-mobile: 30svh;
      {% when '60svh' %}
        --media-height-mobile: 50svh;
      {% when '80svh' %}
        --media-height-mobile: 70svh;
      {% when '100svh' %}
        --media-height-mobile: 100svh;
      {% else %}
        --media-height-mobile: auto;
    {% endcase -%}

    {% if section.settings.media_height != 'auto' %}
     --section-preview-height: 600px;
     {% endif %}
  "
  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
>
  {%- if section.id contains 'media_with_content_brand_intro' -%}
    <div class="brand-intro-card">
      <div class="brand-intro-card__media">
        <img
          class="brand-intro-card__bg-image"
          src="{{ 'brand-intro-bedroom.png' | asset_url }}"
          alt="Layered neutral bedding in a warm bedroom setting"
          loading="lazy"
          width="1200"
          height="800"
        >
      </div>
      <div class="brand-intro-card__overlay-gradient"></div>

      <div class="brand-intro-card__content">
        <div class="brand-intro-card__eyebrow-container">
          <div class="brand-intro-card__eyebrow">Designed for everyday comfort</div>
          <div class="brand-intro-card__eyebrow-line"></div>
        </div>
        <h2 class="brand-intro-card__heading">Made for <br><em>calmer nights</em></h2>
        <p class="brand-intro-card__body">We design soft, breathable bedding layers that bring warmth, texture and ease into everyday sleep.</p>

        <div class="brand-intro-card__features-box">
          <div class="brand-intro-card__feature-row">
            <span class="brand-intro-card__feature-num">01</span>
            <span class="brand-intro-card__feature-label">SOFTNESS</span>
            <span class="brand-intro-card__feature-desc">Gentle on skin, perfect for all seasons.</span>
          </div>
          <div class="brand-intro-card__feature-row">
            <span class="brand-intro-card__feature-num">02</span>
            <span class="brand-intro-card__feature-label">CRAFTED</span>
            <span class="brand-intro-card__feature-desc">Thoughtfully designed layers for the perfect rest.</span>
          </div>
          <div class="brand-intro-card__feature-row">
            <span class="brand-intro-card__feature-num">03</span>
            <span class="brand-intro-card__feature-label">LASTING</span>
            <span class="brand-intro-card__feature-desc">Premium materials made to stay beautiful over time.</span>
          </div>
        </div>

        <a href="/collections/all" class="brand-intro-card__cta">
          Explore our bedding
          <svg class="brand-intro-card__cta-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>
    </div>
  {%- else -%}
    {% content_for 'block', type: '_media-without-appearance', id: 'media' %}

    {% content_for 'block', type: '_content-without-appearance', id: 'content' %}
  {%- endif -%}
</div>

{% stylesheet %}
  .section--page-width {
    &.media-with-content {
      grid-template-areas: 'margin-left media margin-right' 'margin-left content margin-right';

      @media screen and (min-width: 750px) {
        /* Wide proportion is media 3.5 parts, content 2.5 parts. Which equals 7|5. So divide the central column by 7+5 and multiply accordingly */
        --media-with-content-grid-columns: var(--full-page-grid-margin)
          calc((var(--full-page-grid-central-column-width) / 12) * 7)
          calc((var(--full-page-grid-central-column-width) / 12) * 5) var(--full-page-grid-margin);

        grid-template-areas: 'margin-left media content margin-right';
      }
    }

    &.media-with-content--media-right {
      @media screen and (min-width: 750px) {
        --media-with-content-grid-columns: var(--full-page-grid-margin)
          calc((var(--full-page-grid-central-column-width) / 12) * 5)
          calc((var(--full-page-grid-central-column-width) / 12) * 7) var(--full-page-grid-margin);

        grid-template-areas: 'margin-left content media margin-right';
      }
    }

    &.media-with-content--medium {
      @media screen and (min-width: 750px) {
        --media-with-content-grid-columns: var(--full-page-grid-margin)
          repeat(2, calc(var(--full-page-grid-central-column-width) / 2)) var(--full-page-grid-margin);
      }
    }

    &.media-with-content--narrow.media-with-content--media-right {
      @media screen and (min-width: 750px) {
        --media-with-content-grid-columns: var(--full-page-grid-margin)
          calc((var(--full-page-grid-central-column-width) / 3) * 2)
          calc(var(--full-page-grid-central-column-width) / 3) var(--full-page-grid-margin);
      }
    }

    &.media-with-content--narrow {
      @media screen and (min-width: 750px) {
        --media-with-content-grid-columns: var(--full-page-grid-margin)
          calc(var(--full-page-grid-central-column-width) / 3)
          calc((var(--full-page-grid-central-column-width) / 3) * 2) var(--full-page-grid-margin);
      }
    }
  }

  .section--full-width {
    &.media-with-content--media-right {
      @media screen and (min-width: 750px) {
        --media-with-content-grid-columns: 2.5fr 3.5fr;

        grid-template-areas: 'content media';
      }
    }

    &.media-with-content--medium {
      @media screen and (min-width: 750px) {
        --media-with-content-grid-columns: 1fr 1fr;
      }
    }

    &.media-with-content--narrow {
      @media screen and (min-width: 750px) {
        --media-with-content-grid-columns: 2fr 4fr;
      }
    }

    &.media-with-content--narrow.media-with-content--media-right {
      @media screen and (min-width: 750px) {
        --media-with-content-grid-columns: 4fr 2fr;
      }
    }
  }

  /* Keep the CSS specificity lower assuming that liquid won't assign this class with a full width section */
  .media-with-content.media-with-content--media-extend {
    grid-template-columns: var(--media-with-content-grid-columns);
    grid-template-areas: 'media media media' 'margin-left content margin-right';

    @media screen and (min-width: 750px) {
      grid-template-areas: 'media media content margin-right';
    }
  }

  .media-with-content--media-extend.media-with-content--media-right {
    @media screen and (min-width: 750px) {
      grid-template-areas: 'margin-left content media media';
    }
  }

  .media-with-content--media-right {
    @media screen and (min-width: 750px) {
      grid-template-areas: 'margin-left content media media';
    }
  }

  .media-with-content {
    --media-with-content-grid-columns: var(--full-page-grid-with-margins);

    grid-template-columns: var(--media-with-content-grid-columns);
    grid-template-areas: 'media media media' 'content content content';

    @media screen and (min-width: 750px) {
      --media-with-content-grid-columns: 3.5fr 2.5fr;

      /* Default desktop layout is wide media, on the left, in full page section */
      grid-template-areas: 'media content';
    }

    .media-block {
      grid-area: media;
    }

    .media-with-content__content {
      grid-area: content;
      min-width: 0;
    }

    .media-block {
      overflow: hidden;
      border-radius: clamp(1.1rem, 2vw, 1.5rem);
      background: rgb(244 239 233);
      box-shadow: 0 20px 42px rgb(62 51 45 / 0.08);
    }

    .media-block :is(img, video, .placeholder-svg, .resource-image__image) {
      transition: transform var(--animation-speed-medium) var(--animation-timing-fade-in);
    }

    /* Inner blocks spacing */
    .media-with-content__content > .group-block-content {
      padding-inline: var(--page-margin);
      padding-block: calc(2 * var(--page-margin));
      min-width: 0;
      gap: clamp(1rem, 1.8vw, 1.4rem);

      @media screen and (min-width: 750px) {
        padding-block: var(--page-margin);
      }
    }

    &.section--page-width .media-with-content__content > .group-block-content {
      padding-inline: 0;

      @media screen and (min-width: 750px) {
        padding-inline-start: var(--page-margin);
      }
    }

    &.section--page-width.media-with-content--media-right .media-with-content__content > .group-block-content {
      padding-inline-end: var(--page-margin);
      padding-inline-start: 0;
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .media-with-content:hover .media-block :is(img, video, .placeholder-svg, .resource-image__image) {
      transform: scale(1.02);
    }
  }

  .media-with-content .media-with-content__content :is(.button, .button-secondary, .button-custom):not(.email-signup__button) {
    min-height: max(46px, var(--minimum-touch-target));
    border-radius: 12px;
    font-size: clamp(1rem, 1.05vw, 1.06rem);
    font-weight: 600;
    line-height: 1.15;
    box-shadow: 0 14px 30px rgb(62 51 45 / 0.1);
  }

  .media-with-content .media-with-content__content .button-unstyled:not(.email-signup__button) {
    min-height: max(44px, var(--minimum-touch-target));
    display: inline-flex;
    align-items: center;
    padding-block: 0.25rem;
  }

  .media-with-content.section--page-width:not(.media-with-content--media-extend):not(.media-with-content--auto-height)
    .media-with-content__content
    > .group-block-content {
    max-width: min(100%, 35.5rem);
    padding-inline-start: clamp(1rem, 4vw, 3.2rem);
    gap: clamp(1.1rem, 2vw, 1.55rem);
    padding-block: clamp(1.75rem, 2.6vw, 2.3rem);
  }

  .media-with-content.section--page-width:not(.media-with-content--media-extend):not(.media-with-content--auto-height)
    .media-with-content__content
    .text-block.h6
    > *,
  .media-with-content.section--page-width:not(.media-with-content--media-extend):not(.media-with-content--auto-height)
    .media-with-content__content
    .text-block.paragraph:first-child
    > * {
    color: rgb(180 124 97);
    font-size: clamp(0.92rem, 0.95vw, 1rem);
    font-weight: 650;
    letter-spacing: 0.12em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .media-with-content.section--page-width:not(.media-with-content--media-extend):not(.media-with-content--auto-height)
    .media-with-content__content
    .text-block.h3
    > *,
  .media-with-content.section--page-width:not(.media-with-content--media-extend):not(.media-with-content--auto-height)
    .media-with-content__content
    .text-block.h2
    > * {
    max-inline-size: 12ch;
    color: rgb(62 51 45);
    font-size: clamp(2.35rem, 4.2vw, 3.65rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.02;
    text-wrap: balance;
  }

  .media-with-content.section--page-width:not(.media-with-content--media-extend):not(.media-with-content--auto-height)
    .media-with-content__content
    :is(.text-block.rte, .text-block.paragraph)
    > * {
    color: rgb(117 101 90);
    font-size: clamp(1.05rem, 1.2vw, 1.14rem);
    font-weight: 450;
    line-height: 1.64;
  }

  .media-with-content.section--page-width:not(.media-with-content--media-extend):not(.media-with-content--auto-height)
    .media-with-content__content
    .button {
    box-shadow:
      0 1px 0 rgb(255 255 255 / 0.7) inset,
      0 16px 28px rgb(103 74 58 / 0.14);
  }

  .media-with-content.section--page-width.media-with-content--media-extend .media-with-content__content > .group-block-content {
    max-width: min(100%, 35rem);
    padding-inline-start: clamp(1.25rem, 4vw, 3.25rem);
    gap: clamp(1.1rem, 2vw, 1.6rem);
    padding-block: clamp(1.25rem, 2vw, 1.8rem);
    border: 1px solid rgb(226 217 207 / 0.42);
    border-radius: 18px;
    background: linear-gradient(180deg, rgb(250 248 245 / 0.4) 0%, rgb(255 255 255 / 0.24) 100%);
    box-shadow:
      0 1px 0 rgb(255 255 255 / 0.52) inset,
      0 10px 24px rgb(103 74 58 / 0.05);
  }

  .media-with-content.section--page-width.media-with-content--media-extend .media-with-content__content .text-block.h3 > *,
  .media-with-content.section--page-width.media-with-content--media-extend .media-with-content__content .text-block.h2 > * {
    max-inline-size: 14ch;
    color: rgb(62 51 45);
    font-size: clamp(2.3rem, 4vw, 3.5rem);
    font-weight: 600;
    line-height: 1.03;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .media-with-content.section--page-width.media-with-content--media-extend
    .media-with-content__content
    :is(.text-block.rte, .text-block.paragraph)
    > * {
    color: rgb(99 83 72);
    font-size: clamp(1.05rem, 1.15vw, 1.12rem);
    font-weight: 450;
    line-height: 1.65;
  }

  .media-with-content.section--page-width.media-with-content--media-extend .media-with-content__content .text-block.h3 {
    position: relative;
    padding-block-end: 1rem;
  }

  .media-with-content.section--page-width.media-with-content--media-extend .media-with-content__content .text-block.h3::after {
    content: '';
    width: clamp(3rem, 6vw, 4rem);
    height: 2px;
    border-radius: 999px;
    background: rgb(180 124 97 / 0.72);
  }

  .media-with-content.section--page-width.media-with-content--media-extend .media-with-content__content .button {
    box-shadow:
      0 1px 0 rgb(255 255 255 / 0.64) inset,
      0 12px 22px rgb(103 74 58 / 0.1);
  }

  .media-with-content.media-with-content--dark-surface .media-block {
    background: rgb(74 60 52);
    box-shadow: 0 18px 36px rgb(20 14 11 / 0.14);
  }

  .media-with-content.section--page-width.media-with-content--dark-surface:not(.media-with-content--media-extend):not(.media-with-content--auto-height)
    .media-with-content__content
    > .group-block-content {
    max-width: min(100%, 37rem);
    gap: clamp(1.15rem, 2vw, 1.7rem);
  }

  .media-with-content.section--page-width.media-with-content--dark-surface:not(.media-with-content--media-extend):not(.media-with-content--auto-height)
    .media-with-content__content
    .text-block.h6
    > *,
  .media-with-content.section--page-width.media-with-content--dark-surface:not(.media-with-content--media-extend):not(.media-with-content--auto-height)
    .media-with-content__content
    .text-block.paragraph:first-child
    > * {
    color: rgb(223 183 143 / 0.94);
    font-size: clamp(0.94rem, 0.95vw, 1.02rem);
    font-weight: 650;
    text-shadow: 0 1px 10px rgb(0 0 0 / 0.12);
  }

  .media-with-content.section--page-width.media-with-content--dark-surface:not(.media-with-content--media-extend):not(.media-with-content--auto-height)
    .media-with-content__content
    .text-block.h3
    > *,
  .media-with-content.section--page-width.media-with-content--dark-surface:not(.media-with-content--media-extend):not(.media-with-content--auto-height)
    .media-with-content__content
    .text-block.h2
    > * {
    color: #fff8ef;
    font-size: clamp(2.45rem, 4.3vw, 3.85rem);
    font-weight: 600;
    line-height: 1.04;
    text-shadow: 0 1px 2px rgb(0 0 0 / 0.16);
  }

  .media-with-content.section--page-width.media-with-content--dark-surface:not(.media-with-content--media-extend):not(.media-with-content--auto-height)
    .media-with-content__content
    :is(.text-block.rte, .text-block.paragraph)
    > * {
    color: rgb(255 248 239 / 0.84);
    font-size: clamp(1.08rem, 1.24vw, 1.16rem);
    font-weight: 450;
    line-height: 1.64;
  }

  .media-with-content.section--page-width.media-with-content--dark-surface .media-with-content__content :is(.text-block, rte-formatter) li {
    color: rgb(255 248 239 / 0.82);
    font-size: clamp(1.03rem, 1.12vw, 1.1rem);
    font-weight: 450;
  }

  .media-with-content.section--page-width.media-with-content--dark-surface .media-with-content__content :is(.text-block, rte-formatter) li::before {
    background: rgb(214 170 131);
  }

  .media-with-content.section--page-width.media-with-content--dark-surface:not(.media-with-content--media-extend):not(.media-with-content--auto-height)
    .media-with-content__content
    .button {
    box-shadow:
      0 1px 0 rgb(255 255 255 / 0.12) inset,
      0 14px 26px rgb(12 8 6 / 0.18);
  }

  .media-with-content.section--full-width.media-with-content--auto-height {
    @media screen and (min-width: 750px) {
      --media-with-content-grid-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    }
  }

  .media-with-content.section--full-width.media-with-content--auto-height .media-block {
    border-radius: 0;
    box-shadow: none;
  }

  .media-with-content.section--full-width.media-with-content--auto-height .media-with-content__content > .group-block-content {
    max-width: min(100%, 34rem);
    padding-inline: clamp(1.25rem, 4vw, 4rem);
    padding-block: clamp(2rem, 4vw, 3rem);
    gap: clamp(1rem, 1.6vw, 1.35rem);
  }

  .media-with-content.section--full-width.media-with-content--auto-height .media-with-content__content .text-block > * {
    max-inline-size: 30rem;
    color: rgb(62 51 45);
    font-size: clamp(1.08rem, 1.18vw, 1.16rem);
    font-weight: 450;
    line-height: 1.58;
  }

  .media-with-content.section--full-width.media-with-content--auto-height .media-with-content__content .text-block.h3 > * {
    max-inline-size: 28rem;
    color: rgb(77 62 53);
    font-size: clamp(2rem, 3vw, 2.8rem);
    font-weight: 600;
    line-height: 1.06;
  }

  .media-with-content.section--full-width.media-with-content--auto-height
    .media-with-content__content
    :is(.text-block.paragraph, .text-block.rte)
    > * {
    color: rgb(108 91 79);
  }

  .media-with-content.section--full-width.media-with-content--auto-height .email-signup-block {
    max-width: 33rem;
  }

  .media-with-content.section--full-width.media-with-content--auto-height .email-signup__input-group--arrow {
    box-shadow: 0 8px 18px rgb(62 51 45 / 0.035);
  }

  .media-with-content .media-with-content__content :is(.text-block, rte-formatter) ul {
    display: grid;
    gap: 0.8rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .media-with-content .media-with-content__content :is(.text-block, rte-formatter) li {
    position: relative;
    margin: 0;
    padding-inline-start: 1.45rem;
    color: rgb(var(--color-foreground-rgb) / 0.82);
    line-height: 1.72;
  }

  .media-with-content .media-with-content__content :is(.text-block, rte-formatter) li::before {
    content: '';
    position: absolute;
    top: 0.75em;
    left: 0;
    width: 0.48rem;
    height: 0.48rem;
    border-radius: 999px;
    background: rgb(180 154 132);
    transform: translateY(-50%);
  }

  @media screen and (max-width: 749px) {
    .media-with-content .media-block {
      border-radius: 1rem;
      box-shadow: 0 12px 28px rgb(62 51 45 / 0.08);
    }

    .media-with-content .media-with-content__content > .group-block-content {
      padding-inline: clamp(1rem, 5vw, 1.35rem);
      padding-block: clamp(1.2rem, 6vw, 1.75rem);
      gap: clamp(0.85rem, 3vw, 1.15rem);
    }

    .media-with-content.section--page-width:not(.media-with-content--media-extend):not(.media-with-content--auto-height)
      .media-with-content__content
      > .group-block-content,
    .media-with-content.section--page-width.media-with-content--media-extend .media-with-content__content > .group-block-content,
    .media-with-content.section--full-width.media-with-content--auto-height .media-with-content__content > .group-block-content {
      max-width: 100%;
      padding-inline: clamp(1rem, 5vw, 1.35rem);
    }

    .media-with-content.section--page-width.media-with-content--media-extend .media-with-content__content > .group-block-content {
      border-radius: 16px;
      border-color: rgb(226 217 207 / 0.36);
      background: rgb(250 248 245 / 0.34);
      box-shadow: 0 6px 16px rgb(103 74 58 / 0.035);
    }

    .media-with-content .media-with-content__content :is(.text-block, rte-formatter) ul {
      gap: 0.6rem;
    }

    .media-with-content .media-with-content__content :is(.text-block, rte-formatter) li {
      padding-inline-start: 1.2rem;
    }

    .media-with-content.section--page-width.media-with-content--media-extend .media-with-content__content .button,
    .media-with-content.section--page-width:not(.media-with-content--media-extend):not(.media-with-content--auto-height)
      .media-with-content__content
      .button {
      width: 100%;
      justify-content: center;
    }

    .media-with-content.section--full-width.media-with-content--auto-height .media-block {
