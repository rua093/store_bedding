{% liquid
  assign desktop_media = 'none'
  assign mobile_media = 'none'
  assign use_mobile_media = false
  assign fetch_priority = 'auto'
  assign hero_has_visual_preview = request.visual_preview_mode
  assign hero_is_auto_height = false
  assign hero_text_align = 'left'
  assign desktop_widths = '832, 1200, 1600, 1920, 2560, 3840'
  assign mobile_widths = '416, 600, 800, 1200, 1600'
  assign mobile_widths_array = mobile_widths | split: ', '
  assign hero_eyebrow = section.settings.eyebrow | strip
  assign hero_heading = section.settings.heading | strip
  assign hero_description = section.settings.description | strip
  assign hero_primary_label = section.settings.primary_label | strip
  assign hero_primary_link = section.settings.primary_link
  assign hero_secondary_label = section.settings.secondary_label | strip
  assign hero_secondary_link = section.settings.secondary_link

  if section.settings.image_1 != blank and section.settings.media_type_1 == 'image'
    assign desktop_media = 'image'
  elsif section.settings.video_1 != blank and section.settings.media_type_1 == 'video'
    assign desktop_media = 'video'
  endif

  if section.settings.custom_mobile_media
    if section.settings.image_1_mobile != blank and section.settings.media_type_1_mobile == 'image'
      assign mobile_media = 'image'
    elsif section.settings.video_1_mobile != blank and section.settings.media_type_1_mobile == 'video'
      assign mobile_media = 'video'
    endif
  endif

  if mobile_media != 'none'
    assign use_mobile_media = true
  endif

  if section.index == 1
    if desktop_media != 'none' or mobile_media != 'none'
      assign fetch_priority = 'high'
    endif
  endif

  if section.settings.section_height == 'auto'
    assign hero_is_auto_height = true
  endif

  assign primary_image = section.settings.image_1
  if primary_image == blank and section.settings.image_1_mobile != blank
    assign primary_image = section.settings.image_1_mobile
  endif

  case section.settings.horizontal_alignment_flex_direction_column
    when 'center'
      assign hero_text_align = 'center'
    when 'flex-end'
      assign hero_text_align = 'right'
  endcase

  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id, skip_contrast: true
  endif
%}

{% capture hero_media %}
  {% if desktop_media == 'image' and use_mobile_media and mobile_media == 'image' %}
    <picture
      class="hero__media hero__media-item hero__media-item--all"
      data-testid="hero-picture-1"
    >
      <source
        media="(max-width: 749px)"
        srcset="
          {%- for mobile_width in mobile_widths_array -%}
            {{ section.settings.image_1_mobile | image_url: width: mobile_width }} {{ mobile_width }}w{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        "
        sizes="100vw"
        width="{{ section.settings.image_1_mobile.width }}"
        height="{{ section.settings.image_1_mobile.height }}"
      >
      {{
        section.settings.image_1
        | image_url: width: 3840
        | image_tag:
          width: section.settings.image_1.width,
          widths: desktop_widths,
          height: section.settings.image_1.height,
          alt: section.settings.image_1.alt,
          class: 'hero__media',
          sizes: '100vw',
          fetchpriority: fetch_priority,
          data-testid: 'hero-desktop-image-1'
      }}
    </picture>
  {% elsif desktop_media == 'image' %}
    <div class="hero__media-item hero__media-item--desktop{% unless use_mobile_media %} hero__media-item--mobile{% endunless %}">
      {{
        section.settings.image_1
        | image_url: width: 3840
        | image_tag:
          width: section.settings.image_1.width,
          widths: desktop_widths,
          height: section.settings.image_1.height,
          alt: section.settings.image_1.alt,
          class: 'hero__media',
          sizes: '100vw',
          fetchpriority: fetch_priority,
          data-testid: 'hero-desktop-image-1'
      }}
    </div>
  {% elsif desktop_media == 'video' %}
    <div class="hero__media-item hero__media-item--desktop{% unless use_mobile_media %} hero__media-item--mobile{% endunless %}">
      {{
        section.settings.video_1
        | video_tag:
          poster: nil,
          autoplay: true,
          loop: true,
          controls: false,
          muted: true,
          class: 'hero__media',
          data-testid: 'hero-desktop-video-1'
      }}
    </div>
  {% endif %}

  {% if use_mobile_media and mobile_media == 'video' %}
    <div class="hero__media-item hero__media-item--mobile">
      {{
        section.settings.video_1_mobile
        | video_tag:
          poster: nil,
          autoplay: true,
          loop: true,
          controls: false,
          muted: true,
          class: 'hero__media',
          data-testid: 'hero-mobile-video-1'
      }}
    </div>
  {% elsif use_mobile_media and desktop_media != 'image' and mobile_media == 'image' %}
    <div class="hero__media-item hero__media-item--mobile">
      {{
        section.settings.image_1_mobile
        | image_url: width: 1600
        | image_tag:
          width: section.settings.image_1_mobile.width,
          widths: mobile_widths,
          height: section.settings.image_1_mobile.height,
          alt: section.settings.image_1_mobile.alt,
          class: 'hero__media',
          sizes: '100vw',
          fetchpriority: fetch_priority,
          data-testid: 'hero-mobile-image-1'
      }}
    </div>
  {% endif %}

  {% if desktop_media == 'none' and use_mobile_media == false %}
    {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero__media' }}
  {% endif %}
{% endcapture %}

<div
  id="Hero-{{ section.id }}"
  class="hero{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}{% if hero_is_auto_height %} hero--height-auto{% endif %}{% unless section.settings.toggle_overlay %} hero--readability-scrim{% endunless %}"
  style="
    --hero-content-x: {{ section.settings.horizontal_alignment_flex_direction_column }};
    --hero-content-y: {{ section.settings.vertical_alignment_flex_direction_column }};
    --hero-content-y-mobile: {{ section.settings.vertical_alignment_flex_direction_column }};
    --hero-content-width: min(100%, 38rem);
    --hero-copy-max-width: 31rem;
    --hero-text-align: {{ hero_text_align }};
    --hero-eyebrow-color: rgb(240 199 161 / 0.96);
    --hero-heading-color: #fff8ef;
    --hero-description-color: rgb(255 248 239 / 0.86);
    --hero-secondary-cta-color: rgb(255 248 239 / 0.92);
    --hero-secondary-cta-hover: #ffffff;
    --hero-text-shadow: 0 1px 2px rgb(31 22 16 / 0.2), 0 10px 30px rgb(31 22 16 / 0.16);
    --hero-eyebrow-shadow: 0 1px 2px rgb(31 22 16 / 0.26), 0 8px 24px rgb(31 22 16 / 0.18);
    {% if primary_image != blank %}--hero-media-aspect-ratio: {{ primary_image.aspect_ratio }};{% endif %}
    {% if section.settings.section_height == 'custom' %}
      --hero-min-height: {{ section.settings.section_height_custom }}svh;
    {% elsif section.settings.section_height == 'full-screen' %}
      --hero-min-height: 100svh;
    {% elsif section.settings.section_height != 'auto' %}
      --hero-min-height: var(--section-height-{{ section.settings.section_height }});
    {% endif %}
  "
  {% if hero_has_visual_preview %}
    data-shopify-visual-preview
  {% endif %}
>
  <div
    class="hero__section spacing-style section section--full-width"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    <div class="hero__background" data-testid="hero-media-wrapper">
      <div class="hero__media-grid">
        {{ hero_media }}
      </div>
      {% if section.settings.toggle_overlay %}
        <div class="hero__overlay">
          {% render 'overlay', settings: section.settings, layer: '0' %}
        </div>
      {% endif %}
    </div>

    <div class="hero__content-shell hero__content-shell--{{ section.settings.section_width }}">
      <div class="hero__content">
        {% if hero_eyebrow != blank %}
          <p class="hero__eyebrow">{{ hero_eyebrow | escape }}</p>
        {% endif %}
        {% if hero_heading != blank %}
          <h1 class="hero__heading">{{ hero_heading | escape }}</h1>
        {% endif %}
        {% if hero_description != blank %}
          <p class="hero__description">{{ hero_description | escape }}</p>
        {% endif %}
        {% if hero_primary_label != blank or hero_secondary_label != blank %}
          <div class="hero__actions">
            {% if hero_primary_label != blank %}
              <a
                {% if hero_primary_link == blank %}
                  role="link"
                  aria-disabled="true"
                {% else %}
                  href="{{ hero_primary_link }}"
                {% endif %}
                class="hero__cta hero__cta--primary"
              >
                {{ hero_primary_label | escape }}
              </a>
            {% endif %}
            {% if hero_secondary_label != blank %}
              <a
                {% if hero_secondary_link == blank %}
                  role="link"
                  aria-disabled="true"
                {% else %}
                  href="{{ hero_secondary_link }}"
                {% endif %}
                class="hero__cta hero__cta--secondary"
              >
                {{ hero_secondary_label | escape }}
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .hero-wrapper {
    --hero-height-offset: 0px;
  }

  body:has(#header-group > .header-section > #header-component) .hero-wrapper:first-child {
    --hero-height-offset: var(--header-group-height, 0);
  }

  .hero {
    position: relative;
    isolation: isolate;
    min-height: max(0px, calc(var(--hero-min-height, 0px) - var(--hero-height-offset)));
  }

  .hero[data-shopify-visual-preview] {
    min-height: 600px;
  }

  .hero__section {
    position: relative;
    min-height: inherit;
    overflow: hidden;
    z-index: var(--layer-base);
  }

  .hero__background {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: var(--color-background);
  }

  .hero--readability-scrim .hero__background::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgb(26 19 14 / 0.3) 0%, rgb(26 19 14 / 0.14) 18%, transparent 35%),
      radial-gradient(88% 74% at 16% 54%, rgb(26 19 14 / 0.3) 0%, rgb(26 19 14 / 0.16) 36%, transparent 70%);
  }

  .hero__media-grid {
    position: absolute;
    inset: 0;
  }

  .hero__media-item,
  .hero__media-item--all,
  .hero__media-grid > .placeholder-svg {
    position: absolute;
    inset: 0;
  }

  .hero__media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .hero__content-shell {
    position: relative;
    z-index: 2;
    min-height: inherit;
    display: grid;
    align-items: var(--hero-content-y-mobile);
    padding-block-start: clamp(1.75rem, 4vw, 3rem);
    padding-block-end: clamp(2.75rem, 7vw, 4.5rem);
    pointer-events: none;
  }

  .hero__content-shell--page-width {
    grid-column: 2;
    padding-inline: clamp(1rem, 2vw, 1.5rem);
  }

  .hero__content-shell--full-width {
    grid-column: 1 / -1;
    padding-inline: max(var(--page-margin), clamp(1.5rem, 4vw, 4.5rem));
  }

  .hero__content {
    width: var(--hero-content-width);
    max-width: 100%;
    justify-self: var(--hero-content-x);
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 1.8vw, 1.65rem);
    text-align: var(--hero-text-align);
    padding-inline-start: clamp(0rem, 1.2vw, 0.75rem);
    pointer-events: auto;
  }

  .hero__eyebrow {
    margin: 0;
    color: var(--hero-eyebrow-color);
    font-family: var(--font-body--family);
    font-weight: 600;
    font-size: clamp(0.82rem, 1vw, 0.96rem);
    line-height: 1.2;
    letter-spacing: 0.16em;
    text-shadow: var(--hero-eyebrow-shadow);
    text-transform: uppercase;
  }

  .hero__heading {
    margin: 0;
    color: var(--hero-heading-color);
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    font-size: clamp(2.8rem, 5.3vw, 4.75rem);
    line-height: 1.02;
    letter-spacing: -0.038em;
    max-inline-size: min(11ch, 100%);
    text-shadow: var(--hero-text-shadow);
    text-wrap: balance;
  }

  .hero__description {
    margin: 0;
    max-width: min(100%, var(--hero-copy-max-width));
    color: var(--hero-description-color);
    font-family: var(--font-body--family);
    font-size: clamp(1rem, 1.15vw, 1.12rem);
    line-height: 1.68;
    text-shadow: var(--hero-text-shadow);
    text-wrap: pretty;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.85rem 1rem;
    padding-top: 0.25rem;
  }

  .hero__actions > * {
    flex: 0 0 auto;
  }

  .hero__cta {
    min-height: max(48px, var(--minimum-touch-target));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body--family);
    font-weight: 500;
    line-height: 1;
    padding: 0.95rem 1.6rem;
    border-radius: 12px;
    text-decoration: none;
    transition:
      background-color 0.24s ease,
      color 0.24s ease,
      border-color 0.24s ease,
      box-shadow 0.24s ease;
  }

  .hero__cta--primary {
    min-height: max(48px, var(--minimum-touch-target));
    background: var(--color-primary-button-background);
    border: 1px solid var(--color-primary-button-background);
    color: var(--color-primary-button-text);
    box-shadow: 0 14px 30px rgb(58 39 29 / 0.16);
  }

  .hero__cta--primary:hover {
    background: var(--color-primary-button-background-hover, var(--color-primary-button-background));
    border-color: var(--color-primary-button-background-hover, var(--color-primary-button-background));
    box-shadow: 0 16px 32px rgb(58 39 29 / 0.2);
  }

  .hero__cta--secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding-inline: 0;
    padding-block: 0.25rem;
    min-height: auto;
    border-radius: 0;
    color: var(--hero-secondary-cta-color);
    font-weight: 500;
    text-decoration: none;
    text-shadow: var(--hero-text-shadow);
    box-shadow: inset 0 -1px 0 rgb(255 248 239 / 0.42);
  }

  .hero__cta--secondary::after {
    content: '\2192';
    font-size: 0.88em;
    line-height: 1;
    opacity: 0.74;
    transition:
      opacity 0.24s ease,
      transform 0.24s ease,
      color 0.24s ease;
  }

  .hero__cta--secondary:hover {
    color: var(--hero-secondary-cta-hover);
    box-shadow: inset 0 -1px 0 rgb(255 255 255 / 0.7);
  }

  .hero__cta--secondary:hover::after {
    opacity: 1;
    transform: translateX(2px);
  }

  .hero__cta[aria-disabled='true'] {
    opacity: 0.55;
    pointer-events: none;
  }

  .hero--height-auto {
    min-height: 0;
  }

  .hero--height-auto .hero__section {
    min-height: 0;
  }

  .hero--height-auto .hero__background,
  .hero--height-auto .hero__media-grid {
    position: relative;
  }

  .hero--height-auto .hero__content-shell {
    position: absolute;
    inset: 0;
  }

  .hero--height-auto :is(.hero__media, .hero__media-grid > .placeholder-svg) {
    aspect-ratio: var(--hero-media-aspect-ratio, 16 / 9);
  }

  .hero__media-item--mobile {
    display: none;
  }

  .hero__media-item--desktop,
  .hero__media-item--all {
    display: block;
  }

  @media screen and (min-width: 750px) {
    .hero__content-shell {
      align-items: var(--hero-content-y);
      padding-block-start: clamp(2.25rem, 4vw, 3.75rem);
      padding-block-end: clamp(4rem, 8vw, 6rem);
    }
  }

  @media screen and (max-width: 749px) {
    .hero--readability-scrim .hero__background::after {
      background:
        linear-gradient(180deg, rgb(26 19 14 / 0.28) 0%, rgb(26 19 14 / 0.12) 20%, transparent 38%),
        radial-gradient(100% 78% at 28% 70%, rgb(26 19 14 / 0.36) 0%, rgb(26 19 14 / 0.2) 42%, transparent 75%);
    }

    .hero__media-item--desktop {
      display: none;
    }

    .hero__media-item--mobile,
    .hero__media-item--all {
      display: block;
    }

    .hero__content-shell {
      padding-block-start: clamp(1.15rem, 4vw, 1.75rem);
      padding-block-end: clamp(2rem, 8vw, 3rem);
    }

    .hero__content {
      width: min(100%, 28rem);
      gap: 1rem;
      padding-inline-start: 0;
    }

    .hero__heading {
      font-size: clamp(2.2rem, 7.8vw, 3.15rem);
      line-height: 1.03;
      letter-spacing: -0.032em;
      max-inline-size: 11ch;
    }

    .hero__description {
      max-width: 100%;
      font-size: clamp(0.98rem, 3.8vw, 1.04rem);
      line-height: 1.62;
    }

    .hero__actions {
      flex-direction: column;
      align-items: stretch;
      gap: 0.9rem;
    }

    .hero__actions > * {
      width: 100%;
    }

    .hero__cta--primary {
      width: 100%;
      padding-inline: 1.4rem;
    }

    .hero__cta--secondary {
      width: fit-content;
      padding-block: 0.15rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.hero",
  "tag": "section",
  "class": "hero-wrapper section-wrapper",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.media_1"
    },
    {
      "type": "select",
      "id": "media_type_1",
      "label": "t:settings.type",
      "options": [
        {
          "value": "image",
          "label": "t:options.image"
        },
        {
          "value": "video",
          "label": "t:options.video"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "t:settings.image",
      "visible_if": "{{ section.settings.media_type_1 == 'image' }}"
    },
    {
      "type": "video",
      "id": "video_1",
      "label": "t:settings.video",
      "visible_if": "{{ section.settings.media_type_1 == 'video' }}"
    },
    {
      "type": "header",
      "content": "t:content.mobile_media"
    },
    {
      "type": "checkbox",
      "id": "custom_mobile_media",
      "label": "t:settings.custom_mobile_media",
      "default": false
    },
    {
      "type": "header",
      "content": "t:content.mobile_media_1",
      "visible_if": "{{ section.settings.custom_mobile_media }}"
    },
    {
      "type": "select",
      "id": "media_type_1_mobile",
      "label": "t:settings.type",
      "options": [
        {
          "value": "image",
          "label": "t:options.image"
        },
        {
          "value": "video",
          "label": "t:options.video"
        }
      ],
      "default": "image",
      "visible_if": "{{ section.settings.custom_mobile_media }}"
    },
    {
      "type": "image_picker",
      "id": "image_1_mobile",
      "label": "t:settings.image",
      "visible_if": "{{ section.settings.custom_mobile_media and section.settings.media_type_1_mobile == 'image' }}"
    },
    {
      "type": "video",
      "id": "video_1_mobile",
      "label": "t:settings.video",
      "visible_if": "{{ section.settings.custom_mobile_media and section.settings.media_type_1_mobile == 'video' }}"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Premium Bedding"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sleep Better Every Night"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Soft blankets, quilts and comforters made for warmer, calmer nights."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary CTA Label",
      "default": "Shop Bedding"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary CTA Link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary CTA Label",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary CTA Link"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "horizontal_alignment_flex_direction_column",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.right"
        }
      ],
      "default": "flex-start"
    },
    {
      "type": "select",
      "id": "vertical_alignment_flex_direction_column",
      "label": "t:settings.position",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.top"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.bottom"
        }
      ],
      "default": "flex-end"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "t:settings.height",
      "options": [
        {
          "value": "auto",
          "label": "t:options.auto"
        },
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "medium",
          "label": "t:options.medium"
        },
        {
          "value": "large",
          "label": "t:options.large"
        },
        {
          "value": "full-screen",
          "label": "t:options.full_screen"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "large"
    },
    {
