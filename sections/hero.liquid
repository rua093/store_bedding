{% liquid
  assign desktop_media = 'none'
  assign mobile_media = 'none'
  assign use_mobile_media = false
  assign fetch_priority = 'auto'
  assign hero_has_visual_preview = request.visual_preview_mode
  assign hero_is_auto_height = false
  assign hero_text_align = 'left'
  assign hero_slot_align = 'flex-start'
  assign desktop_widths = '832, 1200, 1600, 1920, 2560, 3840'
  assign mobile_widths = '416, 600, 800, 1200, 1600'

  if section.settings.image_1 != blank and section.settings.media_type_1 == 'image'
    assign desktop_media = 'image'
  elsif section.settings.video_1 != blank and section.settings.media_type_1 == 'video'
    assign desktop_media = 'video'
  endif

  if section.settings.custom_mobile_media
    if section.settings.image_1_mobile != blank and section.settings.media_type_1_mobile == 'image'
      assign mobile_media = 'image'
    elsif section.settings.video_1_mobile != blank and section.settings.media_type_1_mobile == 'video'
      assign mobile_media = 'video'
    endif
  endif

  if mobile_media != 'none'
    assign use_mobile_media = true
  endif

  if section.index == 1
    if desktop_media != 'none' or mobile_media != 'none'
      assign fetch_priority = 'high'
    endif
  endif

  if section.settings.section_height == 'auto'
    assign hero_is_auto_height = true
  endif

  assign primary_image = section.settings.image_1
  if primary_image == blank and section.settings.image_1_mobile != blank
    assign primary_image = section.settings.image_1_mobile
  endif

  case section.settings.horizontal_alignment_flex_direction_column
    when 'center'
      assign hero_text_align = 'center'
      assign hero_slot_align = 'center'
    when 'flex-end'
      assign hero_text_align = 'right'
      assign hero_slot_align = 'flex-end'
  endcase

  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id, skip_contrast: true
  endif
%}

{% capture hero_media %}
  {% if desktop_media == 'image' and use_mobile_media and mobile_media == 'image' %}
    <picture
      class="hero__media hero__media-item hero__media-item--all"
      data-testid="hero-picture-1"
    >
      <source
        media="(max-width: 749px)"
        srcset="
          {%- for mobile_width in mobile_widths -%}
            {{ section.settings.image_1_mobile | image_url: width: mobile_width }} {{ mobile_width }}w{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        "
        sizes="100vw"
        width="{{ section.settings.image_1_mobile.width }}"
        height="{{ section.settings.image_1_mobile.height }}"
      >
      {{
        section.settings.image_1
        | image_url: width: 3840
        | image_tag:
          width: section.settings.image_1.width,
          widths: desktop_widths,
          height: section.settings.image_1.height,
          alt: section.settings.image_1.alt,
          class: 'hero__media',
          sizes: '100vw',
          fetchpriority: fetch_priority,
          data-testid: 'hero-desktop-image-1'
      }}
    </picture>
  {% elsif desktop_media == 'image' %}
    <div class="hero__media-item hero__media-item--desktop{% unless use_mobile_media %} hero__media-item--mobile{% endunless %}">
      {{
        section.settings.image_1
        | image_url: width: 3840
        | image_tag:
          width: section.settings.image_1.width,
          widths: desktop_widths,
          height: section.settings.image_1.height,
          alt: section.settings.image_1.alt,
          class: 'hero__media',
          sizes: '100vw',
          fetchpriority: fetch_priority,
          data-testid: 'hero-desktop-image-1'
      }}
    </div>
  {% elsif desktop_media == 'video' %}
    <div class="hero__media-item hero__media-item--desktop{% unless use_mobile_media %} hero__media-item--mobile{% endunless %}">
      {{
        section.settings.video_1
        | video_tag:
          poster: nil,
          autoplay: true,
          loop: true,
          controls: false,
          muted: true,
          class: 'hero__media',
          data-testid: 'hero-desktop-video-1'
      }}
    </div>
  {% endif %}

  {% if use_mobile_media and mobile_media == 'video' %}
    <div class="hero__media-item hero__media-item--mobile">
      {{
        section.settings.video_1_mobile
        | video_tag:
          poster: nil,
          autoplay: true,
          loop: true,
          controls: false,
          muted: true,
          class: 'hero__media',
          data-testid: 'hero-mobile-video-1'
      }}
    </div>
  {% elsif use_mobile_media and desktop_media != 'image' and mobile_media == 'image' %}
    <div class="hero__media-item hero__media-item--mobile">
      {{
        section.settings.image_1_mobile
        | image_url: width: 1600
        | image_tag:
          width: section.settings.image_1_mobile.width,
          widths: mobile_widths,
          height: section.settings.image_1_mobile.height,
          alt: section.settings.image_1_mobile.alt,
          class: 'hero__media',
          sizes: '100vw',
          fetchpriority: fetch_priority,
          data-testid: 'hero-mobile-image-1'
      }}
    </div>
  {% endif %}

  {% if desktop_media == 'none' and use_mobile_media == false %}
    {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero__media' }}
  {% endif %}
{% endcapture %}

{% assign hero_eyebrow = '' %}
{% assign hero_heading = '' %}
{% assign hero_description = '' %}
{% assign hero_actions = '' %}

{% for block in section.blocks %}
  {% capture block_markup %}
    {% case block.type %}
      {% when 'text' %}
        {% render 'text', block: block %}
      {% when 'button' %}
        {% render 'button', link: block.settings.link, block: block %}
      {% when 'jumbo-text' %}
        {% render 'jumbo-text', block: block %}
    {% endcase %}
  {% endcapture %}

  {% if block_markup != blank %}
    {% liquid
      assign block_preset = block.settings.type_preset | default: ''
      assign block_font_size = block.settings.font_size | downcase | default: ''
      assign block_text = block.settings.text | strip_html | strip
      assign is_heading_text = false
      assign is_eyebrow_text = false

      if block_preset == 'h1' or block_preset == 'h2' or block_preset == 'h3' or block_preset == 'h4' or block_preset == 'h5'
        assign is_heading_text = true
      endif
      if block_font_size contains 'heading'
        assign is_heading_text = true
      endif
      if block_preset == 'h6' or block_preset == 'custom'
        assign is_eyebrow_text = true
      endif
    %}

    {% case block.type %}
      {% when 'button' %}
        {% capture hero_actions %}{{ hero_actions }}{{ block_markup }}{% endcapture %}
      {% when 'jumbo-text' %}
        {% if hero_heading == blank %}
          {% assign hero_heading = block_markup %}
        {% else %}
          {% capture hero_description %}{{ hero_description }}{{ block_markup }}{% endcapture %}
        {% endif %}
      {% when 'text' %}
        {% if block_text != blank %}
          {% if hero_eyebrow == blank and hero_heading == blank and is_eyebrow_text and is_heading_text == false %}
            {% assign hero_eyebrow = block_markup %}
          {% elsif hero_heading == blank %}
            {% assign hero_heading = block_markup %}
          {% else %}
            {% capture hero_description %}{{ hero_description }}{{ block_markup }}{% endcapture %}
          {% endif %}
        {% endif %}
    {% endcase %}
  {% endif %}
{% endfor %}

<div
  id="Hero-{{ section.id }}"
  class="hero{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}{% if hero_is_auto_height %} hero--height-auto{% endif %}"
  style="
    --hero-content-x: {{ section.settings.horizontal_alignment_flex_direction_column }};
    --hero-content-y: {{ section.settings.vertical_alignment_flex_direction_column }};
    --hero-content-y-mobile: {{ section.settings.vertical_alignment_flex_direction_column }};
    --hero-content-width: min(100%, 42rem);
    --hero-slot-align: {{ hero_slot_align }};
    --hero-text-align: {{ hero_text_align }};
    {% if primary_image != blank %}--hero-media-aspect-ratio: {{ primary_image.aspect_ratio }};{% endif %}
    {% if section.settings.section_height == 'custom' %}
      --hero-min-height: {{ section.settings.section_height_custom }}svh;
    {% elsif section.settings.section_height == 'full-screen' %}
      --hero-min-height: 100svh;
    {% elsif section.settings.section_height != 'auto' %}
      --hero-min-height: var(--section-height-{{ section.settings.section_height }});
    {% endif %}
  "
  {% if hero_has_visual_preview %}
    data-shopify-visual-preview
  {% endif %}
>
  <div
    class="hero__section spacing-style section section--full-width"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    <div class="hero__background" data-testid="hero-media-wrapper">
      <div class="hero__media-grid">
        {{ hero_media }}
      </div>
      {% if section.settings.toggle_overlay %}
        <div class="hero__overlay">
          {% render 'overlay', settings: section.settings, layer: '0' %}
        </div>
      {% endif %}
    </div>

    <div class="hero__content-shell hero__content-shell--{{ section.settings.section_width }}">
      <div class="hero__content">
        {% if hero_eyebrow != blank %}
          <div class="hero__slot hero__eyebrow">
            {{ hero_eyebrow }}
          </div>
        {% endif %}
        {% if hero_heading != blank %}
          <div class="hero__slot hero__heading">
            {{ hero_heading }}
          </div>
        {% endif %}
        {% if hero_description != blank %}
          <div class="hero__slot hero__description">
            {{ hero_description }}
          </div>
        {% endif %}
        {% if hero_actions != blank %}
          <div class="hero__slot hero__actions">
            {{ hero_actions }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .hero-wrapper {
    --hero-height-offset: 0px;
  }

  body:has(#header-group > .header-section > #header-component) .hero-wrapper:first-child {
    --hero-height-offset: var(--header-group-height, 0);
  }

  .hero {
    position: relative;
    isolation: isolate;
    min-height: max(0px, calc(var(--hero-min-height, 0px) - var(--hero-height-offset)));
  }

  .hero[data-shopify-visual-preview] {
    min-height: 600px;
  }

  .hero__section {
    position: relative;
    min-height: inherit;
    overflow: hidden;
    z-index: var(--layer-base);
  }

  .hero__background {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: var(--color-background);
  }

  .hero__media-grid {
    position: absolute;
    inset: 0;
  }

  .hero__media-item,
  .hero__media-item--all,
  .hero__media-grid > .placeholder-svg {
    position: absolute;
    inset: 0;
  }

  .hero__media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .hero__content-shell {
    position: relative;
    z-index: 2;
    min-height: inherit;
    display: grid;
    align-items: var(--hero-content-y-mobile);
    padding-block: clamp(1.5rem, 5vw, 3rem);
    pointer-events: none;
  }

  .hero__content-shell--page-width {
    grid-column: 2;
  }

  .hero__content-shell--full-width {
    grid-column: 1 / -1;
    padding-inline: var(--page-margin);
  }

  .hero__content {
    width: var(--hero-content-width);
    max-width: 100%;
    justify-self: var(--hero-content-x);
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 2vw, 1.5rem);
    text-align: var(--hero-text-align);
    pointer-events: auto;
  }

  .hero__slot,
  .hero__slot > * {
    min-width: 0;
    max-width: 100%;
  }

  .hero__slot :is(.text-block, jumbo-text) {
    width: 100%;
    max-width: 100%;
  }

  .hero__slot .text-block {
    align-items: var(--hero-slot-align);
  }

  .hero__eyebrow :is(.text-block > *, jumbo-text) {
    color: var(--color-primary-button-background);
    font-size: clamp(0.82rem, 1vw, 0.96rem);
    line-height: 1.2;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero__heading :is(.text-block > *, jumbo-text) {
    color: var(--color-foreground);
    line-height: 0.95;
    letter-spacing: -0.045em;
    max-inline-size: min(12ch, 100%);
    text-wrap: balance;
  }

  .hero__heading .text-block > * {
    font-size: clamp(2.5rem, 7vw, 4.5rem);
  }

  .hero__heading jumbo-text {
    max-width: min(12ch, 100%);
  }

  .hero__description {
    max-width: min(100%, 38rem);
  }

  .hero__description .text-block > *,
  .hero__description rte-formatter,
  .hero__description rte-formatter > * {
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.875rem 1rem;
  }

  .hero__actions > * {
    flex: 0 0 auto;
  }

  .hero__actions :is(.button, .button-secondary, .button-custom) {
    min-height: max(48px, var(--minimum-touch-target));
    box-shadow: none;
  }

  .hero__actions .button-unstyled {
    min-height: auto;
    padding-inline: 0;
  }

  .hero--height-auto {
    min-height: 0;
  }

  .hero--height-auto .hero__section {
    min-height: 0;
  }

  .hero--height-auto .hero__background,
  .hero--height-auto .hero__media-grid {
    position: relative;
  }

  .hero--height-auto .hero__content-shell {
    position: absolute;
    inset: 0;
  }

  .hero--height-auto :is(.hero__media, .hero__media-grid > .placeholder-svg) {
    aspect-ratio: var(--hero-media-aspect-ratio, 16 / 9);
  }

  .hero__media-item--mobile {
    display: none;
  }

  .hero__media-item--desktop,
  .hero__media-item--all {
    display: block;
  }

  @media screen and (min-width: 750px) {
    .hero__content-shell {
      align-items: var(--hero-content-y);
      padding-block: clamp(2rem, 5vw, 4rem);
    }
  }

  @media screen and (max-width: 749px) {
    .hero__media-item--desktop {
      display: none;
    }

    .hero__media-item--mobile,
    .hero__media-item--all {
      display: block;
    }

    .hero__content-shell {
      padding-block: clamp(1rem, 4vw, 2rem);
    }

    .hero__content {
      width: min(100%, 32rem);
      gap: 1rem;
    }

    .hero__heading .text-block > * {
      font-size: clamp(2.2rem, 9vw, 3.25rem);
      max-inline-size: 11ch;
    }

    .hero__description {
      max-width: 100%;
    }

    .hero__actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero__actions > * {
      width: 100%;
    }

    .hero__actions :is(.button, .button-secondary, .button-custom) {
      width: 100%;
      justify-content: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.hero",
  "tag": "section",
  "class": "hero-wrapper section-wrapper",
  "blocks": [
    {
      "type": "text"
    },
    {
      "type": "button"
    },
    {
      "type": "jumbo-text"
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.media_1"
    },
    {
      "type": "select",
      "id": "media_type_1",
      "label": "t:settings.type",
      "options": [
        {
          "value": "image",
          "label": "t:options.image"
        },
        {
          "value": "video",
          "label": "t:options.video"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "t:settings.image",
      "visible_if": "{{ section.settings.media_type_1 == 'image' }}"
    },
    {
      "type": "video",
      "id": "video_1",
      "label": "t:settings.video",
      "visible_if": "{{ section.settings.media_type_1 == 'video' }}"
    },
    {
      "type": "header",
      "content": "t:content.mobile_media"
    },
    {
      "type": "checkbox",
      "id": "custom_mobile_media",
      "label": "t:settings.custom_mobile_media",
      "default": false
    },
    {
      "type": "header",
      "content": "t:content.mobile_media_1",
      "visible_if": "{{ section.settings.custom_mobile_media }}"
    },
    {
      "type": "select",
      "id": "media_type_1_mobile",
      "label": "t:settings.type",
      "options": [
        {
          "value": "image",
          "label": "t:options.image"
        },
        {
          "value": "video",
          "label": "t:options.video"
        }
      ],
      "default": "image",
      "visible_if": "{{ section.settings.custom_mobile_media }}"
    },
    {
      "type": "image_picker",
      "id": "image_1_mobile",
      "label": "t:settings.image",
      "visible_if": "{{ section.settings.custom_mobile_media and section.settings.media_type_1_mobile == 'image' }}"
    },
    {
      "type": "video",
      "id": "video_1_mobile",
      "label": "t:settings.video",
      "visible_if": "{{ section.settings.custom_mobile_media and section.settings.media_type_1_mobile == 'video' }}"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "horizontal_alignment_flex_direction_column",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.right"
        }
      ],
      "default": "flex-start"
    },
    {
      "type": "select",
      "id": "vertical_alignment_flex_direction_column",
      "label": "t:settings.position",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.top"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.bottom"
        }
      ],
      "default": "flex-end"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "t:settings.height",
      "options": [
        {
          "value": "auto",
          "label": "t:options.auto"
        },
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "medium",
          "label": "t:options.medium"
        },
        {
          "value": "large",
          "label": "t:options.large"
        },
        {
          "value": "full-screen",
          "label": "t:options.full_screen"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "large"
    },
    {
      "type": "range",
      "id": "section_height_custom",
      "label": "t:settings.custom_height",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 50,
      "unit": "%",
      "visible_if": "{{ section.settings.section_height == 'custom' }}"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "checkbox",
      "id": "toggle_overlay",
      "label": "t:settings.media_overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "t:settings.overlay_color",
      "alpha": true,
      "default": "#00000026",
      "visible_if": "{{ section.settings.toggle_overlay }}"
    },
    {
      "type": "select",
      "id": "overlay_style",
      "label": "t:settings.overlay_style",
      "options": [
        {
          "value": "solid",
          "label": "t:options.solid"
        },
        {
          "value": "gradient",
          "label": "t:options.gradient"
        }
      ],
      "default": "solid",
      "visible_if": "{{ section.settings.toggle_overlay }}"
    },
    {
      "type": "select",
      "id": "gradient_direction",
      "label": "t:settings.gradient_direction",
      "options": [
        {
          "value": "to top",
          "label": "t:options.up"
        },
        {
          "value": "to bottom",
          "label": "t:options.down"
        }
      ],
      "default": "to top",
      "visible_if": "{{ section.settings.toggle_overlay and section.settings.overlay_style == 'gradient' }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.hero",
      "category": "t:categories.banners",
      "blocks": {
        "text_1": {
          "type": "text",
          "settings": {
            "text": "t:html_defaults.new_arrivals_h2",
            "type_preset": "h1",
            "max_width": "narrow"
          }
        },
        "text_2": {
          "type": "text",
          "settings": {
            "text": "t:html_defaults.made_with_care",
            "max_width": "narrow",
            "padding-block-end": 32
          }
        },
        "button": {
          "type": "button",
          "name": "t:names.button",
          "settings": {
            "label": "t:text_defaults.shop_now_button_label",
            "link": "shopify://collections/all"
          }
        }
      },
      "block_order": ["text_1", "text_2", "button"],
      "settings": {
        "horizontal_alignment_flex_direction_column": "center",
        "section_height": "large",
        "padding-block-start": 40,
        "padding-block-end": 40,
        "toggle_overlay": true,
        "overlay_style": "gradient"
      }
    }
  ]
}
{% endschema %}
